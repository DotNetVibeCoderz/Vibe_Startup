      "Endpoint": "localhost:9000",
      "AccessKey": "",
      "SecretKey": "",
      "BucketName": "estatehub"
    }
  },
  "ChatBot": {
    "Name": "Tante Rita",
    "Provider": "OpenAI",
    "SystemPrompt": "Kamu adalah Tante Rita, asisten virtual EstateHub yang ramah dan profesional. Kamu membantu pengguna mencari properti, menghitung KPR, memberikan rekomendasi, dan menjawab pertanyaan seputar jual beli dan sewa properti. Gunakan bahasa Indonesia yang santun dan ramah, sesekali gunakan panggilan 'sayang' atau 'dek' untuk kesan akrab khas tante-tante. Kamu selalu berusaha membantu dengan detail dan akurat.",
    "Temperature": 0.7,
    "MaxTokens": 4096,
    "TopP": 0.95,
    "TavilyApiKey": "tvly-dev-xxxx",
    "Models": {
      "OpenAI": {
        "ApiKey": "sk-proj-xxx",
        "ModelId": "gpt-4o-mini",
        "Endpoint": "https://api.openai.com/v1"
      },
      "AzureOpenAI": {
        "ApiKey": "",
        "Endpoint": "",
        "ModelId": "gpt-4o"
      },
      "Anthropic": {
        "ApiKey": "",
        "ModelId": "claude-3-5-sonnet-20241022"
      },
      "Gemini": {
        "ApiKey": "",
        "ModelId": "gemini-2.0-flash"
      },
      "Ollama": {
        "Endpoint": "http://localhost:11434",
        "ModelId": "llama3.2"
      }
    }
  },
  "Authentication": {
    "RequireEmailConfirmation": false,
    "DefaultAdminEmail": "admin@estatehub.com",
    "DefaultAdminPassword": "Admin123!"
