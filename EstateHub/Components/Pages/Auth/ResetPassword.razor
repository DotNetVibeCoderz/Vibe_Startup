@page "/reset-password"
@layout EstateHub.Components.Layout.AuthLayout
@inject NavigationManager Navigation

<div class="auth-card fade-in">
    <div class="auth-header text-center mb-6">
        <MudIcon Icon="@Icons.Material.Filled.LockReset" Size="Size.Large" Color="Color.Primary" />
        <MudText Typo="Typo.h4" Style="font-weight:800;" Class="mt-2">Reset Password</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Masukkan email Anda untuk reset password</MudText>
    </div>
    <MudPaper Elevation="2" Class="pa-6" Style="border-radius:16px;">
        @if (!_sent)
        {
            <MudTextField @bind-Value="_email" Label="Email" Variant="Variant.Outlined"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" Class="mb-4" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large"
                       OnClick="SendResetLink" Style="border-radius:12px; font-weight:600;">
                Kirim Link Reset
            </MudButton>
        }
        else
        {
            <MudAlert Severity="Severity.Success" Style="border-radius:12px;">
                <MudText Typo="Typo.body1" Style="font-weight:600;">✅ Link reset password telah dikirim!</MudText>
                <MudText Typo="Typo.body2">Cek inbox email <strong>@_email</strong> untuk instruksi selanjutnya.</MudText>
            </MudAlert>
        }
        <MudDivider Class="my-4" />
        <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/login">
            ← Kembali ke Login
        </MudButton>
    </MudPaper>
</div>

@code {
    private string _email = "";
    private bool _sent;
    private async Task SendResetLink() { await Task.Delay(800); _sent = true; }
}
