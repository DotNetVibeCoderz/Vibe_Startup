@page "/admin/dashboard"
@page "/admin/users"
@page "/admin/properties"
@page "/admin/transactions"
@page "/admin/reports"
@using EstateHub.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db

<PageTitle>Dashboard Admin - EstateHub</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-4">
    <MudText Typo="Typo.h4" Style="font-weight:700;" Class="mb-2">Dashboard Admin</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">Panel kontrol admin EstateHub</MudText>

    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4" Style="border-radius:16px; background:linear-gradient(135deg, #667eea, #764ba2); color:white;">
                <MudText Typo="Typo.caption">Total Pengguna</MudText>
                <MudText Typo="Typo.h3" Style="font-weight:800;">@_totalUsers</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4" Style="border-radius:16px; background:linear-gradient(135deg, #2563EB, #3B82F6); color:white;">
                <MudText Typo="Typo.caption">Total Properti</MudText>
                <MudText Typo="Typo.h3" Style="font-weight:800;">@_totalProperties</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4" Style="border-radius:16px; background:linear-gradient(135deg, #059669, #10B981); color:white;">
                <MudText Typo="Typo.caption">Total Transaksi</MudText>
                <MudText Typo="Typo.h3" Style="font-weight:800;">@_totalTransactions</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4" Style="border-radius:16px; background:linear-gradient(135deg, #DC2626, #EF4444); color:white;">
                <MudText Typo="Typo.caption">Kontrak Aktif</MudText>
                <MudText Typo="Typo.h3" Style="font-weight:800;">@_activeContracts</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="1" Class="pa-4" Style="border-radius:16px;">
        <MudTabs Elevation="0" Position="Position.Top" Border="true" Rounded="true">
            <MudTabPanel Text="Manajemen User">
                <MudTable Items="@_users" Hover="true" Dense="true" Striped="true">
                    <HeaderContent><MudTh>Nama</MudTh><MudTh>Role</MudTh><MudTh>Telepon</MudTh></HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.FullName</MudTd>
                        <MudTd><MudChip T="string" Size="Size.Small">@context.Role</MudChip></MudTd>
                        <MudTd>@context.PhoneNumber</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudTabPanel>
            <MudTabPanel Text="Verifikasi Properti">
                <MudTable Items="@_allProperties" Hover="true" Dense="true" Striped="true">
                    <HeaderContent><MudTh>ID</MudTh><MudTh>Properti</MudTh><MudTh>Status</MudTh></HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Id</MudTd>
                        <MudTd>@context.Title</MudTd>
                        <MudTd>@context.Status</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudTabPanel>
            <MudTabPanel Text="Export Data">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                           Href="/api/export/properties/csv" Class="mb-2">📥 Export CSV</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Tertiary" FullWidth="true"
                           Href="/api/export/properties/excel">📥 Export Excel</MudButton>
            </MudTabPanel>
        </MudTabs>
    </MudPaper>
</MudContainer>

@code {
    private int _totalUsers;
    private int _totalProperties;
    private int _totalTransactions;
    private int _activeContracts;
    private List<ApplicationUser> _users = new();
    private List<Property> _allProperties = new();
    private List<Payment> _payments = new();

    protected override async Task OnInitializedAsync()
    {
        _users = await Db.Users.ToListAsync();
        _allProperties = await Db.Properties.ToListAsync();
        _payments = await Db.Payments.ToListAsync();
        _totalUsers = _users.Count;
        _totalProperties = _allProperties.Count;
        _totalTransactions = _payments.Count;
        _activeContracts = (await Db.Contracts.ToListAsync()).Count(c => c.Status == "Active");
    }
}
