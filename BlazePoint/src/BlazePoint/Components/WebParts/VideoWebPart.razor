@* SharePoint-style Video embed: YouTube URL or direct .mp4 link. *@

@if (_isYouTube)
{
    <div style="position:relative;padding-bottom:56.25%;height:0;border-radius:8px;overflow:hidden">
        <iframe src="@_embedUrl" style="position:absolute;inset:0;width:100%;height:100%;border:0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen></iframe>
    </div>
}
else
{
    <video controls style="width:100%;border-radius:8px" src="@_embedUrl"></video>
}
@if (!string.IsNullOrEmpty(Settings.GetValueOrDefault("caption", "")))
{
    <div class="bp-muted" style="margin-top:6px">@Settings["caption"]</div>
}

@code {
    [Parameter] public Dictionary<string, string> Settings { get; set; } = [];

    private bool _isYouTube;
    private string _embedUrl = "";

    protected override void OnParametersSet()
    {
        var url = Settings.GetValueOrDefault("url", "https://www.youtube.com/watch?v=dQw4w9WgXcQ");
        _isYouTube = url.Contains("youtube.com") || url.Contains("youtu.be");
        if (_isYouTube)
        {
            var id = url.Contains("youtu.be/")
                ? url.Split("youtu.be/")[1].Split('?')[0]
                : url.Contains("v=") ? url.Split("v=")[1].Split('&')[0] : url.Split('/')[^1];
            _embedUrl = $"https://www.youtube.com/embed/{id}";
        }
        else
        {
            _embedUrl = url;
        }
    }
}
