<figure style="margin:0">
    <img src="@Settings.GetValueOrDefault("url", "")" alt="@Settings.GetValueOrDefault("caption", "")"
         style="width:100%;border-radius:8px" />
    @if (!string.IsNullOrEmpty(Settings.GetValueOrDefault("caption", "")))
    {
        <figcaption class="bp-muted" style="margin-top:6px">@Settings["caption"]</figcaption>
    }
</figure>

@code {
    [Parameter] public Dictionary<string, string> Settings { get; set; } = [];
}
