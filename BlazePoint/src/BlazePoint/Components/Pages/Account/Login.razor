@page "/account/login"
@layout EmptyLayout

<PageTitle>Masuk — BlazePoint</PageTitle>

<div class="bp-auth-page">
    <div class="bp-auth-hero">
        <div class="brand">🔷 BlazePoint</div>
        <p>Portal kolaborasi modern: dokumen, workflow, team sites, dan asisten AI dalam satu tempat.</p>
        <div class="bp-card bp-mt">
            <strong>Akun demo</strong>
            <table class="bp-table">
                <tbody>
                    <tr><td>👑 Admin</td><td><code>admin@blazepoint.local</code></td></tr>
                    <tr><td>✏️ Editor</td><td><code>editor@blazepoint.local</code></td></tr>
                    <tr><td>👁️ Viewer</td><td><code>viewer@blazepoint.local</code></td></tr>
                </tbody>
            </table>
            <div class="bp-muted">Password semua akun: <code>Blaze123!</code></div>
        </div>
    </div>

    <div class="bp-auth-card">
        @if (Error is not null)
        {
            <div class="bp-error">Email atau password salah. Coba lagi.</div>
        }
        @if (Reset is not null)
        {
            <div class="bp-success">Password berhasil direset. Silakan masuk.</div>
        }
        <form method="post" action="/auth/login">
            <input type="hidden" name="returnUrl" value="@(ReturnUrl ?? "/")" />
            <input class="bp-input" type="email" name="email" placeholder="Email" required autofocus />
            <input class="bp-input" type="password" name="password" placeholder="Password" required />
            <button type="submit" class="bp-btn">Masuk</button>
        </form>
        <div style="text-align:center;margin-top:14px">
            <a href="/account/forgot">Lupa password?</a>
        </div>
        <hr style="border-color:var(--divider)" />
        <div style="text-align:center">
            <a class="bp-btn success" style="width:auto;padding:10px 18px" href="/account/register">Buat akun baru</a>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")] public string? Error { get; set; }
    [SupplyParameterFromQuery(Name = "reset")] public string? Reset { get; set; }
    [SupplyParameterFromQuery(Name = "returnUrl")] public string? ReturnUrl { get; set; }
}
