@page "/register"
@layout LoginLayout
@attribute [AllowAnonymous]
@inject IAuthService AuthService
@inject NavigationManager Navigation

<div style="text-align:center;margin-bottom:28px;">
    <div style="font-size:48px;">👤</div>
    <h1 style="font-size:26px;font-weight:800;margin:8px 0 4px;">Register</h1>
    <p style="color:var(--text-secondary);">Buat akun PCHub baru</p>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_success ? "alert-success" : "alert-danger")">@_message</div>
}

<form @onsubmit="HandleRegister" style="display:flex;flex-direction:column;gap:12px;">
    <div class="form-group">
        <label>Full Name</label>
        <input class="form-control" @bind="_fullName" placeholder="Nama lengkap" required />
    </div>
    <div class="form-group">
        <label>Username</label>
        <input class="form-control" @bind="_username" placeholder="Username" required />
    </div>
    <div class="form-group">
        <label>Email</label>
        <input class="form-control" type="email" @bind="_email" placeholder="email@example.com" required />
    </div>
    <div class="form-group">
        <label>Phone (optional)</label>
        <input class="form-control" @bind="_phone" placeholder="08123456789" />
    </div>
    <div class="form-group">
        <label>Password</label>
        <input class="form-control" type="password" @bind="_password" placeholder="Min. 6 karakter" required />
    </div>
    <button type="submit" class="btn btn-primary" style="width:100%;padding:14px;font-size:16px;" disabled="@_isLoading">
        @(_isLoading ? "Registering..." : "📝 Daftar")
    </button>
</form>

<div style="text-align:center;margin-top:20px;font-size:13px;">
    <span style="color:var(--text-secondary);">Sudah punya akun? </span>
    <a href="/login">Login di sini</a>
</div>

@code {
    private string _fullName = "", _username = "", _email = "", _phone = "", _password = "";
    private string _message = ""; private bool _success, _isLoading;

    private async Task HandleRegister()
    {
        _isLoading = true; _message = "";
        try
        {
            var result = await AuthService.RegisterAsync(new RegisterRequest(_username, _email, _password, _fullName, string.IsNullOrWhiteSpace(_phone) ? null : _phone));
            if (result != null)
            {
                _success = true;
                _message = "✅ Registrasi berhasil! Redirect ke login...";
                await Task.Delay(1500);
                Navigation.NavigateTo("/login", forceLoad: true);
            }
            else
            {
                _message = "❌ Username atau email sudah terdaftar.";
            }
        }
        catch (Exception ex)
        {
            _message = $"❌ Error: {ex.Message}";
        }
        finally { _isLoading = false; }
    }
}
