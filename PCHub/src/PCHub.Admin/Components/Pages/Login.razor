@page "/login"
@layout LoginLayout
@attribute [AllowAnonymous]
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject PCHub.Admin.Services.PCHubAuthStateProvider AuthState

@if (!string.IsNullOrEmpty(_error))
{
    <div style="background:#FEE2E2;color:#991B1B;padding:12px;border:2px solid #991B1B;border-radius:8px;margin-bottom:16px;font-weight:600;">
        ⚠️ @_error
    </div>
}

<div style="text-align:center;margin-bottom:28px;">
    <div style="font-size:56px;">🎮</div>
    <h1 style="font-size:28px;font-weight:800;margin:8px 0 4px;color:var(--text);">PCHub Admin</h1>
    <p style="color:var(--text-secondary);font-size:14px;">Game Center Management</p>
</div>

<form @onsubmit="HandleLogin" style="display:flex;flex-direction:column;gap:12px;">
    <div class="form-group">
        <label>Username or Email</label>
        <input class="form-control" @bind="_username" @bind:event="oninput" placeholder="admin" />
    </div>
    <div class="form-group">
        <label>Password</label>
        <input class="form-control" type="password" @bind="_password" @bind:event="oninput" placeholder="••••••••" />
    </div>
    <button type="submit" class="btn btn-primary" style="width:100%;padding:14px;font-size:16px;" disabled="@_isLoading">
        @(_isLoading ? "Logging in..." : "🔐 Login")
    </button>
</form>

<div style="text-align:center;margin-top:20px;font-size:13px;color:var(--text-secondary);">
    <p>Demo: <strong>admin</strong> / <strong>Admin123!</strong></p>
    <p style="margin-top:8px;">Belum punya akun? <a href="/register">Daftar di sini</a></p>
</div>

@code {
    private string _username = "admin", _password = "Admin123!";
    private string? _error;
    private bool _isLoading;

    protected override void OnInitialized()
    {
        // Jika sudah login, redirect ke dashboard
        if (AuthState.IsAuthenticated)
            Navigation.NavigateTo("/");
    }

    private async Task HandleLogin()
    {
        _error = null;
        _isLoading = true;
        try
        {
            var result = await AuthService.LoginAsync(new LoginRequest(_username, _password));
            if (result == null)
            {
                _error = "Username atau password salah.";
                return;
            }

            // Set state login di circuit (tanpa cookie redirect!)
            AuthState.Login(
                result.UserId.ToString(),
                result.Username,
                result.Email,
                result.Role,
                result.FullName);

            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
