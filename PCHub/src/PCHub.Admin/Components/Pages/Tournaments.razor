@page "/tournaments"
@attribute [Authorize(Roles = "Admin,Operator")]
@inject ITournamentService TournamentService

<div class="card"><div class="card-header"><h3>🏆 Tournaments</h3><button class="btn btn-primary btn-sm" @onclick="ShowAdd">+ Create</button></div></div>
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px;">@if(_data!=null){@foreach(var t in _data.Items){<div class="card"><div style="font-size:32px;">🏆</div><h3>@t.Name</h3><div style="margin:12px 0;font-size:13px;">🎮 <strong>@(t.GameName??"Any")</strong><br/>📅 @t.StartDate.ToString("dd MMM") - @t.EndDate.ToString("dd MMM")<br/>💰 Prize: <strong>@Helpers.FormatCurrency(t.PrizePool)</strong><br/>👥 @t.ParticipantCount/@t.MaxParticipants</div><span class="badge @(t.IsActive?"badge-success":"badge-danger")">@(t.IsActive?"Active":"Inactive")</span></div>}}</div>
@if(_show){<div class="modal-overlay" @onclick="()=>_show=false"><div class="modal-content" @onclick:stopPropagation="true"><h3>Create Tournament</h3><div class="form-group"><label>Name</label><input class="form-control" @bind="_fn"/></div><div class="form-group"><label>Start Date</label><InputDate class="form-control" @bind-Value="_fs"/></div><div class="form-group"><label>End Date</label><InputDate class="form-control" @bind-Value="_fe"/></div><div class="form-group"><label>Max Participants</label><input class="form-control" type="number" @bind="_fm"/></div><div class="form-group"><label>Prize Pool</label><input class="form-control" type="number" @bind="_fpr"/></div><button class="btn btn-primary" @onclick="Save">Create</button></div></div>}

@code{private PagedResult<TournamentDto>?_data;private bool _show;private string _fn="";private DateTime _fs=DateTime.Now.AddDays(7),_fe=DateTime.Now.AddDays(9);private int _fm=32;private decimal _fpr=1000000;
protected override async Task OnInitializedAsync()=>_data=await TournamentService.GetAllTournamentsPagedAsync(new PagingRequest(1,20));
void ShowAdd(){_fn="";_fs=DateTime.Now.AddDays(7);_fe=DateTime.Now.AddDays(9);_fm=32;_fpr=1000000;_show=true;}
async Task Save(){await TournamentService.CreateTournamentAsync(new TournamentCreateRequest(_fn,null,null,_fs,_fe,_fm,0,_fpr));_show=false;_data=await TournamentService.GetAllTournamentsPagedAsync(new PagingRequest(1,20));}}
