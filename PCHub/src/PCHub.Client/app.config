<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- Server Connection -->
    <add key="ApiBaseUrl" value="https://localhost:5001/api"/>

    <!-- Appearance -->
    <add key="DarkMode" value="false"/>
    <add key="Language" value="id"/>

    <!-- Client Identity -->
    <add key="PcId" value="PC-001"/>
    <add key="PcName" value="PC-Client"/>
    <add key="ClientVersion" value="1.0.0"/>

    <!-- Session -->
    <add key="DefaultSessionDurationMinutes" value="60"/>
    <add key="SessionWarningMinutes" value="5"/>

    <!-- Resource Monitoring -->
    <add key="EnableResourceMonitoring" value="true"/>
    <add key="MonitoringIntervalSeconds" value="5"/>

    <!-- Notifications -->
    <add key="EnableNotifications" value="true"/>
    <add key="NotificationPollIntervalSeconds" value="30"/>

    <!-- Auto Update -->
    <add key="EnableAutoUpdate" value="true"/>
    <add key="UpdateCheckIntervalHours" value="24"/>

    <!-- Screen Lock -->
    <add key="EnableScreenLock" value="true"/>

    <!-- Logging -->
    <add key="EnableLogging" value="true"/>
    <add key="LogLevel" value="Information"/>
  </appSettings>
</configuration>
