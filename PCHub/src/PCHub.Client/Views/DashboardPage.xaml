<UserControl x:Class="PCHub.Client.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!-- Header -->
            <Grid Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="📊 Dashboard" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock x:Name="TxtWelcome" Text="Welcome back!" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Stat Cards -->
            <WrapPanel Margin="0,0,0,16">
                <!-- Total Users -->
                <Border Style="{StaticResource NeoCard}" Width="220" Margin="0,0,12,12" Cursor="Hand">
                    <StackPanel>
                        <TextBlock Text="👥" FontSize="32"/>
                        <TextBlock Text="Total Users" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TxtTotalUsers" Text="--" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Available PCs -->
                <Border Style="{StaticResource NeoCard}" Width="220" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="🖥️" FontSize="32"/>
                        <TextBlock Text="Available PCs" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TxtAvailablePcs" Text="--" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Today Revenue -->
                <Border Style="{StaticResource NeoCard}" Width="220" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="💰" FontSize="32"/>
                        <TextBlock Text="Today Revenue" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TxtRevenue" Text="--" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Active Sessions -->
                <Border Style="{StaticResource NeoCard}" Width="220" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="🎮" FontSize="32"/>
                        <TextBlock Text="Active Sessions" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TxtSessions" Text="--" FontSize="28" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Active Session -->
            <Border Style="{StaticResource NeoCard}" Margin="0,0,0,12" Background="{StaticResource TimerBgBrush}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🎮 Your Active Session" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                        <Button Grid.Column="1" Content="🔄 Refresh" Style="{StaticResource NeoButton}" 
                                FontSize="11" Padding="10,4" Click="Refresh_Click"/>
                    </Grid>
                    <TextBlock x:Name="TxtActiveSession" Text="No active session" 
                               FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <StackPanel x:Name="ActiveSessionPanel" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                        <Button x:Name="BtnStopSession" Content="⏹ Stop Session" Style="{StaticResource DangerButton}" 
                                FontSize="13" Padding="16,8" Click="BtnStopSession_Click"/>
                        <TextBlock x:Name="TxtSessionDuration" Text="" FontSize="14" 
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Popular Games & Promos -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Popular Games -->
                <Border Style="{StaticResource NeoCard}" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="🔥 Popular Games" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                        <ItemsControl x:Name="PopularGamesList"/>
                    </StackPanel>
                </Border>

                <!-- Active Promos -->
                <Border Style="{StaticResource NeoCard}" Grid.Column="1" Margin="6,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🎉 Active Promos" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                        <ItemsControl x:Name="PromosList"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Loading -->
            <TextBlock x:Name="TxtLoading" Text="Loading..." FontSize="12" 
                       Foreground="{StaticResource TextSecondaryBrush}" 
                       HorizontalAlignment="Center" Margin="0,12,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
