<UserControl x:Class="PCHub.Client.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="⚙️ Settings" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>

            <!-- Server Connection -->
            <Border Style="{StaticResource NeoCard}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="🔗 Server Connection" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="API Base URL" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="{StaticResource TextBrush}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ApiUrlBox" Style="{StaticResource NeoTextBox}" Text="https://localhost:5001/api"/>
                        <Button Grid.Column="1" Content="Test" Style="{StaticResource NeoButton}" 
                                FontSize="12" Padding="12,8" Margin="8,0,0,0" Click="TestConnection_Click"/>
                    </Grid>
                    <TextBlock x:Name="TxtConnectionStatus" Text="" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Appearance -->
            <Border Style="{StaticResource NeoCard}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="🎨 Appearance" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <CheckBox x:Name="DarkModeCheck" Content="Dark Mode" Margin="0,0,0,8" Checked="DarkModeCheck_Changed" Unchecked="DarkModeCheck_Changed"/>
                    <TextBlock Text="🌐 Language" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="LanguageBox" SelectedIndex="0" SelectionChanged="LanguageBox_Changed"
                              Style="{StaticResource NeoComboBox}" Width="200" HorizontalAlignment="Left">
                        <ComboBoxItem Content="🇮🇩 Bahasa Indonesia"/>
                        <ComboBoxItem Content="🇬🇧 English"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- System Info -->
            <Border Style="{StaticResource NeoCard}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="💻 System Info" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtMachineName" Text="Machine: --" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="TxtOs" Text="OS: --" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="TxtProcessor" Text="CPU: --" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="TxtCpu" Text="CPU Usage: --" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="TxtRam" Text="RAM: --" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="TxtMemory" Text="Memory: --" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="TxtVersion" Text="PCHub Client v1.0.0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                </StackPanel>
            </Border>

            <!-- Updates -->
            <Border Style="{StaticResource NeoCard}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="🔄 Updates" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <Button Content="🔍 Check for Updates" Style="{StaticResource NeoButton}" 
                            Width="200" HorizontalAlignment="Left" Click="CheckUpdates_Click"/>
                    <TextBlock x:Name="TxtUpdateStatus" Text="" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Save Button -->
            <Button Content="💾 Save Settings" Style="{StaticResource PrimaryButton}" Width="160" Click="SaveSettings_Click"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
