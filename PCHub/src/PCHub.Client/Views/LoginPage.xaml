<UserControl x:Class="PCHub.Client.Views.LoginPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <Grid>
        <Border Style="{StaticResource NeoCard}" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="32">
            <StackPanel>
                <TextBlock Text="🎮" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="PCHub Game Center" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Login to your account" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,20"/>

                <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}" FontSize="12" Margin="0,0,0,8" Visibility="Collapsed"/>

                <TextBlock Text="Username" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="UsernameBox" Style="{StaticResource NeoTextBox}" Margin="0,0,0,12"/>

                <TextBlock Text="Password" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource NeoPasswordBox}" Margin="0,0,0,20"/>

                <Button x:Name="LoginBtn" Content="Login" Style="{StaticResource PrimaryButton}" 
                        Height="48" FontSize="16" Click="LoginBtn_Click"/>
                <TextBlock Text="Demo: admin / Admin123!" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" 
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
