@page "/profile"
@using FastRide.RiderApp.Services
@inject ApiClient Api

<div class="p-3">
    @if (!Api.IsLoggedIn)
    {
        <p class="text-center py-5 text-muted">Please login first</p>
    }
    else if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-warning"></div></div>
    }
    else
    {
        <h5 class="fw-bold mb-3"><i class="bi bi-person-circle text-warning me-2"></i>Profile</h5>

        <div class="text-center mb-4">
            <div class="position-relative d-inline-block">
                @if (!string.IsNullOrWhiteSpace(_profile?.PhotoUrl))
                {
                    <img src="@_profile!.PhotoUrl" class="rounded-circle border border-warning border-3" style="width:80px;height:80px;object-fit:cover;" />
                }
                else
                {
                    <div class="bg-secondary rounded-circle d-inline-flex align-items-center justify-content-center" style="width:80px;height:80px;"><i class="bi bi-person-fill text-white fs-1"></i></div>
                }
            </div>
            <h5 class="mt-2 mb-0">@_profile?.FullName</h5>
            <small class="text-muted">@_profile?.Email</small>
            @if (_editingName)
            {
                <div class="mt-2 d-flex gap-2 justify-content-center">
                    <input class="form-control form-control-sm w-50" @bind="_editNameVal" placeholder="New name" />
                    <button class="btn btn-warning btn-sm" @onclick="SaveName">Save</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="CancelEdit">✕</button>
                </div>
            }
            else
            {
                <div class="mt-1"><small class="text-muted">@_profile?.PhoneNumber</small></div>
                <button class="btn btn-outline-secondary btn-sm mt-1" @onclick="StartEdit"><i class="bi bi-pencil"></i> Edit Name</button>
            }
        </div>

        <div class="list-group">
            <div class="list-group-item d-flex justify-content-between"><i class="bi bi-wallet2 me-2"></i> Payment Methods <i class="bi bi-chevron-right text-muted"></i></div>
            <div class="list-group-item d-flex justify-content-between"><i class="bi bi-tags me-2"></i> Promos <i class="bi bi-chevron-right text-muted"></i></div>
            <div class="list-group-item d-flex justify-content-between"><i class="bi bi-bell me-2"></i> Notifications <i class="bi bi-chevron-right text-muted"></i></div>
            <div class="list-group-item d-flex justify-content-between"><i class="bi bi-gear me-2"></i> Settings</div>
            <div class="list-group-item text-danger" @onclick="DoLogout"><i class="bi bi-box-arrow-right me-2"></i> Logout</div>
        </div>
    }
</div>

@code {
    private ProfileResult? _profile; private bool _loading = true;
    private bool _editingName; private string _editNameVal = "";

    protected override async Task OnInitializedAsync()
    {
        _profile = await Api.GetProfile();
        _loading = false;
    }
    private void StartEdit() { _editingName = true; _editNameVal = _profile?.FullName ?? ""; }
    private void CancelEdit() { _editingName = false; }
    private async Task SaveName() { if (!string.IsNullOrWhiteSpace(_editNameVal)) { await Api.UpdateProfile(_editNameVal, null); _profile = await Api.GetProfile(); } _editingName = false; }
    private void DoLogout() { Api.Logout(); _profile = null; }
}
