{
  "Logging": { "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Warning", "FastRide": "Debug" } },
  "AllowedHosts": "*",
  "Database": {
    "Provider": "SQLite",
    "ConnectionStrings": {
      "SQLite": "Data Source=FastRide.db",
      "SqlServer": "Server=.;Database=FastRide;Trusted_Connection=true;TrustServerCertificate=true",
      "PostgreSQL": "Host=localhost;Database=FastRide;Username=postgres;Password=postgres",
      "MySQL": "Server=localhost;Database=FastRide;User=root;Password=root"
    }
  },
  "Storage": {
    "Provider": "FileSystem",
    "FileSystem": { "Path": "uploads", "BaseUrl": "/uploads" },
    "S3": {
      "Endpoint": "https://minio.local:9000",
      "Bucket": "fastride-photos",
      "AccessKey": "minioadmin",
      "SecretKey": "minioadmin",
      "Region": "us-east-1",
      "PublicUrl": "https://minio.local:9000/fastride-photos"
    },
    "Azure": {
      "ConnectionString": "DefaultEndpointsProtocol=https;AccountName=fastride;AccountKey=...;EndpointSuffix=core.windows.net",
      "Container": "fastride-photos"
    }
  },
  "Jwt": {
    "Secret": "FastRide-Super-Secret-Key-Minimum-32-Characters-Long!",
    "Issuer": "FastRide", "Audience": "FastRide",
    "AccessTokenExpirationMinutes": 1440
  },
  "FareDefaults": {
    "Economy": { "BaseFare": 5000, "CostPerKm": 3000, "CostPerMinute": 500, "MinimumFare": 10000 },
    "Comfort": { "BaseFare": 7000, "CostPerKm": 4000, "CostPerMinute": 700, "MinimumFare": 15000 },
    "Premium": { "BaseFare": 10000, "CostPerKm": 6000, "CostPerMinute": 1000, "MinimumFare": 25000 },
    "Bike": { "BaseFare": 3000, "CostPerKm": 2000, "CostPerMinute": 300, "MinimumFare": 7000 },
    "Electric": { "BaseFare": 5000, "CostPerKm": 3000, "CostPerMinute": 500, "MinimumFare": 10000 }
  },
  "ApiSettings": {
    "BaseUrl": "https://localhost:5001",
    "CorsOrigins": ["https://localhost:5002", "http://localhost:5003"]
  },
  "Urls": "https://localhost:5001;http://localhost:5000"
}
