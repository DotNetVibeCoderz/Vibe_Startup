@page "/orders"
@inject ApiClient ApiClient

<PageTitle>FastRide Admin - Orders</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h2 class="fw-bold mb-0"><i class="bi bi-car-front-fill text-warning me-2"></i>Orders</h2><small class="text-muted">@_total orders total</small></div>
    <select class="form-select form-select-sm bg-dark text-white border-secondary w-auto" @bind="_statusFilter" @bind:after="LoadOrders">
        <option value="">All Status</option>
        <option value="Requested">Requested</option>
        <option value="Accepted">Accepted</option>
        <option value="Started">On Trip</option>
        <option value="Completed">Completed</option>
        <option value="Cancelled">Cancelled</option>
    </select>
</div>

@if (_loading) { <div class="text-center py-5"><div class="spinner-border text-warning"></div></div> }
else if (_orders.Any())
{
    <div class="card stat-card"><div class="card-body p-0">
    <table class="table table-dark table-striped table-fastride mb-0">
    <thead><tr><th>Order</th><th>Rider</th><th>Driver</th><th>Route</th><th>Fare</th><th>Status</th><th>Time</th></tr></thead>
    <tbody>
    @foreach (var o in _orders)
    {
        <tr>
            <td><code>#@o.Id.ToString()[..8]</code></td>
            <td>@o.RiderName</td>
            <td>@(o.DriverName ?? "-")</td>
            <td><small>@Trunc(o.PickupAddress,18) → @Trunc(o.DropoffAddress,18)</small></td>
            <td>Rp @o.FinalFare.ToString("N0")</td>
            <td><span class="badge @Badge(o.Status)">@o.Status</span></td>
            <td><small>@o.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</small></td>
        </tr>
    }
    </tbody></table></div></div>

    <!-- PAGINATION -->
    @if (_totalPages > 1)
    {
        <nav class="mt-3"><ul class="pagination pagination-sm justify-content-center">
            <li class="page-item @(_page <= 1 ? "disabled" : "")"><button class="page-link bg-dark text-white" @onclick="PrevPage">«</button></li>
            @for (int i = 1; i <= _totalPages && i <= 10; i++)
            {
                <li class="page-item @(i == _page ? "active" : "")">
                    <button class="page-link @(i == _page ? "bg-warning text-dark" : "bg-dark text-white")" @onclick="() => GoPage(i)">@i</button>
                </li>
            }
            <li class="page-item @(_page >= _totalPages ? "disabled" : "")"><button class="page-link bg-dark text-white" @onclick="NextPage">»</button></li>
        </ul></nav>
    }
}
else { <div class="text-center py-5 text-muted"><i class="bi bi-inbox display-3"></i><p>No orders found</p></div> }

@code {
    private List<OrderItem> _orders = new();
    private bool _loading = true;
    private int _page = 1, _total, _totalPages;
    private string? _statusFilter;

    protected override async Task OnInitializedAsync() => await LoadOrders();

    private async Task LoadOrders()
    {
        _loading = true; StateHasChanged();
        var result = await ApiClient.GetOrders(_page, 25, _statusFilter);
        if (result != null) { _orders = result.Data; _total = result.Total; _totalPages = result.TotalPages; }
        _loading = false;
    }

    private async Task PrevPage() { if (_page > 1) { _page--; await LoadOrders(); } }
    private async Task NextPage() { if (_page < _totalPages) { _page++; await LoadOrders(); } }
    private async Task GoPage(int p) { _page = p; await LoadOrders(); }

    private static string Trunc(string t, int l) => t.Length <= l ? t : t[..l] + "...";
    private static string Badge(string s) => s switch { "Requested" => "bg-info", "Accepted" => "bg-purple text-white", "Started" or "DriverArrived" => "bg-warning text-dark", "Completed" => "bg-success", "Cancelled" => "bg-danger", _ => "bg-secondary" };
}
