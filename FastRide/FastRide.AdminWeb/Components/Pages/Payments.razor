@page "/payments"
@inject ApiClient ApiClient

<PageTitle>FastRide Admin - Payments</PageTitle>

<h2 class="fw-bold mb-4"><i class="bi bi-credit-card text-warning me-2"></i>Payments</h2>

@if (_loading)
{ <div class="text-center py-5"><div class="spinner-border text-warning"></div></div> }
else if (_payments?.Data.Any() == true)
{
    <div class="card stat-card"><div class="card-body p-0">
    <table class="table table-dark table-striped table-fastride mb-0">
    <thead><tr><th>Transaction</th><th>Order</th><th>Amount</th><th>Method</th><th>Status</th><th>Date</th></tr></thead>
    <tbody>
    @foreach (var p in _payments.Data)
    {
        <tr>
            <td><code>@(p.TransactionReference ?? p.Id.ToString()[..8])</code></td>
            <td><code>#@p.OrderId.ToString()[..8]</code></td>
            <td>Rp @p.Amount.ToString("N0")</td>
            <td>@MethodIcon(p.Method) @p.Method</td>
            <td><span class="badge @(p.Status == "Completed" ? "bg-success" : "bg-warning text-dark")">@p.Status</span></td>
            <td><small>@p.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</small></td>
        </tr>
    }
    </tbody></table></div></div>
}

@code {
    private PaginatedResult<PaymentItem>? _payments;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _payments = await ApiClient.GetPayments();
        _loading = false;
    }

    private string MethodIcon(string m) => m switch
    {
        "Cash" => "💵", "EWallet" => "📱", "CreditCard" => "💳", "BankTransfer" => "🏦", _ => "💰"
    };
}
