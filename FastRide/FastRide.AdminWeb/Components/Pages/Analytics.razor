@page "/analytics"
@inject ApiClient ApiClient

<PageTitle>FastRide Admin - Analytics</PageTitle>

<h2 class="fw-bold mb-4"><i class="bi bi-graph-up text-warning me-2"></i>Analytics</h2>

@if (_loading)
{ <div class="text-center py-5"><div class="spinner-border text-warning"></div></div> }
else
{
    <div class="row g-3">
        <div class="col-12">
            <div class="chart-container">
                <h5><i class="bi bi-clock-history me-2"></i>Orders per Hour (Today)</h5>
                <div class="table-responsive">
                    <table class="table table-dark table-sm text-center mb-0">
                        <thead><tr><th>Hour</th><th>Orders</th><th>Revenue</th><th>Visual</th></tr></thead>
                        <tbody>
                        @foreach (var h in _hourly)
                        {
                            var maxVal = _hourly.Max(x => x.Count);
                            var barWidth = maxVal > 0 ? (int)((double)h.Count / maxVal * 100) : 0;
                            <tr>
                                <td class="text-muted">@h.Hour:00</td>
                                <td><strong>@h.Count</strong></td>
                                <td>Rp @h.Revenue.ToString("N0")</td>
                                <td>
                                    <div class="progress" style="height:12px;">
                                        <div class="progress-bar bg-warning" style="width:@barWidth%"></div>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<HourlyData> _hourly = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _hourly = await ApiClient.GetOrdersByHour(DateTime.UtcNow.Date);
        _loading = false;
    }
}
