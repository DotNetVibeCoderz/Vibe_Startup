@page "/promos"
@inject ApiClient ApiClient

<PageTitle>FastRide Admin - Promos</PageTitle>

<h2 class="fw-bold mb-4"><i class="bi bi-tags-fill text-warning me-2"></i>Promos</h2>

@if (_loading)
{ <div class="text-center py-5"><div class="spinner-border text-warning"></div></div> }
else if (_promos.Any())
{
    <div class="card stat-card"><div class="card-body p-0">
    <table class="table table-dark table-striped table-fastride mb-0">
    <thead><tr><th>Code</th><th>Description</th><th>Type</th><th>Value</th><th>Usage</th><th>Valid Until</th><th>Status</th></tr></thead>
    <tbody>
    @foreach (var p in _promos)
    {
        <tr>
            <td><span class="badge bg-warning text-dark">@p.Code</span></td>
            <td>@p.Description</td>
            <td>@p.Type</td>
            <td>@(p.Type == "Percentage" ? $"{p.Value}%" : $"Rp {p.Value:N0}")</td>
            <td>@p.UsageCount/@p.UsageLimit</td>
            <td><small>@p.ValidUntil.ToLocalTime().ToString("dd MMM yyyy")</small></td>
            <td><span class="badge @(p.IsActive ? "bg-success" : "bg-secondary")">@(p.IsActive ? "Active" : "Inactive")</span></td>
        </tr>
    }
    </tbody></table></div></div>
}

@code {
    private List<PromoItem> _promos = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _promos = await ApiClient.GetPromos();
        _loading = false;
    }
}
