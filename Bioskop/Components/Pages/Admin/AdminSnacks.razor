@page "/admin/snacks"
@attribute [Authorize(Roles = "Admin,Operator")]
@using Bioskop.Services
@using Bioskop.Models
@inject SnackService SnackService

<PageTitle>Kelola Snack - Admin Bioskop</PageTitle>

<div class="admin-page fade-in-up">
    <div class="section-header"><h2>🍿 Kelola Snack & Minuman</h2><button class="btn btn-primary" @onclick="OpenAdd">+ Tambah</button></div>
    <div class="filter-bar">
        <input class="form-input" @bind="_search" @bind:event="oninput" placeholder="🔍 Cari..." style="max-width:300px"/>
        <select class="form-input" @bind="_catFilter" style="max-width:200px">
            <option value="">Semua Kategori</option>
            @foreach(var c in _cats){<option value="@c">@c</option>}
        </select>
    </div>
    <div class="table-responsive"><table class="data-table"><thead><tr><th>Nama</th><th>Kategori</th><th>Harga</th><th>Stok</th><th>Status</th><th>Aksi</th></tr></thead><tbody>
    @foreach(var s in _filtered){
        <tr><td><strong>@s.Name</strong></td><td>@s.Category</td><td>Rp @s.Price.ToString("N0")</td><td>@s.Stock</td>
            <td><span class="status-badge @(s.IsAvailable?"status-paid":"status-cancelled")">@(s.IsAvailable?"Tersedia":"Habis")</span></td>
            <td><button class="btn btn-outline btn-sm" @onclick="()=>OpenEdit(s)">✏️</button>
            <button class="btn btn-outline btn-sm" @onclick="()=>DeleteSnack(s.Id)" style="color:var(--danger)">🗑️</button></td>
        </tr>
    }</tbody></table></div>
</div>

@if(_show){
<Bioskop.Components.Shared.Modal IsVisible="true" Title="@(_ed?"Edit Snack":"Tambah Snack")" Size="md" ShowFooter="true" OnClose="CloseForm">
    <ChildContent>
        <div style="display:flex;flex-direction:column;gap:14px">
            <div class="form-group"><label>Nama</label><input class="form-input" @bind="_fm.Name"/></div>
            <div class="form-group"><label>Deskripsi</label><textarea class="form-input" @bind="_fm.Description" rows="2"></textarea></div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                <div class="form-group"><label>Kategori</label><select class="form-input" @bind="_fm.Category"><option>Popcorn</option><option>Minuman</option><option>Snack</option><option>Combo</option></select></div>
                <div class="form-group"><label>Harga</label><input class="form-input" type="number" @bind="_fm.Price"/></div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                <div class="form-group"><label>Stok</label><input class="form-input" type="number" @bind="_fm.Stock"/></div>
                <div class="form-group"><label>Status</label><select class="form-input" @bind="_fm.IsAvailable"><option value="true">Tersedia</option><option value="false">Habis</option></select></div>
            </div>
        </div>
    </ChildContent>
    <FooterContent><button class="btn btn-outline" @onclick="CloseForm">Batal</button><button class="btn btn-primary" @onclick="SaveSnack">💾 Simpan</button></FooterContent>
</Bioskop.Components.Shared.Modal>}

@code {
    private List<Snack> _snacks=new();private string _search="",_catFilter="";private bool _show,_ed;private Snack _fm=new();
    private string[] _cats=new[]{"Popcorn","Minuman","Snack","Combo"};
    private List<Snack> _filtered=>_snacks.Where(s=>(string.IsNullOrEmpty(_search)||s.Name.Contains(_search,StringComparison.OrdinalIgnoreCase))&&(string.IsNullOrEmpty(_catFilter)||s.Category==_catFilter)).ToList();
    protected override async Task OnInitializedAsync(){_snacks=await SnackService.GetAllAsync();}
    void OpenAdd(){_fm=new Snack{IsAvailable=true,Stock=100,Price=10000,Category="Snack"};_ed=false;_show=true;}
    void OpenEdit(Snack s){_fm=new Snack{Id=s.Id,Name=s.Name,Description=s.Description,Price=s.Price,Category=s.Category,ImageUrl=s.ImageUrl,IsAvailable=s.IsAvailable,Stock=s.Stock};_ed=true;_show=true;}
    void CloseForm(){_show=false;}
    async Task SaveSnack(){if(_ed)await SnackService.UpdateAsync(_fm);else await SnackService.CreateAsync(_fm);_show=false;_snacks=await SnackService.GetAllAsync();}
    async Task DeleteSnack(int id){if(await SnackService.DeleteAsync(id))_snacks=await SnackService.GetAllAsync();}
}
