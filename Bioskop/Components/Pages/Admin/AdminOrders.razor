@page "/admin/orders"
@attribute [Authorize(Roles = "Admin,Operator")]
@using Bioskop.Services
@using Bioskop.Models
@inject OrderService OrderService
@inject NavigationManager Navigation

<PageTitle>Kelola Pesanan - Admin Bioskop</PageTitle>

<div class="admin-page fade-in-up">
    <div class="section-header"><h2>📋 Semua Pesanan</h2></div>

    <div class="filter-bar">
        <input class="form-input" @bind="_search" @bind:event="oninput" placeholder="🔍 Cari order/user/film..." style="max-width:300px"/>
        <select class="form-input" @bind="_statusFilter" style="max-width:200px">
            <option value="">Semua Status</option>
            <option value="Pending">Pending</option>
            <option value="Paid">Paid</option>
            <option value="Cancelled">Cancelled</option>
            <option value="Completed">Completed</option>
        </select>
    </div>

    <div class="table-responsive">
        <table class="data-table"><thead><tr>
            <th>Order #</th><th>User</th><th>Film</th><th>Jadwal</th><th>Kursi</th><th>Total</th><th>Status</th><th>Tanggal</th>
        </tr></thead><tbody>
        @foreach(var o in _filteredOrders){
            <tr>
                <td><strong>@o.OrderNumber</strong></td>
                <td>@o.User?.FullName</td>
                <td>@o.Showtime?.Movie?.Title</td>
                <td>@o.Showtime?.StartTime.ToString("dd/MM HH:mm")</td>
                <td>@string.Join(", ", o.Tickets.Select(t=>$"{t.Seat?.RowLabel}{t.Seat?.ColumnNumber}"))</td>
                <td>Rp @o.GrandTotal.ToString("N0")</td>
                <td><span class="status-badge status-@o.Status.ToLower()">@o.Status</span></td>
                <td>@o.OrderDate.ToString("dd/MM HH:mm")</td>
            </tr>
        }</tbody></table>
    </div>

    @if(!_filteredOrders.Any()){<div class="empty-state"><p>Tidak ada pesanan @(_statusFilter!=""?$"dengan status '{_statusFilter}'":"")</p></div>}
</div>

@code {
    private List<Order> _orders=new();private string _search="",_statusFilter="";
    private List<Order> _filteredOrders=>_orders
        .Where(o=>(string.IsNullOrEmpty(_search)||(o.OrderNumber??"").Contains(_search,StringComparison.OrdinalIgnoreCase)||(o.User?.FullName??"").Contains(_search,StringComparison.OrdinalIgnoreCase)||(o.Showtime?.Movie?.Title??"").Contains(_search,StringComparison.OrdinalIgnoreCase))&&(string.IsNullOrEmpty(_statusFilter)||o.Status==_statusFilter))
        .OrderByDescending(o=>o.OrderDate).ToList();

    protected override async Task OnInitializedAsync(){_orders=await OrderService.GetAllOrdersAsync();}
}
