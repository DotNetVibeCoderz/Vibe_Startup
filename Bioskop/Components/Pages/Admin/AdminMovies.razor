@page "/admin/movies"
@attribute [Authorize(Roles = "Admin,Operator")]
@using Microsoft.AspNetCore.Components.Forms
@using Bioskop.Services
@using Bioskop.Models
@using ClosedXML.Excel
@inject MovieService MovieService
@inject StorageService StorageService
@inject NavigationManager Navigation

<PageTitle>Kelola Film - Admin Bioskop</PageTitle>

<div class="admin-page fade-in-up">
    <div class="section-header"><h2>🎬 Kelola Film</h2><button class="btn btn-primary" @onclick="OpenAdd">+ Tambah Film</button></div>
    <div class="filter-bar">
        <input class="form-input" @bind="_search" @bind:event="oninput" placeholder="🔍 Cari..." style="max-width:300px"/>
        <select class="form-input" @bind="_genreFilter" style="max-width:200px"><option value="">Semua Genre</option>@foreach(var g in _genres){<option value="@g">@g</option>}</select>
        <button class="btn btn-outline btn-sm" @onclick="ExportExcel">📊 Excel</button>
    </div>

    <div class="table-responsive"><table class="data-table"><thead><tr>
        <th>Poster</th><th>Judul</th><th>Genre</th><th>Durasi</th><th>Harga</th><th>Rating</th><th>Status</th><th>Aksi</th>
    </tr></thead><tbody>
    @foreach(var m in _filteredMovies){
        <tr>
            <td>
                @if(!string.IsNullOrEmpty(m.PosterUrl)){<img src="@m.PosterUrl" style="width:50px;height:70px;object-fit:cover;border-radius:4px" alt="poster"/>}
                else{<span style="font-size:1.5em">🎬</span>}
            </td>
            <td><strong>@m.Title</strong></td><td>@m.Genre</td><td>@m.DurationMinutes mnt</td>
            <td>Rp @m.BasePrice.ToString("N0")</td><td>@m.AgeRating</td>
            <td><span class="status-badge @(m.IsNowPlaying?"status-paid":"status-cancelled")">@(m.IsNowPlaying?"Tayang":"Tidak")</span></td>
            <td>
                <button class="btn btn-outline btn-sm" @onclick="()=>OpenEdit(m)">✏️</button>
                <button class="btn btn-outline btn-sm" @onclick="()=>DeleteMovie(m.Id)" style="color:var(--danger)">🗑️</button>
            </td>
        </tr>
    }</tbody></table></div>
</div>

@if(_showForm){
<Bioskop.Components.Shared.Modal IsVisible="true" Title="@(_editing?"Edit Film":"Tambah Film")" Size="lg" ShowFooter="true" OnClose="CloseForm">
    <ChildContent>
        <div style="display:flex;flex-direction:column;gap:14px">

            <!-- POSTER UPLOAD SECTION -->
            <div class="form-group">
                <label>Poster Film</label>
                <div style="display:flex;align-items:flex-start;gap:16px">
                    <!-- Preview -->
                    <div style="width:120px;height:170px;border-radius:8px;overflow:hidden;flex-shrink:0;background:var(--bg-secondary);display:flex;align-items:center;justify-content:center;border:2px dashed var(--border-color)">
                        @if(!string.IsNullOrEmpty(_posterPreviewUrl)){
                            <img src="@_posterPreviewUrl" style="width:100%;height:100%;object-fit:cover" alt="preview"/>
                        }else if(!string.IsNullOrEmpty(_form.PosterUrl)){
                            <img src="@_form.PosterUrl" style="width:100%;height:100%;object-fit:cover" alt="current"/>
                        }else{
                            <span style="font-size:3em">🎬</span>
                        }
                    </div>
                    <div style="flex:1;display:flex;flex-direction:column;gap:10px">
                        <label class="btn btn-outline btn-sm" style="cursor:pointer;align-self:flex-start">
                            📁 Upload Poster
                            <InputFile OnChange="HandlePosterUpload" accept="image/*" hidden/>
                        </label>
                        @if(_uploadingPoster){<span style="font-size:0.85em;color:var(--text-secondary)">Mengupload...</span>}
                        @if(!string.IsNullOrEmpty(_posterError)){<span style="font-size:0.8em;color:var(--danger)">@_posterError</span>}
                        <span style="font-size:0.8em;color:var(--text-muted)">Atau masukkan URL:</span>
                        <input class="form-input" @bind="_form.PosterUrl" placeholder="https://... atau /images/movies/..." />
                    </div>
                </div>
            </div>

            <div class="form-group"><label>Judul</label><input class="form-input" @bind="_form.Title"/></div>
            <div class="form-group"><label>Deskripsi</label><textarea class="form-input" @bind="_form.Description" rows="3"></textarea></div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                <div class="form-group"><label>Genre</label><input class="form-input" @bind="_form.Genre"/></div>
                <div class="form-group"><label>Durasi (menit)</label><input class="form-input" type="number" @bind="_form.DurationMinutes"/></div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">
                <div class="form-group"><label>Harga Dasar</label><input class="form-input" type="number" @bind="_form.BasePrice"/></div>
                <div class="form-group"><label>Rating Usia</label><select class="form-input" @bind="_form.AgeRating"><option value="SU">SU</option><option value="R13">R13</option><option value="R17">R17</option><option value="D17">D17</option></select></div>
                <div class="form-group"><label>Status</label><select class="form-input" @bind="_form.IsNowPlaying"><option value="true">Sedang Tayang</option><option value="false">Tidak Tayang</option></select></div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                <div class="form-group"><label>Tanggal Rilis</label><input class="form-input" type="date" @bind="_form.ReleaseDate"/></div>
                <div class="form-group"><label>Tanggal Berakhir</label><input class="form-input" type="date" @bind="_form.EndDate"/></div>
            </div>
            <div class="form-group"><label>URL Trailer</label><input class="form-input" @bind="_form.TrailerUrl" placeholder="https://youtube.com/..."/></div>
        </div>
    </ChildContent>
    <FooterContent><button class="btn btn-outline" @onclick="CloseForm">Batal</button><button class="btn btn-primary" @onclick="SaveMovie" disabled="@_uploadingPoster">💾 Simpan</button></FooterContent>
</Bioskop.Components.Shared.Modal>}

@code {
    private List<Movie> _movies=new();private string _search="",_genreFilter="";private bool _showForm,_editing,_uploadingPoster;private Movie _form=new();
    private string _posterPreviewUrl="",_posterError="";
    private string[] _genres=new[]{"Action","Adventure","Animation","Biography","Comedy","Drama","Family","Horror","Mystery","Romance","Sci-Fi","Thriller"};
    private List<Movie> _filteredMovies=>_movies.Where(m=>(string.IsNullOrEmpty(_search)||(m.Title??"").Contains(_search,StringComparison.OrdinalIgnoreCase))&&(string.IsNullOrEmpty(_genreFilter)||(m.Genre??"").Contains(_genreFilter))).OrderByDescending(m=>m.ReleaseDate).ToList();

    protected override async Task OnInitializedAsync(){await LoadData();}
    async Task LoadData(){_movies=await MovieService.GetAllAsync();}

    void OpenAdd(){
        _form=new Movie{ReleaseDate=DateTime.Now,IsNowPlaying=true,BasePrice=50000,DurationMinutes=120};
        _posterPreviewUrl="";_posterError="";
        _editing=false;_showForm=true;
    }
    void OpenEdit(Movie m){
        _form=new Movie{Id=m.Id,Title=m.Title,Description=m.Description,Genre=m.Genre,DurationMinutes=m.DurationMinutes,PosterUrl=m.PosterUrl,TrailerUrl=m.TrailerUrl,AgeRating=m.AgeRating,ReleaseDate=m.ReleaseDate,EndDate=m.EndDate,IsNowPlaying=m.IsNowPlaying,BasePrice=m.BasePrice};
        _posterPreviewUrl="";_posterError="";
        _editing=true;_showForm=true;
    }
    void CloseForm(){_showForm=false;_posterPreviewUrl="";_posterError="";}

    // Upload poster via StorageService (FileSystem / AzureBlob / S3 / MinIO)
    async Task HandlePosterUpload(InputFileChangeEventArgs e){
        _posterError="";
        var file=e.GetMultipleFiles(1).FirstOrDefault();
        if(file==null)return;

        // Validate file type
        var ext=Path.GetExtension(file.Name).ToLower();
        if(ext is not (".jpg" or ".jpeg" or ".png" or ".gif" or ".webp")){
            _posterError="Format tidak didukung. Gunakan JPG, PNG, GIF, atau WebP.";
            return;
        }
        if(file.Size>5*1024*1024){_posterError="Ukuran maksimal 5MB.";return;}

        _uploadingPoster=true;
        try{
            using var ms=new MemoryStream();
            await file.OpenReadStream(5*1024*1024).CopyToAsync(ms);
            var url=await StorageService.UploadBytesAsync(ms.ToArray(),file.Name,file.ContentType,"posters");
            if(url!=null){
                _form.PosterUrl=url;
                _posterPreviewUrl=url; // Tampilkan preview
            }else{
                _posterError="Gagal upload poster.";
            }
        }catch(Exception ex){
            _posterError=$"Error: {ex.Message}";
        }finally{
            _uploadingPoster=false;
        }
    }

    async Task SaveMovie(){
        if(_editing)await MovieService.UpdateAsync(_form);else await MovieService.CreateAsync(_form);
        _showForm=false;_posterPreviewUrl="";await LoadData();
    }
    async Task DeleteMovie(int id){if(await MovieService.DeleteAsync(id))await LoadData();}
    async Task ExportExcel(){
        using var wb=new XLWorkbook();var ws=wb.Worksheets.Add("Film");
        ws.Cell(1,1).Value="Judul";ws.Cell(1,2).Value="Genre";ws.Cell(1,3).Value="Durasi";ws.Cell(1,4).Value="Harga";ws.Cell(1,5).Value="Rating";ws.Cell(1,6).Value="Tayang";
        int r=2;foreach(var m in _filteredMovies){ws.Cell(r,1).Value=m.Title;ws.Cell(r,2).Value=m.Genre;ws.Cell(r,3).Value=m.DurationMinutes;ws.Cell(r,4).Value=m.BasePrice;ws.Cell(r,5).Value=m.AgeRating;ws.Cell(r,6).Value=m.IsNowPlaying?"Ya":"Tidak";r++;}
        using var ms=new MemoryStream();wb.SaveAs(ms);await Task.CompletedTask;
    }
}
