@page "/auth/forgot-password"
@using Microsoft.AspNetCore.Identity
@using Bioskop.Models
@inject UserManager<ApplicationUser> UserManager

<PageTitle>Reset Password - Bioskop</PageTitle>

<div class="auth-page"><div class="auth-container fade-in-up">
    <div class="auth-header"><h1>🔑 Reset Password</h1><p>Masukkan email Anda untuk menerima link reset password.</p></div>
    @if(!string.IsNullOrEmpty(_msg)){<div class="alert @(_err?"alert-error":"alert-success")">@_msg</div>}
    @if(!_sent){
        <div class="auth-form">
            <div class="form-group"><label>Email</label><input class="form-input" @bind="_email" type="email" placeholder="contoh@email.com"/></div>
            <button class="btn btn-primary btn-block" @onclick="SendReset" disabled="@_loading">📧 Kirim Link Reset</button>
        </div>
    }
    <div class="auth-footer"><a href="/auth/login">← Kembali ke Login</a></div>
</div></div>

@code {
    private string _email="",_msg="";private bool _err,_loading,_sent;
    async Task SendReset(){
        _loading=true;_msg="";
        if(string.IsNullOrWhiteSpace(_email)){_msg="Email wajib diisi!";_err=true;_loading=false;return;}
        var user=await UserManager.FindByEmailAsync(_email);
        if(user!=null){
            var token=await UserManager.GeneratePasswordResetTokenAsync(user);
            _msg=$"Link reset password telah dikirim ke {_email}. (Token: {token[..20]}...)";
        }else{_msg="Jika email terdaftar, link reset akan dikirim.";}
        _sent=true;_loading=false;
    }
}
