@page "/auth/login"
@using Bioskop.Models
@using Microsoft.AspNetCore.Components

<PageTitle>Login - Bioskop</PageTitle>

<div class="auth-page">
    <div class="auth-container fade-in-up">
        <div class="auth-header">
            <h1>🎬 Welcome Back!</h1>
            <p>Login untuk pesan tiket dan nikmati film favoritmu</p>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-error">❌ @_error</div>
        }

        <form method="post" action="/auth/login" class="auth-form">
            <AntiforgeryToken />

            <div class="form-group">
                <label>Email</label>
                <input name="Email" type="email" placeholder="contoh@email.com" class="form-input" required />
            </div>

            <div class="form-group">
                <label>Password</label>
                <input name="Password" type="password" placeholder="••••••••" class="form-input" required />
            </div>

            <div class="form-options">
                <label class="remember-me">
                    <input name="RememberMe" type="checkbox" value="true" checked />
                    <span>Ingat saya</span>
                </label>
                <a href="/auth/forgot-password" class="forgot-link">Lupa password?</a>
            </div>

            <button type="submit" class="btn btn-primary btn-block">
                <span>🚀 Login</span>
            </button>
        </form>

        <div class="auth-footer">
            Belum punya akun? <a href="/auth/register">Register di sini</a>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    private string? _error;

    protected override void OnParametersSet()
    {
        _error = Error switch
        {
            "locked" => "Akun terkunci. Silakan coba lagi nanti.",
            "invalid" => "Email atau password salah.",
            _ => null
        };
    }
}
