@page "/auth/reset-password"
@attribute [ExcludeFromInteractiveRouting]
@layout WashUp.Components.Layout.EmptyLayout
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using System.Text
@using WashUp.Models
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>Atur Ulang Password - WashUp</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-logo">🔒</div>
        <h1 class="auth-title">Atur ulang password</h1>
        <p class="auth-subtitle">Buat password baru untuk akun @(Email ?? "Anda")</p>

        @if (_done)
        {
            <div class="alert alert-success">Password berhasil diubah. Silakan masuk dengan password baru.</div>
            <a class="btn-primary btn-block" href="/auth/login">Ke halaman masuk</a>
        }
        else
        {
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-error">@_errorMessage</div>
            }
            <EditForm Model="Input" FormName="reset-password" OnValidSubmit="HandleSubmit" method="post">
                <div class="form-group">
                    <label class="form-label" for="rp-password">Password baru</label>
                    <InputText id="rp-password" type="password" class="form-control" @bind-Value="Input.Password" placeholder="Min. 6 karakter, ada huruf besar & angka" autocomplete="new-password" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="rp-confirm">Konfirmasi password baru</label>
                    <InputText id="rp-confirm" type="password" class="form-control" @bind-Value="Input.ConfirmPassword" placeholder="Ulangi password baru" autocomplete="new-password" />
                </div>
                <button type="submit" class="btn-primary btn-block">Simpan password baru</button>
            </EditForm>
        }

        <div class="auth-link">
            <a href="/auth/login">← Kembali ke halaman masuk</a>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    private string? Email { get; set; }

    [SupplyParameterFromQuery]
    private string? Code { get; set; }

    [SupplyParameterFromForm]
    private ResetInput Input { get; set; } = new();

    private string? _errorMessage;
    private bool _done;

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(Email) || string.IsNullOrEmpty(Code))
            _errorMessage = "Tautan reset tidak valid. Buat tautan baru dari halaman lupa password.";
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrEmpty(Email) || string.IsNullOrEmpty(Code)) return;

        if (Input.Password != Input.ConfirmPassword)
        {
            _errorMessage = "Password dan konfirmasi tidak cocok.";
            return;
        }

        var user = await UserManager.FindByEmailAsync(Email);
        if (user == null)
        {
            _errorMessage = "Akun tidak ditemukan.";
            return;
        }

        string token;
        try
        {
            token = Encoding.UTF8.GetString(WebEncoders.Base64UrlDecode(Code));
        }
        catch
        {
            _errorMessage = "Tautan reset rusak. Buat tautan baru dari halaman lupa password.";
            return;
        }

        var result = await UserManager.ResetPasswordAsync(user, token, Input.Password);
        if (result.Succeeded)
        {
            _done = true;
            _errorMessage = null;
        }
        else
        {
            _errorMessage = string.Join(" ", result.Errors.Select(e => e.Code switch
            {
                "InvalidToken" => "Tautan reset kedaluwarsa atau sudah dipakai. Buat tautan baru.",
                "PasswordTooShort" => "Password minimal 6 karakter.",
                "PasswordRequiresDigit" => "Password harus mengandung angka.",
                "PasswordRequiresUpper" => "Password harus mengandung huruf besar.",
                "PasswordRequiresLower" => "Password harus mengandung huruf kecil.",
                _ => e.Description
            }));
        }
    }

    private sealed class ResetInput
    {
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}
