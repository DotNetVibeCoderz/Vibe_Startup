@page "/auth/forgot-password"
@attribute [ExcludeFromInteractiveRouting]
@layout WashUp.Components.Layout.EmptyLayout
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using System.Text
@using WashUp.Models
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>Lupa Password - WashUp</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-logo">🔑</div>
        <h1 class="auth-title">Lupa password?</h1>
        <p class="auth-subtitle">Masukkan email akun Anda. Kami akan membuat tautan untuk mengatur ulang password.</p>

        @if (_resetLink != null)
        {
            <div class="alert alert-success">
                Tautan reset berhasil dibuat. Pada versi produksi, tautan ini dikirim ke email Anda.
            </div>
            <a class="btn-primary btn-block" href="@_resetLink">Atur ulang password sekarang</a>
        }
        else
        {
            @if (_notFound)
            {
                <div class="alert alert-error">Email tidak ditemukan. Periksa kembali atau daftar akun baru.</div>
            }
            <EditForm Model="Input" FormName="forgot-password" OnValidSubmit="HandleSubmit" method="post">
                <div class="form-group">
                    <label class="form-label" for="fp-email">Email</label>
                    <InputText id="fp-email" type="email" class="form-control" @bind-Value="Input.Email" placeholder="nama@email.com" autocomplete="username" />
                </div>
                <button type="submit" class="btn-primary btn-block">Buat tautan reset</button>
            </EditForm>
        }

        <div class="auth-link">
            <a href="/auth/login">← Kembali ke halaman masuk</a>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private ForgotInput Input { get; set; } = new();

    private string? _resetLink;
    private bool _notFound;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(Input.Email)) { _notFound = true; return; }

        var user = await UserManager.FindByEmailAsync(Input.Email.Trim());
        if (user == null) { _notFound = true; return; }

        // Demo mode: no SMTP configured, so surface the reset link directly.
        var token = await UserManager.GeneratePasswordResetTokenAsync(user);
        var code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(token));
        _resetLink = $"/auth/reset-password?email={Uri.EscapeDataString(Input.Email.Trim())}&code={code}";
    }

    private sealed class ForgotInput
    {
        public string Email { get; set; } = "";
    }
}
