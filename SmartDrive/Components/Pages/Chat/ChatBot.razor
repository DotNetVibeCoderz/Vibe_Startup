@page "/chat-bot"
@attribute [Authorize]
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using SmartDrive.Models.Entities
@using Markdig
@inject SmartDrive.Services.ChatBotService ChatBotService
@inject SmartDrive.Data.SmartDriveDbContext DbContext
@inject AuthenticationStateProvider AuthState

<PageTitle>Om Bambang AI - SmartDrive</PageTitle>

<div class="chat-page">
    <div class="chat-sidebar">
        <div class="chat-sidebar-header"><h3>🤖 Chat AI</h3><button class="btn btn-primary btn-sm" @onclick="CreateNewSession">+ Baru</button></div>
        <div class="session-list">
            @foreach (var s in _sessions)
            {
                <div class="session-item @(s.Id == _sid ? "active" : "")" @onclick="() => Select(s.Id)">
                    <div class="session-title">@s.Title</div>
                    <div class="session-time">@(s.LastActivityAt?.ToString("dd/MM HH:mm") ?? s.CreatedAt.ToString("dd/MM HH:mm"))</div>
                    <div class="session-actions">
                        <button class="btn-icon" @onclick:stopPropagation="true" @onclick="() => ResetSession(s.Id)">🔄</button>
                        <button class="btn-icon" @onclick:stopPropagation="true" @onclick="() => DeleteSession(s.Id)">🗑️</button>
                    </div>
                </div>
            }
        </div>
        <div class="chat-sidebar-footer"><small>Powered by Semantic Kernel</small></div>
    </div>

    <div class="chat-main">
        @if (_sid > 0)
        {
            <div class="chat-header"><div class="flex-between"><div><h3>🤖 Om Bambang</h3><small>Asisten Virtual SmartDrive</small></div><div class="flex-center"><InputFile OnChange="HandleImageUpload" accept="image/*" style="display:none" id="imgUp" /><label for="imgUp" class="btn btn-outline btn-sm">🖼️ Gambar</label><InputFile OnChange="HandleDocUpload" accept=".pdf,.doc,.docx,.txt" style="display:none" id="docUp" /><label for="docUp" class="btn btn-outline btn-sm">📎 Dokumen</label></div></div></div>

            <div class="chat-messages">
                @if (!_messages.Any())
                {
                    <div class="chat-welcome"><div class="welcome-icon">🤖</div><h2>Halo! Saya Om Bambang</h2><p>Asisten virtual SmartDrive Academy. Ada yang bisa saya bantu?</p>
                        <div class="quick-actions">
                            <button class="btn btn-outline btn-sm" @onclick='() => SendQuick("Apa saja materi teori yang tersedia?")'>📚 Materi</button>
                            <button class="btn btn-outline btn-sm" @onclick='() => SendQuick("Bagaimana cara booking jadwal?")'>📅 Booking</button>
                            <button class="btn btn-outline btn-sm" @onclick='() => SendQuick("Tips mengemudi untuk pemula?")'>💡 Tips</button>
                            <button class="btn btn-outline btn-sm" @onclick='() => SendQuick("Biaya kursus mengemudi?")'>💰 Biaya</button>
                        </div>
                    </div>
                }

                @foreach (var m in _messages)
                {
                    <div class="chat-message @(m.Role == "user" ? "message-user" : "message-assistant")">
                        <div class="message-avatar">@(m.Role == "user" ? "👤" : "🤖")</div>
                        <div class="message-content">
                            <div class="message-bubble">
                                @if (m.Role == "assistant") { @((MarkupString)RenderMD(m.Content)) } else { @m.Content }
                                @if (!string.IsNullOrEmpty(m.ImageUrls))
                                {
                                    try
                                    {
                                        var urls = System.Text.Json.JsonSerializer.Deserialize<List<string>>(m.ImageUrls);
                                        @foreach (var u in urls ?? new()) { <div class="message-attachment"><img src="@u" style="max-width:200px;border-radius:8px" /></div> }
                                    }
                                    catch { }
                                }
                                @if (!string.IsNullOrEmpty(m.AttachmentUrls))
                                {
                                    try
                                    {
                                        var urls = System.Text.Json.JsonSerializer.Deserialize<List<string>>(m.AttachmentUrls);
                                        @foreach (var u in urls ?? new()) { <div class="message-attachment"><a href="@u" target="_blank">📎 Dokumen</a></div> }
                                    }
                                    catch { }
                                }
                            </div>
                            <div class="message-time">@m.SentAt.ToString("HH:mm")</div>
                        </div>
                    </div>
                }

                @if (_loading)
                {
                    <div class="chat-message message-assistant"><div class="message-avatar">🤖</div><div class="message-bubble typing-indicator"><span></span><span></span><span></span></div></div>
                }
            </div>

            <div class="chat-input-area"><div class="chat-input-wrapper">
                @if (_pendingImgs.Any()) {<div class="pending-attachments">@foreach (var i in _pendingImgs) {<div class="pending-image"><img src="@i" /><button class="btn-icon" @onclick="() => _pendingImgs.Remove(i)">✕</button></div>}</div>}
                @if (_pendingDocs.Any()) {<div class="pending-attachments">@foreach (var d in _pendingDocs) {<div class="pending-doc">📎 @d<button class="btn-icon" @onclick="() => _pendingDocs.Remove(d)">✕</button></div>}</div>}
                <div class="input-row"><textarea class="chat-input" @bind="_msg" @bind:event="oninput" placeholder="Ketik pesan..." @onkeydown="HandleKey" rows="1"></textarea><button class="btn btn-primary" @onclick="SendMsg" disabled="@(string.IsNullOrWhiteSpace(_msg) || _loading)">➤</button></div>
            </div></div>
        }
        else
        {
            <div class="chat-welcome full-height"><div class="welcome-icon">🤖</div><h2>Om Bambang AI</h2><p>Asisten virtual cerdas SmartDrive.</p><button class="btn btn-primary btn-lg" @onclick="CreateNewSession">Mulai Chat Baru</button></div>
        }
    </div>
</div>

<style>
.chat-page{display:flex;height:calc(100vh - 120px);margin:-20px;background:var(--bg-secondary)}
.chat-sidebar{width:300px;border-right:1px solid var(--border-color);display:flex;flex-direction:column}
.chat-sidebar-header{padding:16px;border-bottom:1px solid var(--border-color);display:flex;justify-content:space-between;align-items:center}
.session-list{flex:1;overflow-y:auto}
.session-item{padding:12px 16px;border-bottom:1px solid var(--border-color);cursor:pointer;display:flex;justify-content:space-between;align-items:center}
.session-item:hover{background:var(--bg-hover)}.session-item.active{background:var(--bg-hover);border-left:3px solid var(--accent-color)}
.session-title{font-size:14px;font-weight:500;flex:1}.session-time{font-size:11px;color:var(--text-muted);margin:0 8px}
.session-actions{display:flex;gap:4px}.btn-icon{background:none;border:none;cursor:pointer;padding:2px 4px;border-radius:4px;font-size:12px}
.chat-sidebar-footer{padding:8px 16px;border-top:1px solid var(--border-color);text-align:center}
.chat-main{flex:1;display:flex;flex-direction:column}.chat-header{padding:12px 20px;border-bottom:1px solid var(--border-color)}
.chat-messages{flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:16px}
.chat-welcome{text-align:center;padding:60px 20px}.chat-welcome.full-height{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%}
.welcome-icon{font-size:64px;margin-bottom:16px}.quick-actions{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-top:20px}
.chat-message{display:flex;gap:12px;max-width:80%}.message-user{align-self:flex-end;flex-direction:row-reverse}.message-assistant{align-self:flex-start}
.message-avatar{font-size:28px;flex-shrink:0}.message-bubble{padding:12px 16px;border-radius:18px;font-size:14px;line-height:1.5;word-wrap:break-word}
.message-user .message-bubble{background:var(--accent-color);color:white;border-bottom-right-radius:4px}
.message-assistant .message-bubble{background:var(--bg-tertiary);color:var(--text-primary);border-bottom-left-radius:4px}
.message-time{font-size:11px;color:var(--text-muted);margin-top:4px}.message-attachment{margin-top:8px}
.typing-indicator{display:flex;gap:4px;padding:16px 20px}.typing-indicator span{width:8px;height:8px;background:var(--text-muted);border-radius:50%;animation:typing 1.4s infinite}
.typing-indicator span:nth-child(2){animation-delay:0.2s}.typing-indicator span:nth-child(3){animation-delay:0.4s}
@@keyframes typing{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-10px)}}
.chat-input-area{padding:16px 20px;border-top:1px solid var(--border-color)}.chat-input-wrapper{background:var(--bg-tertiary);border-radius:24px;padding:8px 16px}
.pending-attachments{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:8px}.pending-image{position:relative;width:60px;height:60px}
.pending-image img{width:100%;height:100%;object-fit:cover;border-radius:8px}.pending-image button{position:absolute;top:-6px;right:-6px;background:var(--danger-color);color:white;border-radius:50%;font-size:10px}
.pending-doc{background:var(--bg-secondary);padding:4px 10px;border-radius:12px;font-size:12px;display:flex;align-items:center;gap:6px}
.input-row{display:flex;align-items:center;gap:8px}.chat-input{flex:1;border:none;background:transparent;padding:8px;font-size:14px;color:var(--text-primary);resize:none;outline:none;font-family:inherit}
.chat-input::placeholder{color:var(--text-muted)}@@media(max-width:768px){.chat-sidebar{display:none}.chat-message{max-width:90%}}
</style>

@code {
    private string _uid = ""; private int _sid; private List<ChatBotSession> _sessions = []; private List<ChatBotMessage> _messages = [];
    private string _msg = ""; private bool _loading; private List<string> _pendingImgs = [], _pendingDocs = [];

    protected override async Task OnInitializedAsync()
    {
        var st = await AuthState.GetAuthenticationStateAsync();
        _uid = st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
        if (!string.IsNullOrEmpty(_uid)) { _sessions = await ChatBotService.GetUserSessionsAsync(_uid); if (_sessions.Any()) await Select(_sessions.First().Id); }
    }
    async Task CreateNewSession() { var s = await ChatBotService.CreateSessionAsync(_uid); _sessions = await ChatBotService.GetUserSessionsAsync(_uid); await Select(s.Id); }
    async Task Select(int id) { _sid = id; _messages = await ChatBotService.GetSessionMessagesAsync(id); }
    async Task DeleteSession(int id) { await ChatBotService.DeleteSessionAsync(id, _uid); _sessions = await ChatBotService.GetUserSessionsAsync(_uid); if (_sid == id) { _sid = 0; _messages.Clear(); } }
    async Task ResetSession(int id) { await ChatBotService.ResetSessionAsync(id, _uid); if (_sid == id) _messages.Clear(); }
    async Task SendMsg()
    {
        if (string.IsNullOrWhiteSpace(_msg) || _loading || _sid <= 0) return;
        var txt = _msg; _msg = ""; var imgs = _pendingImgs.ToList(); var docs = _pendingDocs.ToList();
        _pendingImgs.Clear(); _pendingDocs.Clear(); _loading = true;
        try { await ChatBotService.ChatAsync(_sid, txt, _uid, imgs, docs); _messages = await ChatBotService.GetSessionMessagesAsync(_sid); _sessions = await ChatBotService.GetUserSessionsAsync(_uid); }
        catch (Exception ex) { _messages.Add(new ChatBotMessage { Role = "assistant", Content = $"Error: {ex.Message}", SentAt = DateTime.UtcNow }); }
        _loading = false;
    }
    async Task SendQuick(string m) { _msg = m; await SendMsg(); }
    async Task HandleKey(KeyboardEventArgs e) { if (e.Key == "Enter" && !e.ShiftKey) await SendMsg(); }
    async Task HandleImageUpload(InputFileChangeEventArgs e) { foreach (var f in e.GetMultipleFiles(5)) { var fn = $"{Guid.NewGuid()}_{f.Name}"; var p = Path.Combine("wwwroot", "uploads", "chat-images", fn); Directory.CreateDirectory(Path.GetDirectoryName(p)!); using var s = new FileStream(p, FileMode.Create); await f.OpenReadStream(10 * 1024 * 1024).CopyToAsync(s); _pendingImgs.Add($"/uploads/chat-images/{fn}"); } }
    async Task HandleDocUpload(InputFileChangeEventArgs e) { foreach (var f in e.GetMultipleFiles(5)) { var fn = $"{Guid.NewGuid()}_{f.Name}"; var p = Path.Combine("wwwroot", "uploads", "chat-documents", fn); Directory.CreateDirectory(Path.GetDirectoryName(p)!); using var s = new FileStream(p, FileMode.Create); await f.OpenReadStream(20 * 1024 * 1024).CopyToAsync(s); _pendingDocs.Add($"/uploads/chat-documents/{fn}"); } }
    string RenderMD(string md) { if (string.IsNullOrEmpty(md)) return ""; return Markdown.ToHtml(md, new MarkdownPipelineBuilder().UseAdvancedExtensions().Build()); }
}
