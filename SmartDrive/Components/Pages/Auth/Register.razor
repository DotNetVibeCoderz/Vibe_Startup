@page "/auth/register"

<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:#f0f2f5">
<div style="display:flex;width:100%;max-width:1000px;min-height:600px;box-shadow:0 2px 8px rgba(0,0,0,0.15);border-radius:12px;overflow:hidden">
<div style="flex:1;background:linear-gradient(135deg,#1877f2,#0d5bbd);color:white;display:flex;align-items:center;justify-content:center;padding:40px;text-align:center">
<div><div style="font-size:72px;margin-bottom:16px">🚗</div><h1 style="font-size:32px;margin-bottom:8px">SmartDrive Academy</h1><p style="font-size:16px;opacity:0.9">Platform belajar menyetir #1</p></div></div>
<div style="flex:1;background:#fff;padding:40px;display:flex;align-items:center">
<div style="width:100%;max-width:400px;margin:0 auto">
<div style="text-align:center;margin-bottom:24px"><span style="font-size:48px">🚗</span><h1 style="font-size:24px;color:#1c1e21;margin:8px 0">Daftar SmartDrive</h1><p style="color:#65676b;font-size:14px">Mulai perjalanan belajar menyetir Anda!</p></div>

@if (!string.IsNullOrEmpty(_error))
{<div style="padding:12px 16px;border-radius:6px;margin-bottom:16px;background:#fce4ec;color:#c62828;border:1px solid #ef9a9a">@_error</div>}
@if (!string.IsNullOrEmpty(_success))
{<div style="padding:12px 16px;border-radius:6px;margin-bottom:16px;background:#e8f5e9;color:#2e7d32;border:1px solid #a5d6a7">@_success</div>}

<form method="post" action="/api/auth/register">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px">
        <div><label style="display:block;margin-bottom:6px;font-weight:500;font-size:14px;color:#65676b">Nama Lengkap</label><input type="text" name="fullName" style="width:100%;padding:10px 12px;border:1px solid #dddfe2;border-radius:6px;font-size:14px" placeholder="Nama lengkap" required /></div>
        <div><label style="display:block;margin-bottom:6px;font-weight:500;font-size:14px;color:#65676b">Email</label><input type="email" name="email" style="width:100%;padding:10px 12px;border:1px solid #dddfe2;border-radius:6px;font-size:14px" placeholder="Email" required /></div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px">
        <div><label style="display:block;margin-bottom:6px;font-weight:500;font-size:14px;color:#65676b">Nomor HP</label><input type="text" name="phoneNumber" style="width:100%;padding:10px 12px;border:1px solid #dddfe2;border-radius:6px;font-size:14px" placeholder="08xxxxxxxxxx" /></div>
        <div><label style="display:block;margin-bottom:6px;font-weight:500;font-size:14px;color:#65676b">Mendaftar Sebagai</label><select name="role" style="width:100%;padding:10px 12px;border:1px solid #dddfe2;border-radius:6px;font-size:14px;background:#fff"><option value="Student">Siswa</option><option value="Instructor">Instruktur</option></select></div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px">
        <div><label style="display:block;margin-bottom:6px;font-weight:500;font-size:14px;color:#65676b">Password</label><input type="password" name="password" style="width:100%;padding:10px 12px;border:1px solid #dddfe2;border-radius:6px;font-size:14px" placeholder="Minimal 6 karakter" required /></div>
        <div><label style="display:block;margin-bottom:6px;font-weight:500;font-size:14px;color:#65676b">Konfirmasi Password</label><input type="password" name="confirmPassword" style="width:100%;padding:10px 12px;border:1px solid #dddfe2;border-radius:6px;font-size:14px" placeholder="Ulangi password" required /></div>
    </div>
    <button type="submit" style="width:100%;padding:12px 24px;border-radius:6px;border:none;font-size:16px;font-weight:600;cursor:pointer;background:#1877f2;color:white">Daftar</button>
</form>
<div style="text-align:center;margin-top:20px;padding-top:16px;border-top:1px solid #dddfe2;font-size:14px;color:#65676b"><p>Sudah punya akun? <a href="/auth/login" style="color:#1877f2">Login di sini</a></p></div>
</div></div></div></div>

@code {
    private string? _error, _success;
    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation!.BaseUri + Navigation!.Uri);
        // Read query string for error/success
        _error = null; _success = null;
    }
    [Inject] NavigationManager? Navigation { get; set; }
}
