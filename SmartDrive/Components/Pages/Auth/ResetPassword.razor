@page "/auth/reset-password"
@inject NavigationManager Nav

<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:#f0f2f5">
<div style="display:flex;width:100%;max-width:1000px;min-height:500px;box-shadow:0 2px 8px rgba(0,0,0,0.15);border-radius:12px;overflow:hidden">
<div style="flex:1;background:linear-gradient(135deg,#1877f2,#0d5bbd);color:white;display:flex;align-items:center;justify-content:center;padding:40px;text-align:center">
<div><div style="font-size:72px;margin-bottom:16px">🚗</div><h1 style="font-size:32px">SmartDrive Academy</h1></div></div>
<div style="flex:1;background:#fff;padding:40px;display:flex;align-items:center">
<div style="width:100%;max-width:400px;margin:0 auto">
<div style="text-align:center;margin-bottom:24px"><span style="font-size:48px">🔐</span><h1 style="font-size:24px;color:#1c1e21;margin:8px 0">Reset Password</h1><p style="color:#65676b;font-size:14px">Masukkan password baru.</p></div>

@if (!string.IsNullOrEmpty(_msg))
{<div style="padding:12px 16px;border-radius:6px;margin-bottom:16px;background:@(_ok?"#e8f5e9":"#fce4ec");color:@(_ok?"#2e7d32":"#c62828");border:1px solid @(_ok?"#a5d6a7":"#ef9a9a")">@((MarkupString)_msg)</div>}

<form method="post" action="/api/auth/reset-password">
    <input type="hidden" name="token" value="@_token" />
    <div style="margin-bottom:16px"><label style="display:block;margin-bottom:6px;font-weight:500;font-size:14px;color:#65676b">Email</label><input type="email" name="email" value="@_email" style="width:100%;padding:10px 12px;border:1px solid #dddfe2;border-radius:6px;font-size:14px" required /></div>
    <div style="margin-bottom:16px"><label style="display:block;margin-bottom:6px;font-weight:500;font-size:14px;color:#65676b">Password Baru</label><input type="password" name="newPassword" style="width:100%;padding:10px 12px;border:1px solid #dddfe2;border-radius:6px;font-size:14px" required /></div>
    <div style="margin-bottom:16px"><label style="display:block;margin-bottom:6px;font-weight:500;font-size:14px;color:#65676b">Konfirmasi Password</label><input type="password" name="confirmPassword" style="width:100%;padding:10px 12px;border:1px solid #dddfe2;border-radius:6px;font-size:14px" required /></div>
    <button type="submit" style="width:100%;padding:12px 24px;border-radius:6px;border:none;font-size:16px;font-weight:600;cursor:pointer;background:#1877f2;color:white">Reset Password</button>
</form>
<div style="text-align:center;margin-top:20px;padding-top:16px;border-top:1px solid #dddfe2;font-size:14px;color:#65676b"><p><a href="/auth/login" style="color:#1877f2">← Kembali ke Login</a></p></div>
</div></div></div></div>

@code {
    private string _msg=""; private bool _ok; private string _email="",_token="";
    protected override void OnInitialized(){
        var u=Nav.ToAbsoluteUri(Nav.Uri);var q=Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(u.Query);
        if(q.TryGetValue("email",out var e))_email=e!;if(q.TryGetValue("token",out var t))_token=t!;
        if(q.TryGetValue("msg",out var m))_msg=Uri.UnescapeDataString(m!);
        if(q.TryGetValue("ok",out var o))_ok=o=="true";
    }
}
