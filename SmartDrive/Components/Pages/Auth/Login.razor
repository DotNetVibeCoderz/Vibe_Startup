@page "/auth/login"
@inject NavigationManager Nav

@* Simple HTML form — POST ke Minimal API endpoint yg bisa set cookie auth *@

<div class="auth-layout light-theme" style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:#f0f2f5">
<div style="display:flex;width:100%;max-width:1000px;min-height:600px;box-shadow:0 2px 8px rgba(0,0,0,0.15);border-radius:12px;overflow:hidden">
<div style="flex:1;background:linear-gradient(135deg,#1877f2,#0d5bbd);color:white;display:flex;align-items:center;justify-content:center;padding:40px;text-align:center">
<div><div style="font-size:72px;margin-bottom:16px">🚗</div><h1 style="font-size:32px;margin-bottom:8px">SmartDrive Academy</h1><p style="font-size:16px;opacity:0.9;margin-bottom:32px">Platform belajar menyetir #1 di Indonesia</p>
<div style="text-align:left;display:inline-block"><div style="padding:8px 0;font-size:15px">✅ Instruktur Profesional</div><div style="padding:8px 0;font-size:15px">✅ Jadwal Fleksibel</div><div style="padding:8px 0;font-size:15px">✅ Materi Lengkap</div><div style="padding:8px 0;font-size:15px">✅ Simulasi Ujian</div><div style="padding:8px 0;font-size:15px">✅ Asisten AI Om Bambang</div></div></div></div>
<div style="flex:1;background:#fff;padding:40px;display:flex;align-items:center">
<div style="width:100%;max-width:400px;margin:0 auto">
<div style="text-align:center;margin-bottom:24px"><span style="font-size:48px">🚗</span><h1 style="font-size:24px;color:#1c1e21;margin:8px 0">SmartDrive</h1><p style="color:#65676b;font-size:14px">Selamat datang kembali! Silakan login.</p></div>

@if (!string.IsNullOrEmpty(_error))
{<div style="padding:12px 16px;border-radius:6px;margin-bottom:16px;background:#fce4ec;color:#c62828;border:1px solid #ef9a9a">@_error</div>}

<form method="post" action="/api/auth/login">
    <input type="hidden" name="returnUrl" value="@_returnUrl" />
    <div style="margin-bottom:16px"><label style="display:block;margin-bottom:6px;font-weight:500;font-size:14px;color:#65676b">Email</label><input type="email" name="email" style="width:100%;padding:10px 12px;border:1px solid #dddfe2;border-radius:6px;font-size:14px" placeholder="Masukkan email" required /></div>
    <div style="margin-bottom:16px"><label style="display:block;margin-bottom:6px;font-weight:500;font-size:14px;color:#65676b">Password</label><input type="password" name="password" style="width:100%;padding:10px 12px;border:1px solid #dddfe2;border-radius:6px;font-size:14px" placeholder="Masukkan password" required /></div>
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px"><label style="font-size:14px"><input type="checkbox" name="rememberMe" value="true" /> Ingat saya</label><a href="/auth/forgot-password" style="color:#1877f2;font-size:14px">Lupa password?</a></div>
    <button type="submit" style="width:100%;padding:12px 24px;border-radius:6px;border:none;font-size:16px;font-weight:600;cursor:pointer;background:#1877f2;color:white">Login</button>
</form>
<div style="text-align:center;margin-top:20px;padding-top:16px;border-top:1px solid #dddfe2;font-size:14px;color:#65676b"><p>Belum punya akun? <a href="/auth/register" style="color:#1877f2">Daftar sekarang</a></p></div>
</div></div></div></div>

@code {
    private string? _error; private string _returnUrl = "/";
    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var q = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (q.TryGetValue("returnUrl", out var r)) _returnUrl = r!;
        if (q.TryGetValue("error", out var e)) _error = e!;
    }
}
