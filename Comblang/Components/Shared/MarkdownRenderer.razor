@using Markdig

<div class="markdown-body">
    @((MarkupString)_renderedHtml)
</div>

@code {
    [Parameter]
    public string? Content { get; set; }

    private string _renderedHtml = "";

    private static readonly MarkdownPipeline s_pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .UseEmojiAndSmiley()
        .UseMediaLinks()
        .UsePipeTables()
        .UseBootstrap()
        .Build();

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Content))
        {
            _renderedHtml = Markdown.ToHtml(Content, s_pipeline);
        }
        else
        {
            _renderedHtml = "";
        }
    }
}

<style>
/* ==========================================
   Markdown Body
   ========================================== */
.markdown-body {
    line-height: 1.65;
    word-wrap: break-word;
    overflow-wrap: break-word;
}

/* Headings */
.markdown-body ::deep h1,
.markdown-body ::deep h2,
.markdown-body ::deep h3,
.markdown-body ::deep h4 {
    color: var(--pink-primary);
    margin: 0.75rem 0 0.5rem;
    font-weight: 700;
    line-height: 1.3;
}

.markdown-body ::deep h1 { font-size: 1.45rem; }
.markdown-body ::deep h2 { font-size: 1.25rem; }
.markdown-body ::deep h3 { font-size: 1.05rem; }
.markdown-body ::deep h4 { font-size: 0.95rem; }

.message-user .markdown-body ::deep h1,
.message-user .markdown-body ::deep h2,
.message-user .markdown-body ::deep h3 {
    color: white;
}

/* Paragraphs */
.markdown-body ::deep p {
    margin: 0.3rem 0;
}

.markdown-body ::deep p:first-child {
    margin-top: 0;
}

.markdown-body ::deep p:last-child {
    margin-bottom: 0;
}

/* Lists */
.markdown-body ::deep ul,
.markdown-body ::deep ol {
    padding-left: 1.5rem;
    margin: 0.3rem 0;
}

.markdown-body ::deep li {
    margin-bottom: 0.15rem;
}

/* Inline Code */
.markdown-body ::deep code {
    background: rgba(255, 107, 157, 0.1);
    padding: 0.15rem 0.45rem;
    border-radius: 5px;
    font-size: 0.88em;
    font-family: 'Cascadia Code', 'Fira Code', 'JetBrains Mono', 'Consolas', monospace;
}

.message-user .markdown-body ::deep code {
    background: rgba(255, 255, 255, 0.2);
    color: white;
}

/* Code Blocks */
.markdown-body ::deep pre {
    background: #2d2d2d;
    color: #f8f8f2;
    padding: 1rem 1.15rem;
    border-radius: 10px;
    overflow-x: auto;
    margin: 0.5rem 0;
    font-size: 0.85em;
    line-height: 1.5;
}

.markdown-body ::deep pre code {
    background: none;
    padding: 0;
    font-size: inherit;
}

/* Tables */
.markdown-body ::deep table {
    width: 100%;
    border-collapse: collapse;
    margin: 0.5rem 0;
    font-size: 0.85rem;
}

.markdown-body ::deep th,
.markdown-body ::deep td {
    border: 1px solid #ddd;
    padding: 0.45rem 0.7rem;
    text-align: left;
}

.dark-theme .markdown-body ::deep th,
.dark-theme .markdown-body ::deep td {
    border-color: rgba(255, 255, 255, 0.1);
}

.markdown-body ::deep th {
    background: var(--pink-soft);
    font-weight: 700;
}

.dark-theme .markdown-body ::deep th {
    background: rgba(255, 107, 157, 0.12);
}

/* Images */
.markdown-body ::deep img {
    max-width: 100%;
    border-radius: 10px;
    margin: 0.5rem 0;
}

/* Blockquotes */
.markdown-body ::deep blockquote {
    border-left: 3px solid var(--pink-primary);
    padding-left: 1rem;
    margin: 0.5rem 0;
    opacity: 0.8;
    font-style: italic;
}

/* Links */
.markdown-body ::deep a {
    color: var(--pink-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
}

.markdown-body ::deep a:hover {
    opacity: 0.8;
}

.message-user .markdown-body ::deep a {
    color: white;
}

/* Horizontal Rule */
.markdown-body ::deep hr {
    border: none;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    margin: 0.75rem 0;
}

.dark-theme .markdown-body ::deep hr {
    border-top-color: rgba(255, 255, 255, 0.1);
}

/* Bold */
.markdown-body ::deep strong {
    color: var(--pink-primary);
    font-weight: 700;
}

.message-user .markdown-body ::deep strong {
    color: white;
}

/* Task Lists */
.markdown-body ::deep input[type="checkbox"] {
    margin-right: 0.4rem;
}

/* Media */
.markdown-body ::deep video,
.markdown-body ::deep audio {
    max-width: 100%;
    border-radius: 10px;
    margin: 0.5rem 0;
}

/* Details / Summary */
.markdown-body ::deep details {
    margin: 0.4rem 0;
}

.markdown-body ::deep summary {
    cursor: pointer;
    font-weight: 600;
}
</style>
