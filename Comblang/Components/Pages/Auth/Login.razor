@page "/auth/login"
@using System.Security.Claims
@using System.Text.Json
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <span class="auth-icon">💕</span>
            <h2>@(_isRegister ? "Daftar Comblang" : "Login Comblang")</h2>
            <p>@(_isRegister ? "Mulai perjalanan cintamu!" : "Welcome back! Lanjutkan mencari jodoh~")</p>
        </div>

        <div class="auth-form">
            @if (_isRegister)
            {
                <div class="form-group">
                    <label>Username</label>
                    <input type="text" @bind="_username" placeholder="Username kamu" />
                </div>
            }
            <div class="form-group">
                <label>Email</label>
                <input type="email" @bind="_email" placeholder="email@example.com" />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" @bind="_password" placeholder="Password" />
            </div>
            @if (_isRegister)
            {
                <div class="form-group">
                    <label>Konfirmasi Password</label>
                    <input type="password" @bind="_confirmPassword" placeholder="Konfirmasi password" />
                </div>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert-error">@_errorMessage</div>
            }
            @if (!string.IsNullOrEmpty(_successMessage))
            {
                <div class="alert-success">@_successMessage</div>
            }

            <button class="btn btn-primary btn-full" @onclick="SubmitForm" disabled="@_isSubmitting">
                @(_isSubmitting ? "⏳ Memproses..." : _isRegister ? "📝 Daftar" : "🔑 Login")
            </button>
        </div>

        <div class="auth-footer">
            @if (_isRegister)
            {
                <span>Sudah punya akun?</span>
                <button class="btn-link" @onclick="SwitchToLogin">Login di sini</button>
            }
            else
            {
                <span>Belum punya akun?</span>
                <button class="btn-link" @onclick="SwitchToRegister">Daftar di sini</button>
                <button class="btn-link" @onclick="GoToResetPassword">Lupa password?</button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter][SupplyParameterFromQuery] public string? Mode { get; set; }
    private bool _isRegister;
    private bool _isSubmitting;
    private string _email = "", _password = "", _username = "", _confirmPassword = "";
    private string _errorMessage = "", _successMessage = "";

    private sealed record UserInfo(Guid Id, string Email, string Username, string Role, bool IsPremium);
    private sealed record AuthResponse(string? error, string? message, UserInfo? user);
    private sealed record ApiResult(bool ok, int status, AuthResponse? data);

    protected override void OnInitialized() => _isRegister = Mode == "register";

    private void SwitchToLogin()
    {
        _isRegister = false; _errorMessage = ""; _successMessage = "";
        _password = ""; _confirmPassword = "";
    }
    private void SwitchToRegister()
    {
        _isRegister = true; _errorMessage = ""; _successMessage = "";
        _password = ""; _confirmPassword = "";
    }
    private void GoToResetPassword() => Navigation.NavigateTo("/auth/reset-password");

    private async Task<ApiResult?> PostAuthAsync(string url, object payload)
    {
        return await JS.InvokeAsync<ApiResult>("comblangAuth.postJson", url, payload);
    }

    private async Task SubmitForm()
    {
        _errorMessage = ""; _successMessage = "";

        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        { _errorMessage = "Mohon isi semua field."; return; }

        if (_isRegister && _password != _confirmPassword)
        { _errorMessage = "Password dan konfirmasi tidak cocok."; return; }

        if (_isRegister && string.IsNullOrWhiteSpace(_username))
        { _errorMessage = "Username harus diisi."; return; }

        _isSubmitting = true;
        StateHasChanged();

        try
        {
            if (_isRegister)
            {
                // ── REGISTER ──
                var result = await PostAuthAsync("/api/auth/cookie-register", new
                {
                    email = _email,
                    username = _username,
                    password = _password
                });

                if (result is null || !result.ok)
                {
                    _errorMessage = result?.data?.error ?? "Registrasi gagal. Coba lagi.";
                    return;
                }

                _successMessage = result.data?.message ?? "Registrasi berhasil! Mengalihkan...";
                StateHasChanged();
                await Task.Delay(800);
                Navigation.NavigateTo("/swipe", forceLoad: true);
            }
            else
            {
                // ── LOGIN ──
                var result = await PostAuthAsync("/api/auth/cookie-login", new
                {
                    email = _email,
                    password = _password
                });

                if (result is null || !result.ok)
                {
                    _errorMessage = result?.data?.error ?? "Login gagal. Coba lagi.";
                    return;
                }

                _successMessage = result.data?.message ?? "Login berhasil! Mengalihkan...";
                StateHasChanged();
                await Task.Delay(500);
                Navigation.NavigateTo("/swipe", forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Terjadi kesalahan: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}

<style>
.auth-page { min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 1rem; }
.auth-card { background: var(--card-bg); border-radius: var(--border-radius); box-shadow: var(--card-shadow); padding: 2.5rem; width: 100%; max-width: 420px; }
.auth-header { text-align: center; margin-bottom: 2rem; }
.auth-icon { font-size: 3rem; display: block; animation: float 2s infinite; }
@@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
.auth-header h2 { margin: 0.5rem 0; color: var(--pink-primary); }
.auth-header p { opacity: 0.7; font-size: 0.9rem; }
.auth-form { display: flex; flex-direction: column; gap: 1rem; }
.form-group { display: flex; flex-direction: column; gap: 0.3rem; }
.form-group label { font-weight: 600; font-size: 0.85rem; }
.form-group input { padding: 0.7rem 1rem; border-radius: var(--border-radius-sm); border: 1.5px solid var(--pink-light); font-size: 0.95rem; background: transparent; transition: border-color 0.3s; outline: none; }
.form-group input:focus { border-color: var(--pink-primary); box-shadow: 0 0 0 3px rgba(255,107,157,0.15); }
.btn-full { width: 100%; justify-content: center; margin-top: 0.5rem; }
.alert-error { background: #fff0f0; color: #d32f2f; padding: 0.75rem 1rem; border-radius: var(--border-radius-sm); font-size: 0.85rem; border: 1px solid #ffcdd2; }
.alert-success { background: #e8f5e9; color: #2e7d32; padding: 0.75rem 1rem; border-radius: var(--border-radius-sm); font-size: 0.85rem; border: 1px solid #c8e6c9; }
.auth-footer { text-align: center; margin-top: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.9rem; }
.btn-link { background: none; border: none; color: var(--pink-primary); cursor: pointer; text-decoration: underline; font-size: 0.9rem; padding: 0.25rem; }
@@media (max-width: 480px) { .auth-card { padding: 1.5rem; } .auth-icon { font-size: 2.5rem; } }
</style>
