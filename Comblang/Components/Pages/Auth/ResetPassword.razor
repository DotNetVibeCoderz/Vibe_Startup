@page "/auth/reset-password"
@inject NavigationManager Navigation
@inject AuthService AuthService

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <span class="auth-icon">🔑</span>
            <h2>Reset Password</h2>
            <p>@(_step == 1 ? "Masukkan email kamu untuk menerima link reset." : "Masukkan password baru kamu.")</p>
        </div>

        <div class="auth-form">
            @if (_step == 1)
            {
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" @bind="_email" placeholder="email@example.com" />
                </div>
            }
            else
            {
                <div class="form-group">
                    <label>Token Reset</label>
                    <input type="text" @bind="_token" placeholder="Token dari email/link" />
                </div>
                <div class="form-group">
                    <label>Password Baru</label>
                    <input type="password" @bind="_newPassword" placeholder="Minimal 6 karakter" />
                </div>
                <div class="form-group">
                    <label>Konfirmasi Password Baru</label>
                    <input type="password" @bind="_confirmPassword" placeholder="Ulangi password" />
                </div>
            }

            @if (!string.IsNullOrEmpty(_message))
            {
                <div class="alert @(_isError ? "alert-error" : "alert-success")">@_message</div>
            }

            <button class="btn btn-primary btn-full" @onclick="SubmitReset" disabled="@_isSubmitting">
                @(_isSubmitting ? "⏳ Memproses..." : _step == 1 ? "📧 Kirim Link Reset" : "🔐 Reset Password")
            </button>

            <button class="btn-link" @onclick="GoBackToLogin">← Kembali ke Login</button>
        </div>
    </div>
</div>

@code {
    private int _step = 1;
    private bool _isSubmitting;
    private bool _isError;
    private string _email = "", _token = "", _newPassword = "", _confirmPassword = "";
    private string _message = "";

    private void GoBackToLogin() => Navigation.NavigateTo("/auth/login");

    private async Task SubmitReset()
    {
        _message = ""; _isError = false;

        if (_step == 1)
        {
            if (string.IsNullOrWhiteSpace(_email)) { _message = "Email harus diisi."; _isError = true; return; }
            _isSubmitting = true; StateHasChanged();
            try
            {
                var (success, msg, token) = await AuthService.RequestPasswordResetAsync(_email);
                _message = msg;
                if (token != null)
                {
                    _token = token;
                    _message += $"\n\n🔑 Token (DEV): {token}";
                    _step = 2;
                }
            }
            catch (Exception ex) { _message = $"Error: {ex.Message}"; _isError = true; }
            finally { _isSubmitting = false; }
        }
        else
        {
            if (string.IsNullOrWhiteSpace(_token)) { _message = "Token harus diisi."; _isError = true; return; }
            if (_newPassword != _confirmPassword) { _message = "Password tidak cocok."; _isError = true; return; }
            if (_newPassword.Length < 6) { _message = "Password minimal 6 karakter."; _isError = true; return; }

            _isSubmitting = true; StateHasChanged();
            try
            {
                var (success, msg) = await AuthService.ResetPasswordAsync(_email, _token, _newPassword);
                _message = msg; _isError = !success;
                if (success) { await Task.Delay(1500); Navigation.NavigateTo("/auth/login"); }
            }
            catch (Exception ex) { _message = $"Error: {ex.Message}"; _isError = true; }
            finally { _isSubmitting = false; }
        }
    }
}

<style>
.auth-page { min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 1rem; }
.auth-card { background: var(--card-bg); border-radius: var(--border-radius); box-shadow: var(--card-shadow); padding: 2.5rem; width: 100%; max-width: 420px; }
.auth-header { text-align: center; margin-bottom: 2rem; }
.auth-icon { font-size: 3rem; display: block; }
.auth-header h2 { margin: 0.5rem 0; color: var(--pink-primary); }
.auth-header p { opacity: 0.7; font-size: 0.9rem; }
.auth-form { display: flex; flex-direction: column; gap: 1rem; }
.form-group { display: flex; flex-direction: column; gap: 0.3rem; }
.form-group label { font-weight: 600; font-size: 0.85rem; }
.form-group input { padding: 0.7rem 1rem; border-radius: var(--border-radius-sm); border: 1.5px solid var(--pink-light); font-size: 0.95rem; background: transparent; outline: none; }
.form-group input:focus { border-color: var(--pink-primary); box-shadow: 0 0 0 3px rgba(255,107,157,0.15); }
.btn-full { width: 100%; justify-content: center; margin-top: 0.5rem; }
.alert-error { background: #fff0f0; color: #d32f2f; padding: 0.75rem 1rem; border-radius: var(--border-radius-sm); font-size: 0.85rem; border: 1px solid #ffcdd2; white-space: pre-line; }
.alert-success { background: #e8f5e9; color: #2e7d32; padding: 0.75rem 1rem; border-radius: var(--border-radius-sm); font-size: 0.85rem; border: 1px solid #c8e6c9; white-space: pre-line; }
.btn-link { background: none; border: none; color: var(--pink-primary); cursor: pointer; text-decoration: underline; font-size: 0.9rem; padding: 0.5rem; }
@@media (max-width: 480px) { .auth-card { padding: 1.5rem; } }
</style>
