.msg-bubble.typing{padding:.5rem .9rem;display:flex;align-items:center;gap:.5rem}.td{display:flex;gap:4px}.td span{width:7px;height:7px;border-radius:50%;background:#999;animation:tb 1.4s ease infinite}.td span:nth-child(2){animation-delay:.2s}.td span:nth-child(3){animation-delay:.4s}
