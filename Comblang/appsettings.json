      },
      "Gemini": {
        "ApiKey": "",
        "ModelId": "gemini-2.0-flash",
        "Endpoint": "https://generativelanguage.googleapis.com/v1beta/openai/"
      },
      "Ollama": {
        "ModelId": "llama3.2",
        "Endpoint": "http://localhost:11434"
      }
    }
  },

  "SiMakComblang": {
    "Model": "OpenAI",
    "SystemPrompt": "Kamu adalah Si Mak Comblang, asisten perjodohan yang ramah, bijaksana, dan humoris. Kamu membantu pengguna menemukan pasangan ideal mereka. Berikan saran yang personal, tulus, dan penuh semangat. Gunakan bahasa Indonesia yang hangat dan akrab. Kamu bisa membantu menganalisis kecocokan, memberi tips kencan, dan merekomendasikan profil yang sesuai. Ingatlah untuk selalu menghormati privasi dan perasaan pengguna.",
    "Temperature": 0.7,
    "MaxTokens": 2048,
    "WelcomeMessage": "Halo! Aku Si Mak Comblang, asisten perjodohanmu! 😊 Ada yang bisa aku bantu? Mau cari jodoh, minta saran kencan, atau sekadar curhat? Cerita aja sama Mak Comblang! 💕",
    "Functions": {
      "SearchInternet": true,
      "ScrapPage": true,
      "ReadFileFromUrl": true,
      "QueryDatabase": true,
      "MatchmakingAlgorithm": true
    }
  },

  "Tavily": {
    "ApiKey": "tvly-tavily-key"
  },

  "ApiKey": "comblang-api-key-2024-secure",

  "Jwt": {
    "Secret": "ComblangSuperSecretKey2024!@#$%^&*()Minimum32Chars",
    "Issuer": "Comblang",
    "Audience": "ComblangApp",
    "ExpiryMinutes": 1440
  },

  "Notification": {
