@page "/reset-password"
@layout LoginLayout
@rendermode InteractiveServer
@inject Services.AuthService AuthService
@inject NavigationManager Nav

<div class="login-page">
    <div class="login-card">
        <div style="text-align:center;margin-bottom:16px;">
            <span style="font-size:3rem;">🔐</span>
        </div>
        <h2>Reset Password</h2>
        <p class="subtitle">Masukkan email atau username Anda untuk mereset password</p>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-circle"></i> @_error
            </div>
        }
        @if (!string.IsNullOrEmpty(_success))
        {
            <div class="alert alert-success">
                <i class="bi bi-check-circle"></i>
                <strong>Password Berhasil Direset!</strong>
                <p style="margin-top:8px;white-space:pre-line;">@((MarkupString)_success)</p>
                <a href="/login" class="btn btn-primary btn-sm mt-2">🔑 Login Sekarang</a>
            </div>
        }

        @if (string.IsNullOrEmpty(_success))
        {
            <div class="form-group">
                <label>Email atau Username</label>
                <div style="position:relative;">
                    <i class="bi bi-envelope" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-muted);"></i>
                    <input type="text" class="form-control" style="padding-left:36px;"
                           @bind="_emailOrUsername" placeholder="Masukkan email atau username"
                           @onkeydown="HandleKeyDown" />
                </div>
            </div>

            <button class="btn btn-primary w-100 btn-lg" @onclick="HandleReset" disabled="@_loading">
                @if (_loading)
                {
                    <span><i class="bi bi-hourglass-split"></i> Memproses...</span>
                }
                else
                {
                    <span><i class="bi bi-key"></i> Reset Password</span>
                }
            </button>

            <div style="text-align:center;margin-top:16px;">
                <a href="/login"><i class="bi bi-arrow-left"></i> Kembali ke Login</a>
            </div>

            <hr style="margin:20px 0;border-color:var(--border-color);">

            <div style="background:var(--bg-secondary);padding:12px;border-radius:8px;">
                <strong style="font-size:0.85rem;">ℹ️ Petunjuk:</strong>
                <p style="font-size:0.8rem;color:var(--text-muted);margin-top:4px;">
                    Masukkan email atau username yang terdaftar. Password baru akan dibuat otomatis.
                    <br><br>
                    <em>Untuk demo: gunakan <code>admin</code>, <code>agen1</code>, atau <code>jamaah1</code></em>
                </p>
            </div>
        }
    </div>
</div>

@code {
    private string _emailOrUsername = "";
    private string? _error;
    private string? _success;
    private bool _loading;

    protected override void OnInitialized()
    {
        if (AuthService.IsAuthenticated) Nav.NavigateTo("/", true);
    }

    private async Task HandleReset()
    {
        _error = null;
        _success = null;

        if (string.IsNullOrWhiteSpace(_emailOrUsername))
        {
            _error = "Email atau username wajib diisi.";
            return;
        }

        _loading = true;
        try
        {
            var (success, msg) = await AuthService.ResetPasswordAsync(_emailOrUsername.Trim());
            if (success)
            {
                _success = msg;
            }
            else
            {
                _error = msg;
            }
        }
        catch (Exception ex)
        {
            _error = $"Terjadi kesalahan: {ex.Message}";
        }
        _loading = false;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleReset();
    }
}
