@page "/paket"
@rendermode InteractiveServer
@inject Data.AppDbContext Db

<div class="mb-3"><h2>🕋 Paket Haji & Umroh</h2><p class="text-muted">Pilih paket perjalanan suci Anda</p></div>

<div class="grid grid-3">
    @foreach (var p in _pakets)
    {
        <div class="card">
            <div style="height:160px;background:var(--bg-secondary);display:flex;align-items:center;justify-content:center;font-size:3rem;">🕋</div>
            <div class="card-body">
                <span class="badge @(p.JenisPaket=="HajiPlus"?"badge-danger":"badge-info")">@p.JenisPaket</span>
                <h3 style="margin:8px 0;">@p.NamaPaket</h3>
                <p style="font-size:0.85rem;">@(p.Deskripsi.Length>100?p.Deskripsi[..100]+"...":p.Deskripsi)</p>
                <div style="margin:12px 0;"><div><strong>💰 @p.Harga.ToString("C0")</strong></div><div>🕋 @p.DurasiHari Hari</div><div>✈️ @p.Maskapai</div><div>🏨 @p.NamaHotelMekkah</div><div>📅 @p.TanggalBerangkat?.ToString("dd MMM yyyy")</div></div>
                <div style="font-size:0.8rem;color:var(--text-muted);margin:8px 0;">Terisi: @p.Terisi/@p.Kuota (Sisa: @(p.Kuota-p.Terisi))</div>
                <div class="d-flex gap-2"><button class="btn btn-primary flex-1 btn-sm" @onclick="()=>_expandedPaketId=_expandedPaketId==p.Id?null:p.Id">📋 Itinerary</button></div>
                @if(_expandedPaketId==p.Id){<div class="mt-3" style="padding:12px;background:var(--bg-secondary);border-radius:8px;"><strong>Fasilitas:</strong><p>@p.Fasilitas</p><strong>Hotel Madinah:</strong>@p.NamaHotelMadinah<br><strong>Rute:</strong>@p.RutePenerbangan<br><strong>Kepulangan:</strong>@p.TanggalPulang?.ToString("dd MMM yyyy")</div>}
            </div>
        </div>
    }
</div>

@code {
    private List<Models.Paket> _pakets=new(); private int? _expandedPaketId;
    protected override async Task OnInitializedAsync(){ _pakets=Db.Paket.Where(p=>p.IsActive&&p.IsPublished).OrderBy(p=>p.TanggalBerangkat).ToList(); await Task.CompletedTask; }
}
