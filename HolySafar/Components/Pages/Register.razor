@page "/register"
@layout LoginLayout
@rendermode InteractiveServer
@inject Services.AuthService AuthService
@inject NavigationManager Nav

<div class="login-page">
    <div class="login-card" style="max-width:480px;">
        <div style="text-align:center;margin-bottom:16px;">
            <span style="font-size:3rem;">🕌</span>
        </div>
        <h2>HolySafar</h2>
        <p class="subtitle">Daftar Akun Baru</p>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger">@_error</div>
        }
        @if (!string.IsNullOrEmpty(_success))
        {
            <div class="alert alert-success">
                <strong>✅ @_success</strong>
                <br><br>
                <a href="/login" class="btn btn-primary btn-sm">Ke Halaman Login</a>
            </div>
        }

        @if (string.IsNullOrEmpty(_success))
        {
            <div class="grid grid-2">
                <div class="form-group">
                    <label>Nama Lengkap *</label>
                    <input type="text" class="form-control" @bind="_fullName" placeholder="Nama lengkap sesuai KTP" />
                </div>
                <div class="form-group">
                    <label>Username *</label>
                    <input type="text" class="form-control" @bind="_username" placeholder="Username unik" autocomplete="username" />
                </div>
            </div>

            <div class="grid grid-2">
                <div class="form-group">
                    <label>Password *</label>
                    <input type="password" class="form-control" @bind="_password" placeholder="Minimal 6 karakter" autocomplete="new-password" />
                </div>
                <div class="form-group">
                    <label>Konfirmasi Password *</label>
                    <input type="password" class="form-control" @bind="_confirmPassword" placeholder="Ulangi password" autocomplete="new-password" />
                    @if (!string.IsNullOrEmpty(_confirmPassword) && _password != _confirmPassword)
                    {
                        <small style="color:var(--danger);">Password tidak cocok!</small>
                    }
                </div>
            </div>

            <div class="grid grid-2">
                <div class="form-group">
                    <label>Email *</label>
                    <input type="email" class="form-control" @bind="_email" placeholder="contoh@email.com" autocomplete="email" />
                </div>
                <div class="form-group">
                    <label>No. Telepon</label>
                    <input type="text" class="form-control" @bind="_phone" placeholder="0812xxxx" autocomplete="tel" />
                </div>
            </div>

            <div class="form-group">
                <label>
                    <input type="checkbox" @bind="_agreeTerms" />
                    Saya setuju dengan <a href="#" @onclick:preventDefault>Syarat & Ketentuan</a> HolySafar
                </label>
            </div>

            <button class="btn btn-primary w-100 btn-lg" @onclick="HandleRegister" disabled="@(!_agreeTerms || _loading)">
                @if (_loading)
                {
                    <span>🔄 Memproses...</span>
                }
                else
                {
                    <span>📝 Daftar Sekarang</span>
                }
            </button>

            <div style="text-align:center;margin-top:16px;">
                <span>Sudah punya akun? </span>
                <a href="/login">Masuk di sini</a>
            </div>
        }
    </div>
</div>

@code {
    private string _fullName = "";
    private string _username = "";
    private string _password = "";
    private string _confirmPassword = "";
    private string _email = "";
    private string _phone = "";
    private bool _agreeTerms;
    private string? _error;
    private string? _success;
    private bool _loading;

    protected override void OnInitialized()
    {
        if (AuthService.IsAuthenticated) Nav.NavigateTo("/", true);
    }

    private async Task HandleRegister()
    {
        _error = null;
        _success = null;

        // Validasi
        if (string.IsNullOrWhiteSpace(_fullName))
        { _error = "Nama lengkap wajib diisi."; return; }
        if (string.IsNullOrWhiteSpace(_username) || _username.Trim().Length < 3)
        { _error = "Username minimal 3 karakter."; return; }
        if (string.IsNullOrWhiteSpace(_password) || _password.Length < 6)
        { _error = "Password minimal 6 karakter."; return; }
        if (_password != _confirmPassword)
        { _error = "Konfirmasi password tidak cocok."; return; }
        if (string.IsNullOrWhiteSpace(_email))
        { _error = "Email wajib diisi."; return; }
        if (!_agreeTerms)
        { _error = "Anda harus menyetujui syarat & ketentuan."; return; }

        _loading = true;
        try
        {
            var (success, msg) = await AuthService.RegisterAsync(
                _username.Trim(), _password, _fullName.Trim(), _email.Trim(), _phone.Trim());

            if (success)
            {
                _success = msg;
            }
            else
            {
                _error = msg;
            }
        }
        catch (Exception ex)
        {
            _error = $"Terjadi kesalahan: {ex.Message}";
        }
        _loading = false;
    }
}
