@page "/admin/produk"
@rendermode InteractiveServer
@inject Data.AppDbContext Db
@inject Services.StorageService Storage
@inject Services.ExportService Export
@inject IJSRuntime JS

<div class="card">
    <div class="card-header"><h3>🛍️ Master Data Produk</h3>
        <div class="d-flex gap-2">
            <button class="btn btn-outline btn-sm" @onclick="ExportCsv"><i class="bi bi-filetype-csv"></i> CSV</button>
            <button class="btn btn-outline btn-sm" @onclick="ExportExcel"><i class="bi bi-file-earmark-excel"></i> Excel</button>
            <button class="btn btn-primary btn-sm" @onclick="(()=>ShowForm(null))"><i class="bi bi-plus-lg"></i> Tambah</button>
        </div>
    </div>
    <div class="card-body">
        <div class="d-flex gap-2 mb-3 flex-wrap">
            <input class="form-control" style="max-width:250px;" placeholder="🔍 Cari..." @bind="_search" @bind:event="oninput"/>
            <select class="form-control" style="max-width:180px;" @bind="_filterKat"><option value="">Semua</option><option>Koper</option><option>Mukena</option><option>Sajadah</option><option>Aksesoris</option><option>Pakaian</option><option>Alas Kaki</option></select>
            <select class="form-control" style="max-width:150px;" @bind="_sortCol"><option value="NamaProduk">Nama</option><option value="Harga">Harga</option><option value="Stok">Stok</option></select>
            <button class="btn btn-outline btn-sm" @onclick="ToggleSortDir">@(_sortAsc?"▲ Asc":"▼ Desc")</button>
        </div>
        <div class="table-container"><table>
            <thead><tr><th>Gambar</th><th>Nama</th><th>Kategori</th><th>Harga</th><th>Stok</th><th>Status</th><th>Aksi</th></tr></thead>
            <tbody>@foreach(var p in _paged){<tr><td>@if(!string.IsNullOrEmpty(p.GambarUrl)){<img src="@p.GambarUrl" style="width:40px;height:40px;object-fit:cover;border-radius:6px;"/>}else{<span style="font-size:1.5rem;">📦</span>}</td><td><strong>@p.NamaProduk</strong></td><td><span class="badge badge-info">@p.Kategori</span></td><td>@p.Harga.ToString("C0")</td><td>@p.Stok</td><td><span class="badge @(p.IsActive?"badge-success":"badge-danger")">@(p.IsActive?"Aktif":"Nonaktif")</span></td><td><button class="btn btn-outline btn-sm" @onclick="(()=>ShowForm(p))"><i class="bi bi-pencil"></i></button><button class="btn btn-danger btn-sm" @onclick="(()=>Delete(p.Id))"><i class="bi bi-trash"></i></button></td></tr>}</tbody>
        </table></div>
        <div class="pagination"><button disabled="@(_page<=1)" @onclick="()=>_page--">Prev</button>@for(int i=1;i<=_totalPages;i++){<button class="@(i==_page?"active":"")" @onclick="()=>_page=i">@i</button>}<button disabled="@(_page>=_totalPages)" @onclick="()=>_page++">Next</button><span class="text-muted" style="margin-left:12px;">@_all.Count data</span></div>
    </div>
</div>

@if(_showForm){<div class="modal-backdrop" @onclick="(()=>_showForm=false)"><div class="modal" @onclick:stopPropagation="true" style="max-width:650px;"><div class="modal-header"><h3>@(_edit==null?"Tambah":"Edit") Produk</h3><button class="btn-icon" @onclick="(()=>_showForm=false)">✕</button></div><div class="modal-body"><div class="form-group"><label>Gambar</label>@if(!string.IsNullOrEmpty(_previewUrl)){<img src="@_previewUrl" style="max-width:200px;border-radius:8px;margin-bottom:8px;"/>}<InputFile OnChange="OnUpload" accept="image/*" class="form-control"/>@if(_uploading){<small>Mengupload...</small>}</div><div class="grid grid-2"><div class="form-group"><label>Nama *</label><input class="form-control" @bind="_ef.NamaProduk"/></div><div class="form-group"><label>Kategori</label><select class="form-control" @bind="_ef.Kategori"><option>Koper</option><option>Mukena</option><option>Sajadah</option><option>Aksesoris</option><option>Pakaian</option><option>Alas Kaki</option></select></div><div class="form-group"><label>Harga *</label><input type="number" class="form-control" @bind="_ef.Harga"/></div><div class="form-group"><label>Stok</label><input type="number" class="form-control" @bind="_ef.Stok"/></div></div><div class="form-group"><label>Deskripsi</label><textarea class="form-control" rows="3" @bind="_ef.Deskripsi"></textarea></div><div class="form-group"><label><input type="checkbox" @bind="_ef.IsActive"/> Aktif</label></div></div><div class="modal-footer"><button class="btn btn-outline" @onclick="(()=>_showForm=false)">Batal</button><button class="btn btn-primary" @onclick="Save">Simpan</button></div></div></div>}

@code {
    private List<Models.Produk> _all=new(),_paged=new();
    private string _search="",_filterKat="",_sortCol="NamaProduk"; private bool _sortAsc=true;
    private int _page=1,_pageSize=15,_totalPages=1;
    private bool _showForm,_uploading; private Models.Produk? _edit; private Models.Produk _ef=new(); private string? _previewUrl; private IBrowserFile? _selectedFile;

    protected override async Task OnInitializedAsync()=>await Load();
    private async Task Load(){_all=await Task.Run(()=>Db.Produk.OrderByDescending(p=>p.CreatedAt).ToList());Apply();}
    private void Apply(){var q=_all.AsEnumerable();if(!string.IsNullOrWhiteSpace(_search)){var s=_search.ToLower();q=q.Where(p=>p.NamaProduk.ToLower().Contains(s)||p.Kategori.ToLower().Contains(s));}if(!string.IsNullOrEmpty(_filterKat))q=q.Where(p=>p.Kategori==_filterKat);q=_sortCol switch{"Harga"=>_sortAsc?q.OrderBy(p=>p.Harga):q.OrderByDescending(p=>p.Harga),"Stok"=>_sortAsc?q.OrderBy(p=>p.Stok):q.OrderByDescending(p=>p.Stok),_=>_sortAsc?q.OrderBy(p=>p.NamaProduk):q.OrderByDescending(p=>p.NamaProduk)};_all=q.ToList();_totalPages=Math.Max(1,(int)Math.Ceiling(_all.Count/(double)_pageSize));if(_page>_totalPages)_page=_totalPages;_paged=_all.Skip((_page-1)*_pageSize).Take(_pageSize).ToList();}
    private void ToggleSortDir(){_sortAsc=!_sortAsc;Apply();}
    private void ShowForm(Models.Produk? p){_edit=p;_ef=p==null?new Models.Produk{IsActive=true,Kategori="Koper"}:new Models.Produk{Id=p.Id,NamaProduk=p.NamaProduk,Kategori=p.Kategori,Deskripsi=p.Deskripsi,Harga=p.Harga,Stok=p.Stok,GambarUrl=p.GambarUrl,IsActive=p.IsActive};_previewUrl=_ef.GambarUrl;_selectedFile=null;_showForm=true;}
    private async Task OnUpload(InputFileChangeEventArgs e){var f=e.File;if(f==null)return;_selectedFile=f;_uploading=true;await using var s=f.OpenReadStream(5*1024*1024);var url=await Storage.UploadAsync(s,f.Name,"produk");_ef.GambarUrl=url;_previewUrl=url;_uploading=false;}
    private async Task Save(){if(string.IsNullOrWhiteSpace(_ef.NamaProduk))return;if(_edit==null){_ef.CreatedAt=DateTime.UtcNow;Db.Produk.Add(_ef);}else{var p=await Db.Produk.FindAsync(_edit.Id);if(p!=null){p.NamaProduk=_ef.NamaProduk;p.Kategori=_ef.Kategori;p.Deskripsi=_ef.Deskripsi;p.Harga=_ef.Harga;p.Stok=_ef.Stok;p.GambarUrl=_ef.GambarUrl;p.IsActive=_ef.IsActive;}}await Db.SaveChangesAsync();_showForm=false;await Load();}
    private async Task Delete(int id){var p=await Db.Produk.FindAsync(id);if(p!=null){Db.Produk.Remove(p);await Db.SaveChangesAsync();await Load();}}
    private async Task Dnl(byte[] b,string fn){await JS.InvokeVoidAsync("eval",$"var a=document.createElement('a');a.href='data:application/octet-stream;base64,{Convert.ToBase64String(b)}';a.download='{fn}';a.click();");}
    private async Task ExportCsv()=>await Dnl(Export.ExportToCsv(_all.Select(p=>new{p.NamaProduk,p.Kategori,p.Harga,p.Stok,p.IsActive})),"produk.csv");
    private async Task ExportExcel()=>await Dnl(Export.ExportToExcel(_all.Select(p=>new{p.NamaProduk,p.Kategori,p.Harga,p.Stok,p.IsActive}),"Produk"),"produk.xlsx");
}
