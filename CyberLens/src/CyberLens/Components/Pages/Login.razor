@page "/login"
@layout EmptyLayout
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]

<PageTitle>Masuk — CyberLens</PageTitle>

<div class="login-wrap">
    <div class="login-card">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:22px">
            <div class="brand" style="border:none;padding:0">
                <div class="mark" style="width:44px;height:44px"><Icon Name="lens" Size="26" /></div>
            </div>
            <div>
                <div class="name" style="font-family:var(--font-display);font-size:30px;font-weight:800;letter-spacing:-0.03em">CyberLens</div>
                <div class="mono" style="font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink-mute)">OSINT // Media Intelligence</div>
            </div>
        </div>

        <div class="card pad">
            <div class="mono" style="font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:4px">// authenticate</div>
            <h1 style="font-size:24px;margin-bottom:18px">Masuk ke konsol</h1>

            @if (HasError)
            {
                <div class="card" style="background:color-mix(in srgb, var(--red) 15%, var(--surface));border-color:var(--red);padding:11px 14px;margin-bottom:16px;box-shadow:none">
                    <span class="mono" style="font-size:12px;color:var(--red);font-weight:600">✕ Username atau password salah.</span>
                </div>
            }

            <form method="post" action="/auth/login">
                <AntiforgeryToken />
                <input type="hidden" name="returnUrl" value="@ReturnUrl" />
                <div class="field-row">
                    <label class="fld">Username</label>
                    <input class="inp" name="username" autocomplete="username" required autofocus placeholder="admin" />
                </div>
                <div class="field-row">
                    <label class="fld">Password</label>
                    <input class="inp" name="password" type="password" autocomplete="current-password" required placeholder="••••••••" />
                </div>
                <button class="btn accent" type="submit" style="width:100%;justify-content:center;font-size:15px">
                    <Icon Name="lock" Size="16" /> Masuk
                </button>
            </form>
        </div>

        <div class="card pad" style="margin-top:14px;box-shadow:var(--shadow-sm)">
            <div class="mono" style="font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:8px">// akun demo (password = username)</div>
            <div class="wrap">
                <span class="tag-chip">admin</span>
                <span class="tag-chip">analyst</span>
                <span class="tag-chip">viewer</span>
                <span class="tag-chip">supervisor</span>
            </div>
        </div>

        <div class="mono" style="text-align:center;font-size:10.5px;color:var(--ink-mute);margin-top:18px;line-height:1.6">
            Dibuat oleh <span style="color:var(--accent);font-weight:600">Gravicode Studios</span><br />
            dipimpin oleh Kang Fadhil
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public int? Error { get; set; }
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
    private bool HasError => Error == 1;
}
