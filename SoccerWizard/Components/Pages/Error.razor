@page "/error"

<div class="sw-error-page">
    <div class="sw-error-container">
        <div class="sw-error-code">@StatusCode</div>
        <h1 class="sw-error-title">@ErrorTitle</h1>
        <p class="sw-error-message">@ErrorMessage</p>
        <a href="/" class="sw-btn sw-btn-primary sw-btn-lg">
            <i class="bi bi-house-fill"></i> Back to Dashboard
        </a>
    </div>
</div>

@code {
    [Parameter] public int StatusCode { get; set; } = 500;
    
    private string ErrorTitle => StatusCode switch
    {
        404 => "Page Not Found",
        403 => "Access Denied",
        500 => "Server Error",
        _ => "Something went wrong"
    };
    
    private string ErrorMessage => StatusCode switch
    {
        404 => "The page you're looking for doesn't exist or has been moved.",
        403 => "You don't have permission to access this page.",
        _ => "An unexpected error has occurred. Please try again later."
    };
}
