@page "/auth/reset-password"
@rendermode InteractiveServer
@inject NavigationManager Navigation

<div class="sw-auth-page">
    <div class="sw-auth-container">
        <div class="sw-auth-header">
            <div class="sw-auth-logo">⚽</div>
            <h1>Reset <b>Password</b></h1>
            <p>Set a new password for your account</p>
        </div>

        <div class="sw-auth-card">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="sw-alert danger"><i class="bi bi-exclamation-triangle"></i><span>@errorMessage</span></div>
            }
            
            <form method="post" action="/reset-password">
                <div class="sw-form-group">
                    <label><i class="bi bi-envelope"></i> Email</label>
                    <input type="email" name="email" class="sw-input" placeholder="your@email.com" required />
                </div>
                <div class="sw-form-group">
                    <label><i class="bi bi-lock"></i> New Password</label>
                    <input type="password" name="newPassword" class="sw-input" placeholder="Min. 6 characters" required minlength="6" />
                </div>
                <div class="sw-form-group">
                    <label><i class="bi bi-lock-fill"></i> Confirm New Password</label>
                    <input type="password" name="confirmPassword" class="sw-input" placeholder="Repeat new password" required minlength="6" />
                </div>
                <button type="submit" class="sw-btn sw-btn-primary sw-btn-block"><i class="bi bi-key"></i> Reset Password</button>
            </form>

            <div class="sw-auth-footer">
                <a href="/auth/login">Back to login</a>
            </div>
        </div>
    </div>
</div>

@code {
    private string? errorMessage;

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        errorMessage = query["error"];
    }
}
