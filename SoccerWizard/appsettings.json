{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "DatabaseProvider": "Sqlite",

  "ConnectionStrings": {
    "Sqlite": "Data Source=SoccerWizard.db",
    "SqlServer": "Server=localhost;Database=SoccerWizard;User Id=sa;Password=YourPassword123;TrustServerCertificate=True;",
    "MySql": "Server=localhost;Database=SoccerWizard;User=root;Password=YourPassword123;",
    "PostgreSql": "Host=localhost;Database=SoccerWizard;Username=postgres;Password=YourPassword123;"
  },

  "StorageProvider": "FileSystem",

  "Storage": {
    "FileSystem": { "RootPath": "wwwroot/uploads" },
    "S3": {
      "BucketName": "soccerwizard-uploads",
      "Region": "us-east-1",
      "AccessKey": "",
      "SecretKey": "",
      "ServiceUrl": null
    },
    "MinIO": {
      "BucketName": "soccerwizard-uploads",
      "Endpoint": "localhost:9000",
      "AccessKey": "minioadmin",
      "SecretKey": "minioadmin",
      "UseSsl": false
    },
    "AzureBlob": {
      "ConnectionString": "DefaultEndpointsProtocol=https;xxx",
      "ContainerName": "soccerwizard-uploads"
    }
  },

  "VectorDatabaseProvider": "InMemory",

  "VectorDatabase": {
    "InMemory": {},
    "Sqlite": { "ConnectionString": "Data Source=SoccerWizardVectors.db" },
    "Qdrant": {
      "Endpoint": "http://localhost:6333",
      "ApiKey": "",
      "VectorSize": 1536
    },
    "Chroma": {
      "Endpoint": "http://localhost:8000",
      "CollectionName": "soccerwizard_embeddings"
    }
  },

  "LLM": {
    "DefaultProvider": "OpenAI",
    "SystemPrompt": "You are SoccerWizard AI, a football expert. Be concise and helpful.",
    "OpenAI": {
      "ApiKey": "sk-proj-open-ai-key",
      "Model": "gpt-4o-mini",
      "EmbeddingModel": "text-embedding-3-small"
    },
    "Gemini": {
      "ApiKey": "",
      "Model": "gemini-2.0-flash",
      "EmbeddingModel": "text-embedding-004"
    },
    "Anthropic": {
      "ApiKey": "",
      "Model": "claude-3-5-sonnet-20241022"
    },
    "Ollama": {
      "Endpoint": "http://localhost:11434",
      "Model": "llama3.2",
      "EmbeddingModel": "nomic-embed-text"
    }
  },

  "Tavily": {
    "ApiKey": "tvly-key"
  },

  "SportsData": {
    "ApiKey": "sport-data-api-key",
    "BaseUrl": "https://api.football-data.org/v4"
  },

  "ApiKeys": [
    "sw-dev-key-2024",
    "sw-api-key-2025-prod"
  ],
 
  "AppSettings": {
    "AppName": "SoccerWizard",
    "Version": "2.0.0",
    "BaseUrl": "https://localhost:5001",
    "EnableRealTimeUpdates": true,
    "PredictionRefreshMinutes": 5,
    "MaxPredictionsPerDay": 50,
    "EnableVectorSearch": true
  }
}
