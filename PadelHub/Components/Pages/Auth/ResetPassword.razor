@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@page "/auth/reset-password"
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Reset Password - PadelHub</PageTitle>
<div class="d-flex align-center justify-center" style="min-height:80vh;">
    <MudPaper Class="pa-8" Elevation="4" Style="max-width:440px; width:100%; border-radius:16px;">
        <div class="text-center mb-6">
            <MudIcon Icon="@Icons.Material.Filled.LockReset" Size="Size.Large" Color="Color.Primary" />
            <MudText Typo="Typo.h5" Style="font-weight:700;" Class="mt-2">Reset Password</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@(_tokenSent ? "Masukkan token & password baru" : "Masukkan email untuk reset")</MudText>
        </div>
        @if (!_tokenSent) {
            <EditForm Model="_model" OnValidSubmit="SendResetLinkAsync" FormName="resetForm">
                <MudTextField @bind-Value="_model.Email" Label="Email" Variant="Variant.Outlined" Required="true" InputType="InputType.Email" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" Class="mb-4" />
                @if (!string.IsNullOrEmpty(_error)) { <MudAlert Severity="Severity.Error" Class="mb-3" Square="false" Variant="Variant.Filled">@_error</MudAlert> }
                @if (!string.IsNullOrEmpty(_success)) { <MudAlert Severity="Severity.Success" Class="mb-3" Square="false" Variant="Variant.Filled">@_success</MudAlert> }
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large" ButtonType="ButtonType.Submit" StartIcon="@Icons.Material.Filled.Send" Disabled="_isSubmitting">Kirim Link Reset</MudButton>
            </EditForm>
        } else {
            <EditForm Model="_resetModel" OnValidSubmit="ResetPasswordAsync" FormName="newPasswordForm">
                <MudTextField @bind-Value="_resetModel.Token" Label="Token Reset" Variant="Variant.Outlined" Required="true" Class="mb-3" />
                <MudTextField @bind-Value="_resetModel.NewPassword" Label="Password Baru" Variant="Variant.Outlined" Required="true" InputType="InputType.Password" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" Class="mb-3" />
                <MudTextField @bind-Value="_resetModel.ConfirmPassword" Label="Konfirmasi" Variant="Variant.Outlined" Required="true" InputType="InputType.Password" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" Class="mb-4" />
                @if (!string.IsNullOrEmpty(_error)) { <MudAlert Severity="Severity.Error" Class="mb-3" Square="false" Variant="Variant.Filled">@_error</MudAlert> }
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large" ButtonType="ButtonType.Submit" StartIcon="@Icons.Material.Filled.LockReset" Disabled="_isSubmitting">Reset Password</MudButton>
            </EditForm>
        }
        <MudDivider Class="my-4" />
        <MudText Typo="Typo.body2" Align="Align.Center"><MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="GoLogin" Size="Size.Small">← Kembali ke Login</MudButton></MudText>
    </MudPaper>
</div>

@code {
    private ResetRequestModel _model = new(); private ResetPasswordModel _resetModel = new();
    private string? _error; private string? _success; private bool _isSubmitting; private bool _tokenSent;

    private async Task SendResetLinkAsync() {
        _error = null; _isSubmitting = true;
        var user = await UserManager.FindByEmailAsync(_model.Email);
        if (user == null || !user.IsActive) { _success = "Jika email terdaftar, link reset dikirim."; _tokenSent = true; _isSubmitting = false; return; }
        var token = await UserManager.GeneratePasswordResetTokenAsync(user);
        _success = "Token reset dibuat (demo)."; _resetModel = new ResetPasswordModel { Token = token }; _tokenSent = true; _isSubmitting = false;
        Snackbar.Add("Link reset dibuat!", Severity.Info);
    }
    private async Task ResetPasswordAsync() {
        _error = null; _isSubmitting = true;
        if (_resetModel.NewPassword != _resetModel.ConfirmPassword) { _error = "Password tidak cocok."; _isSubmitting = false; return; }
        var user = await UserManager.FindByEmailAsync(_model.Email);
        if (user == null) { _error = "User tidak ditemukan."; _isSubmitting = false; return; }
        var result = await UserManager.ResetPasswordAsync(user, _resetModel.Token, _resetModel.NewPassword);
        if (result.Succeeded) { Snackbar.Add("Password direset!", Severity.Success); Nav.NavigateTo("/auth/login"); }
        else { _error = "Token tidak valid."; }
        _isSubmitting = false;
    }
    private void GoLogin() => Nav.NavigateTo("/auth/login");
    private class ResetRequestModel { public string Email { get; set; } = ""; }
    private class ResetPasswordModel { public string Token { get; set; } = ""; public string NewPassword { get; set; } = ""; public string ConfirmPassword { get; set; } = ""; }
}
