@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Operator")]
@page "/analytics/matches"
@inject AppDbContext Db

<PageTitle>Statistik Pertandingan - PadelHub</PageTitle>
<MudText Typo="Typo.h4" GutterBottom="true">📊 Statistik Pertandingan</MudText>

<MudGrid>
    <MudItem xs="12" md="4"><MudPaper Class="pa-4" Elevation="2" Style="text-align:center;"><MudText Typo="Typo.caption">Total Pertandingan</MudText><MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight:700;">@_totalMatches</MudText></MudPaper></MudItem>
    <MudItem xs="12" md="4"><MudPaper Class="pa-4" Elevation="2" Style="text-align:center;"><MudText Typo="Typo.caption">Turnamen Aktif</MudText><MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight:700;">@_activeTournaments</MudText></MudPaper></MudItem>
    <MudItem xs="12" md="4"><MudPaper Class="pa-4" Elevation="2" Style="text-align:center;"><MudText Typo="Typo.caption">Turnamen Selesai</MudText><MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight:700;">@_completedTournaments</MudText></MudPaper></MudItem>
</MudGrid>

<MudPaper Class="pa-4 mt-4" Elevation="2" Style="border-radius:12px;">
    <MudText Typo="Typo.h6" GutterBottom="true">🏆 Hasil Pertandingan Terbaru</MudText>
    <MudTable Items="_recentMatches" Hover="true" Dense="true">
        <HeaderContent><MudTh>Turnamen</MudTh><MudTh>Round</MudTh><MudTh>Court</MudTh><MudTh>Waktu</MudTh><MudTh>Score</MudTh><MudTh>Status</MudTh></HeaderContent>
        <RowTemplate>
            <MudTd>@context.Tournament?.Name</MudTd>
            <MudTd><span class="badge-chip">@context.RoundName</span></MudTd>
            <MudTd>@context.Court?.Name</MudTd>
            <MudTd>@(context.ScheduledTime?.ToString("dd MMM HH:mm") ?? "-")</MudTd>
            <MudTd><strong>@context.Score</strong></MudTd>
            <MudTd><span class="badge-chip @GetStatusBadge(context.Status)">@context.Status</span></MudTd>
        </RowTemplate>
    </MudTable>
</MudPaper>

<MudPaper Class="pa-4 mt-4" Elevation="2" Style="border-radius:12px;">
    <MudText Typo="Typo.h6" GutterBottom="true">👥 Performa Pemain (Top Scorers)</MudText>
    <MudTable Items="_topPlayers" Hover="true" Dense="true">
        <HeaderContent><MudTh>Pemain</MudTh><MudTh>Rating</MudTh><MudTh>Match</MudTh><MudTh>Win</MudTh><MudTh>Loss</MudTh><MudTh>Win Rate</MudTh></HeaderContent>
        <RowTemplate>
            <MudTd><strong>@context.User?.FullName</strong></MudTd>
            <MudTd>@context.Rating</MudTd>
            <MudTd>@context.TotalMatches</MudTd>
            <MudTd style="color:#2E7D32;">@context.Wins</MudTd>
            <MudTd style="color:#C62828;">@context.Losses</MudTd>
            <MudTd>@(context.TotalMatches > 0 ? (context.Wins * 100 / context.TotalMatches).ToString() + "%" : "N/A")</MudTd>
        </RowTemplate>
    </MudTable>
</MudPaper>

@code {
    private int _totalMatches, _activeTournaments, _completedTournaments;
    private List<Match> _recentMatches = new();
    private List<PlayerProfile> _topPlayers = new();

    protected override async Task OnInitializedAsync()
    {
        _totalMatches = await Db.Matches.CountAsync();
        _activeTournaments = await Db.Tournaments.CountAsync(t => t.Status == "InProgress" || t.Status == "Registration");
        _completedTournaments = await Db.Tournaments.CountAsync(t => t.Status == "Completed");
        _recentMatches = await Db.Matches.Include(m => m.Tournament).Include(m => m.Court).OrderByDescending(m => m.CreatedAt).Take(15).ToListAsync();
        _topPlayers = await Db.PlayerProfiles.Include(p => p.User).OrderByDescending(p => p.Rating).Take(10).ToListAsync();
    }

    private static string GetStatusBadge(string? s) => s switch { "Scheduled" => "badge-info", "InProgress" => "badge-warning", "Completed" => "badge-success", "Cancelled" => "badge-error", _ => "" };
}
