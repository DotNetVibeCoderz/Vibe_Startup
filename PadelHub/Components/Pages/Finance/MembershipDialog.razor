@using MudBlazor

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(_isEdit ? "✏️ Edit Paket" : "➕ Tambah Paket")</MudText></TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_name" Label="Nama Paket" Variant="Variant.Outlined" Required="true" Class="mb-3" />
        <MudSelect @bind-Value="_type" Label="Tipe" Variant="Variant.Outlined" Class="mb-3">
            <MudSelectItem Value="@("Monthly")">Bulanan</MudSelectItem>
            <MudSelectItem Value="@("Yearly")">Tahunan</MudSelectItem>
        </MudSelect>
        <MudTextField @bind-Value="_price" Label="Harga (Rp)" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentText="Rp" Class="mb-3" />
        <MudTextField @bind-Value="_discount" Label="Diskon (%)" Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField @bind-Value="_durationDays" Label="Durasi (hari)" Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField @bind-Value="_maxBooking" Label="Max Booking/Bulan" Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField @bind-Value="_desc" Label="Deskripsi" Variant="Variant.Outlined" Lines="3" Class="mb-3" />
        <MudSwitch @bind-Value="_isActive" Label="Aktif" Color="Color.Primary" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Batal</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">Simpan</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public bool IsEdit { get; set; }
    private bool _isEdit => IsEdit;
    private string _name = ""; private string _type = "Monthly"; private string _price = "500000";
    private string _discount = "5"; private string _durationDays = "30"; private string _maxBooking = "8";
    private string _desc = ""; private bool _isActive = true;

    private void Submit() => MudDialog?.Close(DialogResult.Ok(new { Name = _name, Type = _type, Price = _price, Discount = _discount, DurationDays = _durationDays, MaxBooking = _maxBooking, Description = _desc, IsActive = _isActive }));
    private void Cancel() => MudDialog?.Cancel();
}
