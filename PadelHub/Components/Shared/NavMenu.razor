@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using MudBlazor

<CascadingAuthenticationState>
    <MudNavMenu Style="padding-top:8px;">
        @if (_isAuthenticated)
        {
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudDivider Class="my-2" />
            <MudNavLink Href="/reservations" Icon="@Icons.Material.Filled.CalendarMonth">Reservasi</MudNavLink>
            <MudNavLink Href="/tournaments" Icon="@Icons.Material.Filled.EmojiEvents">Turnamen</MudNavLink>
            <MudNavLink Href="/players/rankings" Icon="@Icons.Material.Filled.Leaderboard">Ranking</MudNavLink>
            <MudNavLink Href="/coaches" Icon="@Icons.Material.Filled.School">Pelatih</MudNavLink>
            <MudDivider Class="my-2" />
            <MudNavGroup Title="Komunitas" Icon="@Icons.Material.Filled.Forum" Expanded="false">
                <MudNavLink Href="/social/timeline" Icon="@Icons.Material.Filled.Timeline">Timeline</MudNavLink>
                <MudNavLink Href="/social/chat" Icon="@Icons.Material.Filled.Chat">Chat</MudNavLink>
                <MudNavLink Href="/social/forum" Icon="@Icons.Material.Filled.QuestionAnswer">Forum</MudNavLink>
                <MudNavLink Href="/social/events" Icon="@Icons.Material.Filled.Event">Event</MudNavLink>
            </MudNavGroup>
            <MudNavLink Href="/chatbot" Icon="@Icons.Material.Filled.SmartToy" Style="font-weight:bold; color:var(--mud-palette-secondary);">🤖 Coach Sherly</MudNavLink>
            <MudDivider Class="my-2" />

            @if (_isOperatorOrAdmin)
            {
                <MudNavGroup Title="Manajemen" Icon="@Icons.Material.Filled.Business" Expanded="false">
                    <MudNavLink Href="/clubs" Icon="@Icons.Material.Filled.List">Klub</MudNavLink>
                    <MudNavLink Href="/courts" Icon="@Icons.Material.Filled.GridView">Lapangan</MudNavLink>
                    <MudNavLink Href="/players" Icon="@Icons.Material.Filled.People">Pemain</MudNavLink>
                    <MudNavLink Href="/players/cards" Icon="@Icons.Material.Filled.CreditCard">Kartu Member</MudNavLink>
                    <MudNavLink Href="/players/checkin" Icon="@Icons.Material.Filled.QrCodeScanner">Check-in</MudNavLink>
                    <MudNavLink Href="/training" Icon="@Icons.Material.Filled.Schedule">Latihan</MudNavLink>
                </MudNavGroup>
                <MudNavGroup Title="Keuangan" Icon="@Icons.Material.Filled.AccountBalanceWallet" Expanded="false">
                    <MudNavLink Href="/finance/payments" Icon="@Icons.Material.Filled.Payment">Pembayaran</MudNavLink>
                    <MudNavLink Href="/finance/membership" Icon="@Icons.Material.Filled.CardMembership">Membership</MudNavLink>
                    <MudNavLink Href="/finance/reports" Icon="@Icons.Material.Filled.Assessment">Laporan</MudNavLink>
                </MudNavGroup>
                <MudNavGroup Title="Analitik" Icon="@Icons.Material.Filled.Analytics" Expanded="false">
                    <MudNavLink Href="/analytics/dashboard" Icon="@Icons.Material.Filled.Insights">Dashboard</MudNavLink>
                    <MudNavLink Href="/analytics/matches" Icon="@Icons.Material.Filled.SportsTennis">Match</MudNavLink>
                </MudNavGroup>
                <MudDivider Class="my-2" />
            }

            @if (_isAdmin)
            {
                <MudNavGroup Title="Administrasi" Icon="@Icons.Material.Filled.AdminPanelSettings" Expanded="false">
                    <MudNavLink Href="/admin/users" Icon="@Icons.Material.Filled.ManageAccounts">User</MudNavLink>
                    <MudNavLink Href="/admin/master-data" Icon="@Icons.Material.Filled.Storage">Master Data</MudNavLink>
                    <MudNavLink Href="/admin/audit-log" Icon="@Icons.Material.Filled.History">Audit Log</MudNavLink>
                    <MudNavLink Href="/admin/system-config" Icon="@Icons.Material.Filled.Settings">Konfigurasi</MudNavLink>
                    <MudNavLink Href="/admin/iot" Icon="@Icons.Material.Filled.Sensors">IoT Simulator</MudNavLink>
                </MudNavGroup>
                <MudNavLink Href="/swagger" Icon="@Icons.Material.Filled.Api" Target="_blank">API (Swagger)</MudNavLink>
            }
        }
        else
        {
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Beranda</MudNavLink>
            <MudDivider Class="my-2" />
            <MudNavLink Href="/auth/login" Icon="@Icons.Material.Filled.Login">Masuk</MudNavLink>
            <MudNavLink Href="/auth/register" Icon="@Icons.Material.Filled.PersonAdd">Daftar</MudNavLink>
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="pa-4">🔒 Login untuk akses penuh.</MudText>
        }
    </MudNavMenu>
</CascadingAuthenticationState>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }
    private bool _isAuthenticated;
    private bool _isAdmin;
    private bool _isOperatorOrAdmin;

    protected override async Task OnParametersSetAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;
            _isAuthenticated = user.Identity?.IsAuthenticated == true;
            _isAdmin = user.IsInRole("Admin");
            _isOperatorOrAdmin = _isAdmin || user.IsInRole("Operator");
        }
    }
}
