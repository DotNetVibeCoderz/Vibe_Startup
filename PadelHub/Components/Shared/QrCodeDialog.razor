@using MudBlazor
@inject IJSRuntime JS

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">🎾 Kartu Member - @PlayerName</MudText>
    </TitleContent>
    <DialogContent>
        <MudPaper Class="pa-6" Elevation="3" Style="text-align:center; max-width:350px; margin:0 auto; border-radius:16px; background: linear-gradient(135deg, #1B5E20 0%, #4CAF50 100%); color:white;">
            <MudText Typo="Typo.h6" Style="font-weight:700;">PadelHub</MudText>
            <MudText Typo="Typo.caption">Member Card</MudText>
            <MudDivider Class="my-3" Style="border-color:rgba(255,255,255,0.3);" />
            <img src="@QrCodeBase64" alt="QR Code" style="width:180px; height:180px; background:white; padding:8px; border-radius:8px;" />
            <MudDivider Class="my-3" Style="border-color:rgba(255,255,255,0.3);" />
            <MudText Typo="Typo.body1" Style="font-weight:600;">@PlayerName</MudText>
        </MudPaper>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="PrintCard">Cetak</MudButton>
        <MudButton OnClick="CloseDialog">Tutup</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public string QrCodeBase64 { get; set; } = "";
    [Parameter] public string PlayerName { get; set; } = "";

    private async Task PrintCard() => await JS.InvokeVoidAsync("print");
    private void CloseDialog() => MudDialog?.Close(DialogResult.Ok(true));
}
