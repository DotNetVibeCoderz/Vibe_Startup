@page "/leaderboard"
@attribute [Authorize]
@inject GamificationService Service

<h3>🏆 Leaderboard</h3>
<div class="brutal-card" style="padding:0;">
    <table class="brutal-table w-full">
        <thead><tr><th>Rank</th><th>Member</th><th>Points</th></tr></thead>
        <tbody>
            @{
                int rank = 1;
            }
            @foreach (var entry in leaderboard)
            {
                <tr>
                    <td>@(rank == 1 ? "🥇" : rank == 2 ? "🥈" : rank == 3 ? "🥉" : rank.ToString())</td>
                    <td>@entry.UserName</td>
                    <td><strong>@entry.TotalPoints</strong></td>
                </tr>
                rank++;
            }
        </tbody>
    </table>
</div>

@code {
    private List<LeaderboardEntry> leaderboard = new();
    protected override async Task OnInitializedAsync() => leaderboard = await Service.GetLeaderboardAsync(20);
}
