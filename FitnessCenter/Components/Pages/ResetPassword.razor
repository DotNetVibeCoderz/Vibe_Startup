@page "/reset-password"
@attribute [Authorize]
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Navigation

<h3>🔑 Reset Password</h3>

<div class="brutal-card" style="max-width:500px;">
    <p style="color:var(--text-muted);">Enter your current password and new password below.</p>

    @if (!string.IsNullOrEmpty(errorMsg))
    {
        <div class="brutal-badge brutal-badge-danger w-full mb-2" style="display:block;text-align:center;">@errorMsg</div>
    }
    @if (!string.IsNullOrEmpty(successMsg))
    {
        <div class="brutal-badge brutal-badge-success w-full mb-2" style="display:block;text-align:center;">@successMsg</div>
    }

    <div class="mb-1">
        <label>Current Password</label>
        <input class="brutal-input" type="password" @bind="currentPassword" />
    </div>
    <div class="mb-1">
        <label>New Password (min 8 chars, uppercase, lowercase, digit)</label>
        <input class="brutal-input" type="password" @bind="newPassword" />
    </div>
    <div class="mb-2">
        <label>Confirm New Password</label>
        <input class="brutal-input" type="password" @bind="confirmPassword" />
    </div>
    <button class="brutal-btn brutal-btn-primary w-full" @onclick="ChangePassword" disabled="@isLoading">
        @(isLoading ? "Processing..." : "🔑 Reset Password")
    </button>

    <div class="mt-2">
        <a href="/profile" class="brutal-btn brutal-btn-outline brutal-btn-sm">← Back to Profile</a>
    </div>
</div>

@code {
    private string currentPassword = "", newPassword = "", confirmPassword = "";
    private string errorMsg = "", successMsg = "";
    private bool isLoading;

    private async Task ChangePassword()
    {
        errorMsg = ""; successMsg = "";

        if (string.IsNullOrWhiteSpace(currentPassword) || string.IsNullOrWhiteSpace(newPassword))
        { errorMsg = "All fields are required."; return; }
        if (newPassword.Length < 8)
        { errorMsg = "New password must be at least 8 characters."; return; }
        if (newPassword != confirmPassword)
        { errorMsg = "Passwords do not match."; return; }

        isLoading = true;
        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(authState.User);
            if (user != null)
            {
                var result = await UserManager.ChangePasswordAsync(user, currentPassword, newPassword);
                if (result.Succeeded) { successMsg = "✅ Password changed successfully!"; currentPassword = ""; newPassword = ""; confirmPassword = ""; }
                else { errorMsg = string.Join("; ", result.Errors.Select(e => e.Description)); }
            }
        }
        catch (Exception ex) { errorMsg = ex.Message; }
        finally { isLoading = false; }
    }
}
