@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState

<div class="brutal-layout">
    <button class="mobile-menu-btn" style="position:fixed;top:0.5rem;left:0.5rem;z-index:200;background:var(--bg-secondary);"
            @onclick="() => mobileOpen = !mobileOpen">
        ☰
    </button>

    <aside class="brutal-sidebar @(mobileOpen ? "mobile-open" : "")">
        <div class="brutal-sidebar-logo">
            🏋️ FITNESS<br>CENTER
        </div>
        <nav>
            <NavLink class="brutal-nav-item" href="/" Match="NavLinkMatch.All">🏠 Dashboard</NavLink>
            @if (isAuthenticated)
            {
                <div style="padding:0.5rem 1.5rem;font-size:0.7rem;color:var(--text-muted);text-transform:uppercase;margin-top:0.5rem;">Main Menu</div>
                <NavLink class="brutal-nav-item" href="/members">👥 Members</NavLink>
                <NavLink class="brutal-nav-item" href="/memberships">💳 Memberships</NavLink>
                <NavLink class="brutal-nav-item" href="/attendance">📋 Attendance</NavLink>
                <NavLink class="brutal-nav-item" href="/classes">📅 Classes</NavLink>
                <NavLink class="brutal-nav-item" href="/trainers">🎯 Trainers</NavLink>

                <div style="padding:0.5rem 1.5rem;font-size:0.7rem;color:var(--text-muted);text-transform:uppercase;margin-top:0.5rem;">Features</div>
                <NavLink class="brutal-nav-item" href="/payments">💰 Payments</NavLink>
                <NavLink class="brutal-nav-item" href="/discounts">🏷️ Discounts</NavLink>
                <NavLink class="brutal-nav-item" href="/forum">💬 Forum</NavLink>
                <NavLink class="brutal-nav-item" href="/events">🎪 Events</NavLink>
                <NavLink class="brutal-nav-item" href="/workout">🏃 Workout</NavLink>
                <NavLink class="brutal-nav-item" href="/nutrition">🥗 Nutrition</NavLink>
                <NavLink class="brutal-nav-item" href="/feedback">⭐ Feedback</NavLink>
                <NavLink class="brutal-nav-item" href="/leaderboard">🏆 Leaderboard</NavLink>
                <NavLink class="brutal-nav-item" href="/chatbot">🤖 Chat Coach</NavLink>
                <NavLink class="brutal-nav-item" href="/api/docs" target="_blank">📡 API Docs</NavLink>

                <div style="padding:0.5rem 1.5rem;font-size:0.7rem;color:var(--text-muted);text-transform:uppercase;margin-top:0.5rem;">Account</div>
                <NavLink class="brutal-nav-item" href="/profile">👤 Profile</NavLink>
                <NavLink class="brutal-nav-item" href="/reset-password">🔑 Reset Password</NavLink>

                @if (currentUser?.Role == UserRole.Admin)
                {
                    <div style="padding:0.5rem 1.5rem;font-size:0.7rem;color:var(--text-muted);text-transform:uppercase;margin-top:0.5rem;">Admin</div>
                    <NavLink class="brutal-nav-item" href="/admin/config">⚙️ Configuration</NavLink>
                }
            }
            else
            {
                <div style="padding:0.5rem 1.5rem;font-size:0.7rem;color:var(--text-muted);text-transform:uppercase;margin-top:0.5rem;">Account</div>
                <NavLink class="brutal-nav-item" href="/login">🔑 Login</NavLink>
                <NavLink class="brutal-nav-item" href="/register">📝 Register</NavLink>
            }
        </nav>

        <div style="margin-top:auto;padding:1.5rem;border-top:var(--border-thin);">
            @if (isAuthenticated && currentUser != null)
            {
                <div style="font-weight:700;font-family:var(--font-heading);">@currentUser.FullName</div>
                <div style="font-size:0.8rem;color:var(--text-muted);">@currentUser.Role</div>
                <div class="flex gap-1 mt-1">
                    <span class="brutal-badge brutal-badge-accent">⭐ @currentUser.LoyaltyPoints pts</span>
                </div>
                <form action="/logout" method="post" class="mt-2">
                    <AntiforgeryToken />
                    <button type="submit" class="brutal-btn brutal-btn-outline brutal-btn-sm w-full">🚪 Logout</button>
                </form>
            }
            else
            {
                <a href="/login" class="brutal-btn w-full">🔑 Login</a>
            }
            <button class="brutal-btn brutal-btn-sm w-full mt-1" onclick="toggleTheme()">🌓 Toggle Theme</button>
        </div>
    </aside>

    <main class="brutal-main">
        <div class="brutal-topbar">
            <h3 style="margin:0;">@GetPageTitle()</h3>
            <div class="flex items-center gap-2">
                @if (isAuthenticated)
                {
                    <a href="/notifications" class="brutal-btn brutal-btn-sm">🔔</a>
                    <a href="/profile" class="brutal-btn brutal-btn-sm">👤</a>
                }
            </div>
        </div>
        @Body
    </main>
</div>

@code {
    private bool mobileOpen;
    private bool isAuthenticated;
    private ApplicationUser? currentUser;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var principal = authState.User;
            isAuthenticated = principal.Identity?.IsAuthenticated ?? false;
            if (isAuthenticated) currentUser = await UserManager.GetUserAsync(principal);
        }
        catch { isAuthenticated = false; }
    }

    private string GetPageTitle()
    {
        var path = Navigation.Uri.Replace(Navigation.BaseUri, "/").ToLower();
        return path switch
        {
            "/" => "DASHBOARD",
            "/members" => "MEMBERS",
            "/memberships" => "MEMBERSHIPS",
            "/attendance" => "ATTENDANCE",
            "/classes" => "CLASSES",
            "/trainers" => "TRAINERS",
            "/payments" => "PAYMENTS",
            "/discounts" => "DISCOUNTS",
            "/forum" => "FORUM",
            "/events" => "EVENTS",
            "/workout" => "WORKOUT",
            "/nutrition" => "NUTRITION",
            "/feedback" => "FEEDBACK",
            "/leaderboard" => "LEADERBOARD",
            "/chatbot" => "COACH TOMMY",
            "/profile" => "MY PROFILE",
            "/reset-password" => "RESET PASSWORD",
            "/register" => "REGISTER",
            "/login" => "LOGIN",
            _ => path.Replace("/", "").ToUpper()
        };
    }
}
