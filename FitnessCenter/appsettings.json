{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Database": {
    "Provider": "SQLite",
    "ConnectionStrings": {
      "SQLite": "Data Source=fitness_center.db",
      "SQLServer": "Server=localhost;Database=FitnessCenter;Trusted_Connection=True;TrustServerCertificate=True;",
      "MySQL": "Server=localhost;Database=FitnessCenter;User=root;Password=yourpassword;",
      "PostgreSQL": "Host=localhost;Database=FitnessCenter;Username=postgres;Password=yourpassword;"
    }
  },

  "Storage": {
    "_comment": "Available providers: FileSystem, AzureBlob, S3, MinIO",
    "Provider": "FileSystem",

    "FileSystem": {
      "_comment": "Local file system storage - no additional setup needed",
      "RootPath": "wwwroot/uploads"
    },

    "AzureBlob": {
      "_comment": "Microsoft Azure Blob Storage",
      "ConnectionString": "DefaultEndpointsProtocol=https;xxx",
      "ContainerName": "fitnesscenter",
      "CdnEndpoint": ""
    },

    "S3": {
      "_comment": "AWS S3 or S3-compatible storage (DigitalOcean Spaces, Cloudflare R2, etc.)",
      "AccessKey": "YOUR_AWS_ACCESS_KEY",
      "SecretKey": "YOUR_AWS_SECRET_KEY",
      "BucketName": "fitnesscenter",
      "Region": "us-east-1",
      "ServiceUrl": "",
      "CdnEndpoint": ""
    },

    "MinIO": {
      "_comment": "Self-hosted MinIO object storage (S3 compatible)",
      "Endpoint": "localhost:9000",
      "AccessKey": "minioadmin",
      "SecretKey": "minioadmin",
      "BucketName": "fitnesscenter",
      "UseSsl": false
    }
  },

  "PaymentGateway": {
    "DefaultProvider": "Midtrans",
    "Midtrans": {
      "ServerKey": "",
      "ClientKey": "",
      "IsProduction": false
    },
    "Stripe": {
      "SecretKey": "",
      "PublishableKey": "",
      "WebhookSecret": ""
    },
    "Xendit": {
      "ApiKey": "",
      "WebhookToken": ""
    }
  },

  "AI": {
    "DefaultProvider": "OpenAI",
    "Providers": {
      "OpenAI": {
        "ApiKey": "sk-proj-xxx",
        "Model": "gpt-4o-mini",
        "Endpoint": "https://api.openai.com/v1"
      },
      "Anthropic": {
        "ApiKey": "",
        "Model": "claude-3-5-sonnet-20241022"
      },
      "Gemini": {
        "ApiKey": "",
        "Model": "gemini-2.0-flash"
      },
      "Ollama": {
        "Endpoint": "http://localhost:11434",
        "Model": "llama3.2"
      }
    }
  },

  "ChatBot": {
    "Name": "Coach Tommy",
    "SystemPrompt": "Kamu adalah Coach Tommy, asisten virtual kebugaran profesional dari FitnessCenter. Kamu ramah, bersemangat, dan ahli dalam bidang fitness, nutrisi, dan gaya hidup sehat. Bantu member dengan pertanyaan seputar latihan, nutrisi, jadwal kelas, membership, dan tips kesehatan. Gunakan bahasa Indonesia yang santai dan memotivasi. Berikan rekomendasi yang personal dan aman. Jika ada pertanyaan medis serius, selalu sarankan untuk konsultasi dengan dokter.",
    "Temperature": 0.7,
    "MaxTokens": 2048,
    "WelcomeMessage": "Halo! Saya Coach Tommy, asisten virtual kamu di FitnessCenter. Ada yang bisa saya bantu hari ini? 💪",
    "Functions": {
      "EnableWebSearch": true,
      "EnableWebScraping": true,
      "EnableDateTime": true,
      "EnableMathCalculation": true,
      "EnableDatabaseQuery": true
    }
  },

  "Gamification": {
    "PointsPerCheckIn": 10,
    "PointsPerClass": 25,
    "PointsPerWorkoutLog": 15,
    "PointsPerForumPost": 20,
    "PointsPerFeedback": 15,
    "StreakBonusMultiplier": 2.0,
    "Badges": {
      "FirstCheckIn": { "Name": "First Steps", "Points": 50, "Description": "Check-in pertama di FitnessCenter!" },
      "TenCheckIns": { "Name": "Dedicated", "Points": 100, "Description": "10 kali check-in berturut-turut" },
      "FiftyClasses": { "Name": "Class Master", "Points": 200, "Description": "Mengikuti 50 kelas" },
      "HundredWorkouts": { "Name": "Iron Body", "Points": 500, "Description": "100 workout log dicatat" },
      "SocialButterfly": { "Name": "Social Butterfly", "Points": 150, "Description": "50 post di forum komunitas" }
    }
  },

  "VirtualClasses": {
    "Zoom": {
      "SdkKey": "",
      "SdkSecret": ""
    },
    "MicrosoftTeams": {
      "ClientId": "",
      "ClientSecret": "",
      "TenantId": ""
    }
  },

  "EmergencyAlert": {
    "EmailRecipients": "staff@fitnesscenter.com",
    "SmsGatewayUrl": "",
    "SmsApiKey": ""
  },

  "Tavily": {
    "ApiKey": "tvly-dev-xxx"
  }
}
