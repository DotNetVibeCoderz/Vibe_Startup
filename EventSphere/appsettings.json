{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=EventSphere.db"
  },
  "Database": {
    "Provider": "SQLite",
    "Comment": "Options: SQLite, SqlServer, MySQL, PostgreSQL"
  },
  "Storage": {
    "Provider": "FileSystem",
    "Comment": "Options: FileSystem, AzureBlob, S3, MinIO",
    "FileSystem": {
      "BasePath": "wwwroot/uploads"
    },
    "AzureBlob": {
      "ConnectionString": "DefaultEndpointsProtocol=https;xxx",
      "ContainerName": "eventsphere"
    },
    "S3": {
      "AccessKey": "",
      "SecretKey": "",
      "Region": "us-east-1",
      "BucketName": "eventsphere",
      "ServiceUrl": ""
    },
    "MinIO": {
      "Endpoint": "localhost:9000",
      "AccessKey": "",
      "SecretKey": "",
      "BucketName": "eventsphere"
    }
  },
  "ApiKey": {
    "HeaderName": "X-Api-Key",
    "Keys": [
      "eventsphere-api-key-2025-secure",
      "eventsphere-admin-key-2025"
    ],
    "Comment": "API keys untuk mengakses REST API. Tambahkan header X-Api-Key di request."
  },
  "AI": {
    "DefaultProvider": "OpenAI",
    "Comment": "Options: OpenAI, Anthropic, Gemini, Ollama",
    "ChatBot": {
      "Name": "Tante Sherly",
      "SystemPrompt": "Kamu adalah Tante Sherly, asisten virtual yang ramah dan berpengalaman di EventSphere. Kamu membantu pengguna dalam merencanakan event, mencari vendor, mengatur anggaran, dan memberikan saran terbaik untuk acara mereka. Kamu berbicara dengan gaya yang hangat, bersahabat, dan sedikit humoris seperti seorang tante yang bijak. Gunakan bahasa Indonesia yang santai tapi sopan. Kamu bisa membantu mencari vendor, menghitung budget, memberi ide tema, dan menjawab pertanyaan seputar event planning.",
      "Temperature": 0.7,
      "MaxTokens": 2000,
      "TopP": 0.9
    },
    "Providers": {
      "OpenAI": {
        "ApiKey": "sk-proj-open-ai-key",
        "Model": "gpt-4o-mini",
        "Endpoint": "https://api.openai.com/v1"
      },
      "Anthropic": {
        "ApiKey": "",
        "Model": "claude-3-5-sonnet-20241022",
        "Endpoint": "https://api.anthropic.com"
      },
      "Gemini": {
        "ApiKey": "",
        "Model": "gemini-2.0-flash",
        "Endpoint": ""
      },
      "Ollama": {
        "Model": "llama3",
        "Endpoint": "http://localhost:11434"
      }
    },
    "Tavily": {
      "ApiKey": "tvly-tavily-key",
      "Endpoint": "https://api.tavily.com/search"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
