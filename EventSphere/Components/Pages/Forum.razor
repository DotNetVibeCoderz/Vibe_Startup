@page "/forum"
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using EventSphere.Data.Models
@using EventSphere.Services
@inject MediaService MediaService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<PageTitle>Forum - EventSphere</PageTitle>

@if (selectedPost == null)
{
    @* ═══ FORUM LIST ═══ *@
    <div class="page-header">
        <div><h1>💡 Community Forum</h1><p class="text-muted">Berbagi tips, review, dan pengalaman event</p></div>
        <div class="flex gap-2">
            <select @bind="categoryFilter" class="neo-select">
                <option value="">All Categories</option><option value="Tips">Tips</option><option value="Review">Review</option><option value="Discussion">Discussion</option><option value="Question">Question</option>
            </select>
            <button class="neo-btn neo-btn-primary" @onclick="ShowNewPost">➕ New Post</button>
        </div>
    </div>

    @if (posts != null && posts.Any())
    {
        foreach (var post in filteredPosts)
        {
            <div class="neo-card mb-2" style="cursor:pointer;" @onclick="() => OpenPost(post.Id)">
                <div class="flex justify-between items-start"><div style="flex:1;">
                    <div class="flex items-center gap-2 mb-1">
                        <h3>@post.Title</h3>
                        @if (!string.IsNullOrEmpty(post.Category)) { <span class="neo-badge badge-info">@post.Category</span> }
                        @if (post.IsPinned) { <span class="neo-badge badge-warning">📌 Pinned</span> }
                    </div>
                    <p class="text-muted" style="font-size:0.9rem;">@post.Content?.Truncate(200)</p>
                    <div class="flex items-center gap-3 mt-2">
                        <small class="text-muted">👤 <strong>@post.Author?.FullName</strong></small>
                        <small class="text-muted">🕐 @post.CreatedAt.ToString("dd MMM yyyy")</small>
                        <small>👁️ @post.ViewCount</small><small>❤️ @post.LikeCount</small><small>💬 @(post.Comments?.Count ?? 0)</small>
                    </div>
                </div></div>
            </div>
        }
    }
    else { <div class="neo-card text-center" style="padding:3rem;"><h2>🚀 No posts yet!</h2><p class="text-muted">Jadilah yang pertama berbagi.</p></div> }

    @if (showNewPost)
    {
        <div class="modal-overlay" @onclick="() => showNewPost = false"><div class="modal-content" @onclick:stopPropagation="true" style="max-width:550px;">
            <h2>➕ New Post</h2>
            <EditForm Model="newPost" OnValidSubmit="CreatePost">
                <div class="flex flex-col gap-2 mt-2">
                    <InputText @bind-Value="newPost.Title" class="neo-input" placeholder="Title..." />
                    <InputTextArea @bind-Value="newPost.Content" class="neo-input" rows="6" placeholder="Share your experience..." />
                    <select @bind="newPost.Category" class="neo-select"><option value="Tips">💡 Tips</option><option value="Review">⭐ Review</option><option value="Discussion">💬 Discussion</option><option value="Question">❓ Question</option></select>
                    <div class="flex gap-2 mt-2"><button type="submit" class="neo-btn neo-btn-primary">📝 Publish</button><button type="button" class="neo-btn" @onclick="() => showNewPost = false">Cancel</button></div>
                </div>
            </EditForm>
        </div></div>
    }
}
else
{
    @* ═══ POST DETAIL ═══ *@
    <div class="page-header">
        <div>
            <button class="neo-btn" @onclick="ClosePost">← Back to Forum</button>
            <h1>@selectedPost.Title</h1>
            <div class="flex items-center gap-3 mt-1">
                <small class="text-muted">👤 <strong>@selectedPost.Author?.FullName</strong></small>
                <small class="text-muted">🕐 @selectedPost.CreatedAt.ToString("dd MMM yyyy")</small>
                <span class="neo-badge badge-info">@selectedPost.Category</span>
                <small>👁️ @selectedPost.ViewCount</small><small>❤️ @selectedPost.LikeCount likes</small>
            </div>
        </div>
        @if (selectedPost.AuthorId == currentUserId)
        {
            <div class="flex gap-2"><button class="neo-btn" @onclick="() => EditPost(selectedPost)">✏️ Edit</button><button class="neo-btn neo-btn-error" @onclick="() => ConfirmDeletePost(selectedPost)">🗑️ Delete</button></div>
        }
    </div>

    @* Content *@
    <div class="neo-card mb-3">
        <div style="white-space:pre-wrap; line-height:1.7;">@selectedPost.Content</div>
        <div class="flex items-center gap-2 mt-3 pt-3" style="border-top:1px solid rgba(0,0,0,0.05);">
            <button class="neo-btn neo-btn-sm @(hasLiked ? "neo-btn-success" : "")" @onclick="ToggleLike" disabled="@hasLiked" title="@(hasLiked ? "Already liked" : "Like")">
                @(hasLiked ? "❤️ Liked" : "🤍 Like") (@selectedPost.LikeCount)
            </button>
            @if (hasLiked) { <small class="text-success">✅ You liked this</small> }
        </div>
    </div>

    @* EDIT MODAL *@
    @if (showEditPost)
    {
        <div class="modal-overlay" @onclick="() => showEditPost = false"><div class="modal-content" @onclick:stopPropagation="true" style="max-width:550px;">
            <h2>✏️ Edit Post</h2>
            <EditForm Model="editModel" OnValidSubmit="SaveEditPost">
                <div class="flex flex-col gap-2 mt-2">
                    <InputText @bind-Value="editModel.Title" class="neo-input" />
                    <InputTextArea @bind-Value="editModel.Content" class="neo-input" rows="6" />
                    <select @bind="editModel.Category" class="neo-select"><option value="Tips">Tips</option><option value="Review">Review</option><option value="Discussion">Discussion</option><option value="Question">Question</option></select>
                    <div class="flex gap-2 mt-2"><button type="submit" class="neo-btn neo-btn-primary">💾 Save</button><button type="button" class="neo-btn" @onclick="() => showEditPost = false">Cancel</button></div>
                </div>
            </EditForm>
        </div></div>
    }

    @* DELETE CONFIRM *@
    @if (showDeleteConfirm)
    {
        <div class="modal-overlay" @onclick="() => showDeleteConfirm = false"><div class="modal-content" @onclick:stopPropagation="true" style="max-width:400px;text-align:center;">
            <div style="font-size:3rem;">⚠️</div><h2>Delete Post?</h2><p class="text-muted mt-2">Post dan semua komentar akan dihapus permanen.</p>
            <div class="flex gap-2 mt-3 justify-center"><button class="neo-btn neo-btn-error neo-btn-lg" @onclick="DeletePost">🗑️ Delete</button><button class="neo-btn neo-btn-lg" @onclick="() => showDeleteConfirm = false">Cancel</button></div>
        </div></div>
    }

    @* ═══ RATING ═══ *@
    <div class="neo-card mb-3">
        <h3>⭐ Beri Rating</h3>
        <p class="text-muted mb-2">Bagaimana menurut Anda tentang post ini?</p>
        <div class="flex items-center gap-1">
            <button class="star-btn @(currentRating >= 1 ? "active" : "")" @onclick="() => SetRatingExact(1)">⭐</button>
            <button class="star-btn @(currentRating >= 2 ? "active" : "")" @onclick="() => SetRatingExact(2)">⭐</button>
            <button class="star-btn @(currentRating >= 3 ? "active" : "")" @onclick="() => SetRatingExact(3)">⭐</button>
            <button class="star-btn @(currentRating >= 4 ? "active" : "")" @onclick="() => SetRatingExact(4)">⭐</button>
            <button class="star-btn @(currentRating >= 5 ? "active" : "")" @onclick="() => SetRatingExact(5)">⭐</button>
            <span class="text-muted ml-3">@(currentRating > 0 ? $"Anda memberi **{currentRating}/5** ⭐" : "Klik bintang untuk rating")</span>
            @if (currentRating > 0) { <button class="neo-btn neo-btn-sm text-muted" @onclick="() => { currentRating = 0; }" style="font-size:0.7rem;">reset</button> }
        </div>
    </div>

    @* ═══ COMMENTS ═══ *@
    <div class="neo-card mb-3">
        <h3>💬 Komentar (@comments.Count)</h3>
        @if (comments.Any())
        {
            <div class="flex flex-col gap-2 mt-2">
                @foreach (var c in comments)
                {
                    <div class="neo-card-inset" style="padding:1rem;">
                        <div class="flex justify-between items-start">
                            <div class="flex items-center gap-2">
                                <div style="width:28px;height:28px;border-radius:50%;background:var(--primary-light);display:flex;align-items:center;justify-content:center;font-size:0.7rem;color:var(--primary-dark);">@FirstChar(c.Author?.FullName)</div>
                                <div><strong style="font-size:0.9rem;">@c.Author?.FullName</strong><br><small class="text-muted">@c.CreatedAt.ToString("dd MMM yyyy HH:mm")</small></div>
                            </div>
                            @if (c.AuthorId == currentUserId) { <button class="neo-btn neo-btn-sm neo-btn-error" @onclick="() => DeleteComment(c.Id)">🗑️</button> }
                        </div>
                        <p class="mt-2" style="white-space:pre-wrap;">@c.Content</p>
                    </div>
                }
            </div>
        }
        else { <p class="text-muted mt-2">Belum ada komentar.</p> }

        <div class="mt-3 pt-3" style="border-top:1px solid rgba(0,0,0,0.05);">
            <textarea @bind="newComment" @bind:event="oninput" class="neo-input" rows="3" placeholder="Tulis komentar..."></textarea>
            <div class="flex gap-2 mt-2"><button class="neo-btn neo-btn-primary" @onclick="AddComment" disabled="@(string.IsNullOrWhiteSpace(newComment))">💬 Kirim</button></div>
        </div>
    </div>
}

<style>
    .star-btn { background: none; border: none; font-size: 1.8rem; cursor: pointer; padding: 0.1rem 0.2rem; transition: all 0.15s; opacity: 0.3; filter: grayscale(100%); }
    .star-btn.active { opacity: 1; filter: grayscale(0%); transform: scale(1.1); }
    .star-btn:hover { opacity: 0.8; transform: scale(1.2); }
    .star-btn.active:hover { opacity: 1; }
</style>

@code {
    private List<ForumPost> posts = new();
    private ForumPost? selectedPost;
    private List<ForumComment> comments = new();
    private string categoryFilter = "", currentUserId = "";

    private bool showNewPost, showEditPost, showDeleteConfirm;
    private ForumPost newPost = new(), editModel = new();
    private ForumPost? deletingPost;

    private string newComment = "";
    private int currentRating;
    private bool hasLiked;
    private static readonly HashSet<string> UserLikedPosts = new();

    private List<ForumPost> filteredPosts => posts
        .Where(p => string.IsNullOrEmpty(categoryFilter) || p.Category == categoryFilter)
        .OrderByDescending(p => p.IsPinned).ThenByDescending(p => p.CreatedAt).ToList();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        currentUserId = user?.Id ?? "";
        posts = await MediaService.GetForumPostsAsync();
    }

    private void ShowNewPost() => showNewPost = true;
    private async Task CreatePost() { newPost.AuthorId = currentUserId; await MediaService.CreatePostAsync(newPost); showNewPost = false; newPost = new(); posts = await MediaService.GetForumPostsAsync(); }

    private void EditPost(ForumPost post) { editModel = new ForumPost { Id = post.Id, Title = post.Title, Content = post.Content, Category = post.Category }; showEditPost = true; }
    private async Task SaveEditPost() { if (selectedPost != null) { selectedPost.Title = editModel.Title; selectedPost.Content = editModel.Content; selectedPost.Category = editModel.Category; } showEditPost = false; }

    private void ConfirmDeletePost(ForumPost post) { deletingPost = post; showDeleteConfirm = true; }
    private async Task DeletePost() { if (deletingPost != null) { posts.Remove(deletingPost); selectedPost = null; showDeleteConfirm = false; posts = await MediaService.GetForumPostsAsync(); } }

    private async Task OpenPost(Guid postId)
    {
        selectedPost = posts.FirstOrDefault(p => p.Id == postId);
        if (selectedPost != null)
        {
            selectedPost.ViewCount++;
            comments = selectedPost.Comments?.ToList() ?? new();
            hasLiked = UserLikedPosts.Contains($"{currentUserId}_{postId}");
            currentRating = 0;
        }
    }

    private void ClosePost() { selectedPost = null; comments = new(); currentRating = 0; hasLiked = false; newComment = ""; }

    private async Task ToggleLike()
    {
        if (selectedPost == null || hasLiked) return;
        var key = $"{currentUserId}_{selectedPost.Id}";
        if (UserLikedPosts.Contains(key)) return;
        selectedPost.LikeCount++; hasLiked = true; UserLikedPosts.Add(key);
    }

    private void SetRatingExact(int rating) { currentRating = rating; }

    private async Task AddComment()
    {
        if (string.IsNullOrWhiteSpace(newComment) || selectedPost == null || string.IsNullOrEmpty(currentUserId)) return;
        var c = new ForumComment { PostId = selectedPost.Id, AuthorId = currentUserId, Content = newComment, CreatedAt = DateTime.UtcNow };
        await MediaService.AddCommentAsync(c);
        comments.Add(c); newComment = "";
        posts = await MediaService.GetForumPostsAsync();
        selectedPost = posts.FirstOrDefault(p => p.Id == selectedPost.Id);
    }

    private async Task DeleteComment(Guid id)
    {
        comments.RemoveAll(c => c.Id == id);
        posts = await MediaService.GetForumPostsAsync();
        if (selectedPost != null) selectedPost = posts.FirstOrDefault(p => p.Id == selectedPost.Id);
    }

    private static string FirstChar(string? s) => !string.IsNullOrEmpty(s) ? s[0].ToString().ToUpper() : "?";
}
