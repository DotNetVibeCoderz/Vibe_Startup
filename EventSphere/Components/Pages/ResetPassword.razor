@page "/reset-password"
@layout MinimalLayout
@using Microsoft.AspNetCore.Identity
@using EventSphere.Data.Models
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>Reset Password - EventSphere</PageTitle>

<div style="display:flex; align-items:center; justify-content:center; min-height:100vh; background:var(--bg);">
    <div class="neo-card" style="width:100%; max-width:440px; padding:2.5rem;">

        @if (resetSuccessful)
        {
            <!-- ═══ SUCCESS MESSAGE ═══ -->
            <div class="text-center">
                <div style="font-size:4rem;">✅</div>
                <h2>Password Berhasil Diubah!</h2>
                <p class="text-muted mt-2">Password Anda telah berhasil diperbarui.</p>
                <a href="/" class="neo-btn neo-btn-primary mt-3">🏠 Kembali ke Dashboard</a>
            </div>
        }
        else if (!string.IsNullOrEmpty(token) && !string.IsNullOrEmpty(email))
        {
            <!-- ═══ SET NEW PASSWORD (with token) ═══ -->
            <div class="text-center mb-3">
                <h1 style="font-size:3rem;">🔐</h1>
                <h2>Buat Password Baru</h2>
                <p class="text-muted">Masukkan password baru untuk <strong>@email</strong></p>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="neo-card-inset mb-2" style="background:#FADBD8; color:#C0392B; padding:0.75rem;">
                    ⚠️ @errorMessage
                </div>
            }

            <EditForm Model="resetModel" OnValidSubmit="HandleResetPassword" FormName="resetForm">
                <DataAnnotationsValidator />
                <div class="flex flex-col gap-2">
                    <div>
                        <label class="text-light" style="font-size:0.85rem;">Password Baru</label>
                        <InputText @bind-Value="resetModel.NewPassword" type="password" class="neo-input"
                                   placeholder="Minimal 8 karakter" />
                        <small class="text-muted">Min. 8 karakter, huruf besar, huruf kecil, angka, simbol</small>
                    </div>
                    <div>
                        <label class="text-light" style="font-size:0.85rem;">Konfirmasi Password</label>
                        <InputText @bind-Value="resetModel.ConfirmPassword" type="password" class="neo-input"
                                   placeholder="Ulangi password" />
                    </div>
                    <button type="submit" class="neo-btn neo-btn-primary neo-btn-lg w-full mt-2">
                        🔒 Simpan Password Baru
                    </button>
                </div>
            </EditForm>
        }
        else if (isSendingEmail)
        {
            <!-- ═══ FORGOT PASSWORD FORM ═══ -->
            <div class="text-center mb-3">
                <h1 style="font-size:3rem;">🔑</h1>
                <h2>Lupa Password?</h2>
                <p class="text-muted">Masukkan email Anda, kami akan kirim link reset password.</p>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="neo-card-inset mb-2" style="background:#FADBD8; color:#C0392B; padding:0.75rem;">
                    ⚠️ @errorMessage
                </div>
            }
            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="neo-card-inset mb-2" style="background:#D5F5E3; color:#1E8449; padding:0.75rem;">
                    ✅ @successMessage
                </div>
            }

            <EditForm Model="forgotModel" OnValidSubmit="HandleForgotPassword" FormName="forgotForm">
                <div class="flex flex-col gap-2">
                    <div>
                        <label class="text-light" style="font-size:0.85rem;">Email</label>
                        <InputText @bind-Value="forgotModel.Email" class="neo-input" placeholder="you@email.com" />
                    </div>
                    <button type="submit" class="neo-btn neo-btn-primary neo-btn-lg w-full mt-2">
                        📧 Kirim Link Reset
                    </button>
                </div>
            </EditForm>

            <div class="text-center mt-3">
                <a href="/login" class="text-primary">← Kembali ke Login</a>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] [SupplyParameterFromQuery] public string? token { get; set; }
    [Parameter] [SupplyParameterFromQuery] public string? email { get; set; }

    private ForgotPasswordModel forgotModel = new();
    private ResetPasswordModel resetModel = new();
    private string? errorMessage;
    private string? successMessage;
    private bool isSendingEmail = true;
    private bool resetSuccessful;

    protected override void OnInitialized()
    {
        // Jika ada token dan email di query string, tampilkan form reset
        if (!string.IsNullOrEmpty(token) && !string.IsNullOrEmpty(email))
        {
            isSendingEmail = false;
            resetModel.Email = email;
            resetModel.Token = token;
        }
    }

    private async Task HandleForgotPassword()
    {
        errorMessage = null;
        successMessage = null;

        var user = await UserManager.FindByEmailAsync(forgotModel.Email);
        if (user == null || !await UserManager.IsEmailConfirmedAsync(user))
        {
            // Jangan reveal apakah user exists (security best practice)
            successMessage = "Jika email terdaftar, link reset password telah dikirim.";
            return;
        }

        var resetToken = await UserManager.GeneratePasswordResetTokenAsync(user);
        var resetLink = $"{Navigation.BaseUri}reset-password?email={user.Email}&token={Uri.EscapeDataString(resetToken)}";

        // Dalam production, kirim email via SMTP. Untuk demo, tampilkan link di console.
        Console.WriteLine($"🔑 Password Reset Link: {resetLink}");

        successMessage = "✅ Link reset password telah dikirim ke email Anda. (Cek console untuk demo)";
    }

    private async Task HandleResetPassword()
    {
        errorMessage = null;

        if (resetModel.NewPassword != resetModel.ConfirmPassword)
        {
            errorMessage = "Password dan konfirmasi tidak cocok.";
            return;
        }

        var user = await UserManager.FindByEmailAsync(resetModel.Email);
        if (user == null)
        {
            errorMessage = "User tidak ditemukan.";
            return;
        }

        var result = await UserManager.ResetPasswordAsync(user, resetModel.Token, resetModel.NewPassword);
        if (result.Succeeded)
        {
            resetSuccessful = true;
        }
        else
        {
            errorMessage = string.Join(", ", result.Errors.Select(e => e.Description));
        }
    }

    private class ForgotPasswordModel
    {
        public string Email { get; set; } = "";
    }

    private class ResetPasswordModel
    {
        public string Email { get; set; } = "";
        public string Token { get; set; } = "";
        public string NewPassword { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}
