@page "/chatbot"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using EventSphere.Data.Models
@using EventSphere.Services
@attribute [Authorize]
@inject AiChatService AiChatService
@inject UserManager<ApplicationUser> UserManager
@inject StorageService StorageService
@inject IConfiguration Config
@inject AuthenticationStateProvider AuthProvider
@inject IJSRuntime JS

<PageTitle>🤖 Tante Sherly - AI Assistant</PageTitle>

<div class="page-header">
    <div>
        <h1>🤖 Tante Sherly</h1>
        <p class="text-muted">Konsultasi event planning dengan AI assistant Anda yang ramah</p>
    </div>
    <div class="flex gap-2">
        <select @bind="selectedProvider" class="neo-select">
            <option value="OpenAI">🧠 OpenAI</option>
            <option value="Anthropic">🔮 Anthropic</option>
            <option value="Gemini">🌟 Gemini</option>
            <option value="Ollama">🦙 Ollama</option>
        </select>
        <button class="neo-btn" @onclick="ResetCurrentSession">🔄 Reset</button>
        <button class="neo-btn neo-btn-primary" @onclick="CreateNewSession">➕ New Chat</button>
    </div>
</div>

<div style="display:flex; gap:1.25rem; height:calc(100vh - 200px);">
    <!-- Sidebar Sessions -->
    <div class="neo-card" style="width:280px; overflow-y:auto; flex-shrink:0;">
        <h3>💬 Sessions</h3>
        <div class="flex flex-col gap-1 mt-1">
            @foreach (var s in sessions)
            {
                <div class="neo-card-inset"
                     style="padding:0.5rem 0.75rem; cursor:pointer; @(s.Id == currentSessionId ? "border-left:4px solid var(--primary);" : "")"
                     @onclick="() => LoadSession(s.Id)">
                    <small style="font-weight:600;">@s.Title?.Truncate(25)</small>
                    <br><small class="text-muted">@s.LastActivity?.ToString("dd MMM HH:mm")</small>
                    <button class="neo-btn neo-btn-sm neo-btn-error" style="float:right; padding:0.15rem 0.4rem; font-size:0.7rem;"
                            @onclick="() => DeleteSession(s.Id)" @onclick:stopPropagation="true">✕</button>
                </div>
            }
        </div>
    </div>

    <!-- Chat Area -->
    <div class="chat-container" style="flex:1;">
        <div class="chat-messages" id="chat-scroll">
            @if (!messages.Any())
            {
                <div class="text-center" style="margin:auto;">
                    <div style="font-size:4rem;">🤖</div>
                    <h2>Halo! Saya Tante Sherly</h2>
                    <p class="text-muted">
                        Tanya apa saja tentang:<br>
                        📅 Perencanaan event • 🏢 Rekomendasi vendor • 💰 Budget<br>
                        🎨 Ide tema & dekorasi • 📋 Checklist & timeline
                    </p>
                </div>
            }

            @foreach (var msg in messages)
            {
                <div class="chat-bubble @(msg.Role == "User" ? "user" : "assistant")">
                    <small style="opacity:0.7;">@(msg.Role == "Assistant" ? "🤖 Tante Sherly" : "👤 You")</small>

                    @if (!string.IsNullOrEmpty(msg.ImageUrl))
                    {
                        <div class="mt-1">
                            <img src="@msg.ImageUrl" style="max-width:200px; border-radius:8px;" alt="Attached" />
                        </div>
                    }

                    <div class="message-content">@((MarkupString)RenderMarkdown(msg.Content ?? ""))</div>

                    @if (!string.IsNullOrEmpty(msg.AttachmentUrl))
                    {
                        <div class="mt-1">
                            <a href="@msg.AttachmentUrl" target="_blank" class="neo-btn neo-btn-sm">📎 @msg.AttachmentName</a>
                        </div>
                    }

                    <small style="opacity:0.5; font-size:0.7rem;">@msg.CreatedAt.ToLocalTime().ToString("HH:mm")</small>
                </div>
            }

            @if (isLoading)
            {
                <div class="chat-bubble assistant">
                    <small style="opacity:0.7;">🤖 Tante Sherly</small>
                    <div class="message-content"><em>Mengetik...</em></div>
                </div>
            }
        </div>

        <!-- Input Area -->
        <div class="chat-input-area">
            @if (selectedFile != null)
            {
                <div class="neo-badge badge-info" style="display:flex; align-items:center; gap:0.5rem;">
                    📎 @selectedFile.Name
                    <button style="background:none; border:none; cursor:pointer;" @onclick="ClearSelectedFile">✕</button>
                </div>
            }

            <textarea @bind="userInput" @bind:event="oninput" class="chat-input"
                      placeholder="Tanya Tante Sherly..."
                      @onkeydown="HandleKeyDown" rows="1"></textarea>

            <label class="neo-btn" style="cursor:pointer;">
                📎 <InputFile OnChange="HandleFileSelected" accept="image/*,.pdf,.doc,.docx,.xlsx" hidden />
            </label>

            <button class="neo-btn neo-btn-primary" @onclick="SendMessage"
                    disabled="@(string.IsNullOrWhiteSpace(userInput) || isLoading)">➤</button>
        </div>
    </div>
</div>

@code {
    private List<ChatBotSession> sessions = new();
    private List<ChatBotMessage> messages = new();
    private Guid currentSessionId;
    private string userInput = "";
    private string selectedProvider = "OpenAI";
    private bool isLoading;
    private string? currentUserId;
    private IBrowserFile? selectedFile;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user != null) currentUserId = user.Id;
        selectedProvider = Config.GetValue<string>("AI:DefaultProvider") ?? "OpenAI";
        await LoadSessions();
    }

    private async Task LoadSessions()
    {
        if (currentUserId == null) return;
        sessions = await AiChatService.GetSessionsForUserAsync(currentUserId);
        if (sessions.Any()) await LoadSession(sessions.First().Id);
        else await CreateNewSession();
    }

    private async Task LoadSession(Guid sessionId)
    {
        currentSessionId = sessionId;
        messages = await AiChatService.GetMessagesForSessionAsync(sessionId);
        await ScrollToBottom();
    }

    private async Task CreateNewSession()
    {
        if (currentUserId == null) return;
        var session = await AiChatService.CreateSessionAsync(currentUserId);
        currentSessionId = session.Id;
        messages = new();
        await LoadSessions();
    }

    private async Task ResetCurrentSession()
    {
        await AiChatService.ResetSessionAsync(currentSessionId);
        messages = new();
    }

    private async Task DeleteSession(Guid sessionId)
    {
        await AiChatService.DeleteSessionAsync(sessionId);
        await LoadSessions();
    }

    // 🔑 UPLOAD: Gunakan StorageService (otomatis ikuti provider di appsettings)
    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userInput) || isLoading) return;
        var message = userInput;
        userInput = "";
        isLoading = true;

        try
        {
            string? imageUrl = null;
            string? attachmentUrl = null;
            string? attachmentName = null;

            // 🔑 Upload file via StorageService — ikuti provider: FileSystem / AzureBlob / S3 / MinIO
            if (selectedFile != null)
            {
                using var stream = selectedFile.OpenReadStream(10 * 1024 * 1024); // Max 10MB
                var uploadedUrl = await StorageService.UploadAsync(
                    stream, selectedFile.Name, selectedFile.ContentType, "chat");

                if (selectedFile.ContentType.StartsWith("image/"))
                {
                    imageUrl = uploadedUrl; // Image → ImageContent untuk AI vision
                }
                else
                {
                    attachmentUrl = uploadedUrl; // Dokumen → link di text message
                    attachmentName = selectedFile.Name;
                }

                selectedFile = null;
            }

            await AiChatService.ChatAsync(currentSessionId, message,
                imageUrl: imageUrl,
                attachmentUrl: attachmentUrl,
                attachmentName: attachmentName,
                provider: selectedProvider);

            messages = await AiChatService.GetMessagesForSessionAsync(currentSessionId);
            await LoadSessions();
        }
        finally
        {
            isLoading = false;
            await ScrollToBottom();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey) await SendMessage();
    }

    private void HandleFileSelected(InputFileChangeEventArgs e) => selectedFile = e.File;
    private void ClearSelectedFile() => selectedFile = null;

    private string RenderMarkdown(string text)
    {
        if (string.IsNullOrEmpty(text)) return "";
        try
        {
            var pipeline = new Markdig.MarkdownPipelineBuilder().Build();
            return Markdig.Markdown.ToHtml(text, pipeline);
        }
        catch
        {
            return System.Net.WebUtility.HtmlEncode(text).Replace("\n", "<br>");
        }
    }

    private async Task ScrollToBottom()
    {
        await Task.Delay(100);
        await JS.InvokeVoidAsync("eval", "const el=document.getElementById('chat-scroll');if(el)el.scrollTop=el.scrollHeight;");
    }
}
