@page "/kontrak"
@attribute [Authorize]
@inject KontrakService KontrakSvc

<div class="card-header"><h2 class="card-title">📄 Manajemen Kontrak</h2><button class="btn btn-primary" @onclick="ShowAddModal">➕ Tambah Kontrak</button></div>
<div class="card"><div class="table-container"><table class="table"><thead><tr><th>No Kontrak</th><th>Penghuni</th><th>Kamar</th><th>Mulai</th><th>Selesai</th><th>Harga</th><th>Status</th></tr></thead>
<tbody>@foreach (var k in _kontrak) { <tr><td class="font-bold">@k.NomorKontrak</td><td>@k.Penghuni?.NamaLengkap</td><td>@k.Kamar?.NomorKamar</td><td>@k.TanggalMulai.ToString("dd MMM yyyy")</td><td>@k.TanggalSelesai.ToString("dd MMM yyyy")</td><td>@k.HargaSewa.ToRupiah()</td><td><span class="badge @(k.Status == StatusKontrak.Aktif ? "badge-success" : "badge-secondary")">@k.Status</span></td></tr> }</tbody></table></div></div>

@if (_showModal)
{ <div class="modal-overlay" @onclick="() => _showModal = false"><div class="modal-content" @onclick:stopPropagation="true"><div class="modal-header"><h3>Tambah Kontrak</h3><button class="btn btn-sm btn-danger" @onclick="() => _showModal = false">✕</button></div>
<form @onsubmit="SaveKontrak"><div class="form-row"><div class="form-group"><label class="form-label">Penghuni</label><input type="number" class="form-control" @bind="_form.PenghuniId" /></div><div class="form-group"><label class="form-label">Kamar</label><input type="number" class="form-control" @bind="_form.KamarId" /></div></div>
<div class="form-row"><div class="form-group"><label class="form-label">Tanggal Mulai</label><input type="date" class="form-control" @bind="_form.TanggalMulai" /></div><div class="form-group"><label class="form-label">Tanggal Selesai</label><input type="date" class="form-control" @bind="_form.TanggalSelesai" /></div></div>
<div class="form-row"><div class="form-group"><label class="form-label">Harga Sewa</label><input type="number" class="form-control" @bind="_form.HargaSewa" /></div><div class="form-group"><label class="form-label">Deposit</label><input type="number" class="form-control" @bind="_form.Deposit" /></div></div>
<button type="submit" class="btn btn-primary w-full">💾 Simpan</button></form></div></div> }

@code { private List<Kontrak> _kontrak = new(); private Kontrak _form = new(); private bool _showModal; protected override async Task OnInitializedAsync() => _kontrak = await KontrakSvc.GetAllAsync(); private void ShowAddModal() { _form = new(); _showModal = true; } private async Task SaveKontrak() { await KontrakSvc.CreateAsync(_form); _showModal = false; _kontrak = await KontrakSvc.GetAllAsync(); } }
