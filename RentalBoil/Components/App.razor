<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>RentalBoil</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="RentalBoil.styles.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <HeadOutlet @rendermode="Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer" />
    <script>
        (function() {
            var theme = document.cookie.split('; ').find(r => r.startsWith('theme='));
            if (theme) {
                var t = theme.split('=')[1];
                document.documentElement.setAttribute('data-bs-theme', t);
                document.body.className = t === 'dark' ? 'dark-theme' : 'light-theme';
            }
            var lang = document.cookie.split('; ').find(r => r.startsWith('lang='));
            if (lang) document.documentElement.setAttribute('lang', lang.split('=')[1]);
        })();
    </script>
</head>
<body class="light-theme">
    <Routes @rendermode="Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer" />

    <script>
        // ═══ MAP FUNCTIONS — globally available ═══

        // ── Single Vehicle Map ──
        var _vMap = null, _vMarker = null;
        window.initVehicleMap = function(lat, lng, name, speed, heading) {
            if (_vMap) _vMap.remove();
            _vMap = L.map('vehicleMap').setView([lat, lng], 15);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {attribution:'&copy; OpenStreetMap'}).addTo(_vMap);
            var icon = L.divIcon({html:'<div style="font-size:32px;transform:translate(-50%,-50%);">🚗</div>',className:'',iconSize:[40,40],iconAnchor:[20,20]});
            _vMarker = L.marker([lat, lng], {icon:icon}).addTo(_vMap);
            _vMarker.bindPopup('<b>'+name+'</b><br>🚀 '+speed+' km/h | 🧭 '+heading+'°');
            L.circle([lat, lng], {radius:30, color:'#6C5CE7', fillOpacity:0.2}).addTo(_vMap);
        };
        window.updateVehiclePos = function(lat, lng) {
            if (_vMarker) { _vMarker.setLatLng([lat, lng]); if (_vMap) _vMap.panTo([lat, lng]); }
        };

        // ── Admin Map (all vehicles) ──
        var _aMap = null, _aMarkers = [];
        window.initAdminMap = function(dataJson) {
            _aMarkers.forEach(function(m){m.remove();}); _aMarkers = [];
            if (_aMap) _aMap.remove();
            var data = JSON.parse(dataJson);
            if (!data.length) return;
            _aMap = L.map('adminMap').setView([data[0].lat, data[0].lng], 13);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {attribution:'&copy; OpenStreetMap'}).addTo(_aMap);
            var bounds = [];
            data.forEach(function(v) {
                bounds.push([v.lat, v.lng]);
                var icon = L.divIcon({html:'<div style="font-size:24px;transform:translate(-50%,-50%);">🚗</div>',className:'',iconSize:[30,30],iconAnchor:[15,15]});
                var m = L.marker([v.lat, v.lng], {icon:icon}).addTo(_aMap);
                // ★ FIX: property names match System.Text.Json camelCase from C# anonymous type
                m.bindPopup('<b>'+v.name+'</b><br>'+v.plateNumber+'<br>🚀 '+v.speed+' km/h | 🔐 '+v.lockStatus+' | ⚡ '+v.engine+'<br>👤 '+v.customer);
                L.circle([v.lat, v.lng], {radius:25, color:v.motion==='Moving'?'#00B894':'#FDCB6E', fillOpacity:0.15}).addTo(_aMap);
                _aMarkers.push(m);
            });
            if (bounds.length) _aMap.fitBounds(bounds, {padding:[40,40]});
        };
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="_framework/blazor.web.js"></script>
</body>
</html>
