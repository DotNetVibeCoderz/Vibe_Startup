@page "/login"
@page "/login/{ReturnUrl}"
@inject NavigationManager Navigation

<div class="flex-center" style="min-height:70vh;">
    <div class="clay-card" style="width:100%;max-width:440px;padding:40px;">
        <div class="text-center mb-24">
            <div style="font-size:3rem;">🚗</div>
            <h2 style="font-weight:800;">Rental<span class="text-accent">Boil</span></h2>
            <p class="text-muted">Masuk ke akun Anda</p>
        </div>

        <form method="post" action="/account/login">
            <AntiforgeryToken />
            <input type="hidden" name="returnUrl" value="@formReturnUrl" />

            <div class="mb-16">
                <label class="form-label">Email</label>
                <input name="email" type="email" class="form-clay" placeholder="email@example.com" required />
            </div>
            <div class="mb-16">
                <label class="form-label">Kata Sandi</label>
                <input name="password" type="password" class="form-clay" placeholder="••••••••" required />
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="badge-clay badge-clay-danger w-100 mb-16">@errorMessage</div>
            }

            <button type="submit" class="btn-clay btn-clay-primary w-100">Masuk</button>
        </form>

        <div class="text-center mt-24">
            <p class="text-muted">Belum punya akun? <a href="/register">Daftar</a></p>
        </div>
        <div class="text-center mt-16">
            <small class="text-muted">
                Demo: admin@rentalboil.com / Admin123!<br>
                partner1@rentalboil.com / Partner123!<br>
                customer1@rentalboil.com / Customer123!
            </small>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery(Name = "returnUrl")] public string? ReturnUrlQuery { get; set; }
    [SupplyParameterFromQuery(Name = "error")] public string? Error { get; set; }

    private string? errorMessage;
    private string formReturnUrl = "/";

    protected override void OnParametersSet()
    {
        // Prioritaskan returnUrl dari query agar konsisten saat redirect.
        formReturnUrl = ReturnUrlQuery ?? ReturnUrl ?? "/";

        errorMessage = Error switch
        {
            "invalid" => "Email atau password salah.",
            "suspended" => "Akun Anda telah di-suspend.",
            _ => null
        };
    }
}
