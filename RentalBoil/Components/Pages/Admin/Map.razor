@page "/admin/map"
@attribute [Authorize(Roles = "Admin")]
@inject IServiceScopeFactory ScopeFactory
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@using System.Text.Json

@if (isReady)
{
    <div class="page-header">
        <div>
            <h1 class="page-title">🗺️ Peta Seluruh Kendaraan Aktif</h1>
            <p class="page-subtitle">@vehicles.Count kendaraan sedang disewa</p>
        </div>
        <div style="display:flex;gap:8px;">
            <button class="btn-clay" @onclick="RefreshAll">🔄 Refresh</button>
            <span class="badge-clay badge-clay-success">🟢 @vehicles.Count(v => v.MotionStatus == "Moving") Bergerak</span>
            <span class="badge-clay badge-clay-warning">🛑 @vehicles.Count(v => v.MotionStatus == "Stopped") Berhenti</span>
        </div>
    </div>

    <div class="clay-card mb-24" style="padding:0;overflow:hidden;min-height:500px;">
        <div id="adminMap" style="width:100%;height:550px;"></div>
    </div>

    <div class="clay-card" style="padding:0;overflow-x:auto;">
        <table class="table-clay" style="margin:0;">
            <thead><tr>
                <th>Kendaraan</th><th>Plat</th><th>Customer</th>
                <th>📍 Lat/Lng</th><th>🚀 Speed</th><th>🔐 Lock</th><th>⚡ Engine</th><th>🏃 Status</th>
                <th>🗺️</th>
            </tr></thead>
            <tbody>
                @foreach (var v in vehicles)
                {
                    <tr>
                        <td><strong>@v.Name</strong></td><td>@v.PlateNumber</td><td>@v.CustomerName</td>
                        <td style="font-family:monospace;font-size:0.8rem;">@v.Lat?.ToString("F4"), @v.Lng?.ToString("F4")</td>
                        <td>@v.Speed km/h</td>
                        <td><span class="badge-clay @(v.LockStatus == "Unlocked" ? "badge-clay-success" : "badge-clay-danger")">@v.LockStatus</span></td>
                        <td><span class="badge-clay @(v.EngineStatus == "On" ? "badge-clay-success" : "badge-clay-danger")">@v.EngineStatus</span></td>
                        <td><span class="badge-clay @(v.MotionStatus == "Moving" ? "badge-clay-info" : "badge-clay-warning")">@v.MotionStatus</span></td>
                        <td><a href="/vehicles/@v.VehicleId/map" class="btn-clay" style="font-size:0.7rem;padding:2px 8px;">🗺️</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private bool isReady;
    private List<VehicleMapItem> vehicles = new();

    private static readonly JsonSerializerOptions _jsonOpts = new() { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };

    protected override async Task OnInitializedAsync() { await LoadData(); isReady = true; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && vehicles.Any(v => v.Lat.HasValue))
        {
            var data = vehicles.Where(v => v.Lat.HasValue).Select(v => new { lat = v.Lat!.Value, lng = v.Lng!.Value, name = v.Name, plateNumber = v.PlateNumber, speed = v.Speed, lockStatus = v.LockStatus, engine = v.EngineStatus, motion = v.MotionStatus, customer = v.CustomerName });
            await JSRuntime.InvokeVoidAsync("initAdminMap", JsonSerializer.Serialize(data, _jsonOpts));
        }
    }

    private async Task LoadData()
    {
        using var scope = ScopeFactory.CreateScope(); var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();
        var ids = await db.Bookings.Where(b => b.Status == BookingStatus.Active).Select(b => b.VehicleId).ToListAsync();
        var vlist = await db.Vehicles.AsNoTracking().Where(v => ids.Contains(v.Id)).ToListAsync();
        var blist = await db.Bookings.Include(b => b.Customer).Where(b => ids.Contains(b.VehicleId) && b.Status == BookingStatus.Active).ToListAsync();
        vehicles = vlist.Select(v => { var b = blist.FirstOrDefault(bk => bk.VehicleId == v.Id); return new VehicleMapItem { VehicleId = v.Id, Name = v.Name, PlateNumber = v.PlateNumber, Lat = v.Latitude, Lng = v.Longitude, Speed = v.CurrentSpeed, LockStatus = v.LockStatus.ToString(), EngineStatus = v.EngineStatus.ToString(), MotionStatus = v.MotionStatus.ToString(), CustomerName = b?.Customer?.FullName ?? "-" }; }).ToList();
    }

    private async Task RefreshAll() { await LoadData(); StateHasChanged(); }

    private class VehicleMapItem { public int VehicleId; public string Name="", PlateNumber="", LockStatus="", EngineStatus="", MotionStatus="", CustomerName=""; public double? Lat, Lng; public double Speed; }
}
