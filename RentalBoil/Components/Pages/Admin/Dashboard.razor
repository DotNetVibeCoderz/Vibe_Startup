@page "/admin/dashboard"
@attribute [Authorize(Roles = "Admin")]
@inject BookingService BookingService
@inject VehicleService VehicleService
@inject AppDbContext Db

@if (stats != null)
{
    <div class="page-header">
        <div>
            <h1 class="page-title">🖥️ Admin Dashboard</h1>
            <p class="page-subtitle">Monitoring & kontrol sistem</p>
        </div>
        <div style="display:flex;gap:8px;">
            <a href="/reports" class="btn-clay">📋 Laporan</a>
            <a href="/gps" class="btn-clay">🛰️ GPS Tracking</a>
            <a href="/admin/map" class="btn-clay">🗺️ Peta Semua</a>
        </div>
    </div>

    <div class="grid-4 mb-24">
        <div class="stat-card"><div class="stat-icon" style="background:rgba(108,92,231,0.15);color:var(--accent);">📦</div><div><div class="stat-value">@totalBookings</div><div class="stat-label">Total Booking</div></div></div>
        <div class="stat-card"><div class="stat-icon" style="background:rgba(0,184,148,0.15);color:var(--success);">💰</div><div><div class="stat-value">Rp @String.Format("{0:N0}", totalRevenue)</div><div class="stat-label">Total Revenue</div></div></div>
        <div class="stat-card"><div class="stat-icon" style="background:rgba(116,185,255,0.15);color:var(--info);">🚗</div><div><div class="stat-value">@activeRentals</div><div class="stat-label">Sewa Aktif</div></div></div>
        <div class="stat-card"><div class="stat-icon" style="background:rgba(253,203,110,0.15);color:var(--warning);">⏳</div><div><div class="stat-value">@pendingBookings</div><div class="stat-label">Pending</div></div></div>
    </div>

    <div class="grid-4 mb-24">
        <div class="stat-card"><div class="stat-icon" style="background:rgba(108,92,231,0.15);color:var(--accent);">👥</div><div><div class="stat-value">@totalUsers</div><div class="stat-label">Pengguna</div></div></div>
        <div class="stat-card"><div class="stat-icon" style="background:rgba(225,112,85,0.15);color:var(--danger);">🚗</div><div><div class="stat-value">@totalVehicles</div><div class="stat-label">Kendaraan</div></div></div>
        <div class="stat-card"><div class="stat-icon" style="background:rgba(0,184,148,0.15);color:var(--success);">📊</div><div><div class="stat-value">@completionRate.ToString("F1")%</div><div class="stat-label">Completion</div></div></div>
        <div class="stat-card"><div class="stat-icon" style="background:rgba(253,203,110,0.15);color:var(--warning);">🏁</div><div><div class="stat-value">@todayBookings</div><div class="stat-label">Booking Hari Ini</div></div></div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
        <div class="clay-card" style="padding:24px;">
            <h3 style="font-weight:700;">📈 Pendapatan 30 Hari</h3>
            @if (monthlyData.Any())
            {
                var maxVal = monthlyData.Max(x => x.Amount); if (maxVal == 0) maxVal = 1;
                <div style="margin-top:16px;max-height:300px;overflow-y:auto;">
                    @foreach (var d in monthlyData)
                    {
                        var pct = (int)(d.Amount / maxVal * 100);
                        <div style="margin-bottom:4px;">
                            <div style="display:flex;justify-content:space-between;font-size:0.7rem;"><span>@d.Date.ToString("dd/MM")</span><span class="text-muted">@(d.Amount > 0 ? String.Format("{0:N0}", d.Amount) : "")</span></div>
                            <div style="height:14px;background:var(--clay-bg);border-radius:7px;overflow:hidden;"><div style="height:100%;width:@pct%;background:linear-gradient(90deg,var(--accent),var(--accent-light));border-radius:7px;min-width:3px;"></div></div>
                        </div>
                    }
                </div>
            }
            <div class="mt-8 text-center"><span class="badge-clay badge-clay-accent">Total: Rp @String.Format("{0:N0}", monthlyData.Sum(x => x.Amount))</span></div>
        </div>
        <div class="clay-card" style="padding:24px;">
            <h3 style="font-weight:700;">🏆 Kendaraan Terpopuler</h3>
            @if (popularVehicles.Any())
            {
                var maxR = popularVehicles.Max(x => x.Count); if (maxR == 0) maxR = 1;
                <div style="margin-top:16px;">
                    @foreach (var pv in popularVehicles)
                    {
                        var pct = (int)((double)pv.Count / maxR * 100);
                        <div style="margin-bottom:8px;">
                            <div style="display:flex;justify-content:space-between;font-size:0.8rem;"><span>@pv.Name</span><span class="text-muted">@pv.Count x | Rp @String.Format("{0:N0}", pv.Revenue)</span></div>
                            <div style="height:20px;background:var(--clay-bg);border-radius:10px;overflow:hidden;"><div style="height:100%;width:@pct%;background:linear-gradient(90deg,#FDCB6E,#F39C12);border-radius:10px;min-width:3px;"></div></div>
                        </div>
                    }
                </div>
            }
            else { <p class="text-muted mt-16">Belum ada data.</p> }
        </div>
    </div>

    <div class="clay-card mt-24" style="padding:24px;">
        <h3 style="font-weight:700;">💳 Revenue per Metode Pembayaran</h3>
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:16px;">
            @foreach (var pm in paymentMethods)
            {
                <div class="clay-card-inset text-center" style="padding:16px;">
                    <div style="font-size:1.5rem;">@GetPaymentIcon(pm.Method)</div>
                    <div style="font-weight:700;">@pm.Method</div>
                    <div style="font-size:0.8rem;color:var(--text-muted);">@pm.Count transaksi</div>
                    <div style="color:var(--accent);font-weight:600;">Rp @String.Format("{0:N0}", pm.Revenue)</div>
                </div>
            }
        </div>
    </div>

    <div class="clay-card mt-24" style="padding:24px;">
        <div class="flex-between mb-16">
            <h3 style="font-weight:700;">🚨 Verifikasi Pending</h3>
            <span class="badge-clay badge-clay-warning">@pendingVehicles.Count pending</span>
        </div>
        @if (pendingVehicles.Any())
        {
            <div style="overflow-x:auto;"><table class="table-clay">
                <thead><tr><th>Kendaraan</th><th>Owner</th><th>Tgl Daftar</th><th>Aksi</th></tr></thead>
                <tbody>
                    @foreach (var v in pendingVehicles)
                    {
                        <tr><td><strong>@v.Name</strong><br/><small>@v.Brand @v.Model</small></td><td>@v.Owner?.FullName</td><td>@v.CreatedAt.ToString("dd MMM yy")</td>
                        <td><button class="btn-clay btn-clay-success" style="padding:4px 10px;font-size:0.75rem;" @onclick="() => VerifyVehicle(v.Id, true)">✅ Verifikasi</button></td></tr>
                    }
                </tbody>
            </table></div>
        }
        else { <p class="text-muted">Tidak ada yang pending.</p> }
    </div>
}

@code {
    private object? stats;
    private List<Vehicle> pendingVehicles = new();
    private decimal totalRevenue;
    private int totalBookings, pendingBookings, activeRentals, todayBookings, totalUsers, totalVehicles;
    private double completionRate;
    private List<(DateTime Date, decimal Amount)> monthlyData = new();
    private List<(string Name, int Count, decimal Revenue)> popularVehicles = new();
    private List<(string Method, int Count, decimal Revenue)> paymentMethods = new();

    protected override async Task OnInitializedAsync()
    {
        stats = await BookingService.GetAdminStatsAsync();
        pendingVehicles = await VehicleService.GetPendingVerificationAsync();
        totalBookings = (int)(stats.GetType().GetProperty("TotalBookings")?.GetValue(stats) ?? 0);
        totalRevenue = (decimal)(stats.GetType().GetProperty("TotalRevenue")?.GetValue(stats) ?? 0m);
        activeRentals = (int)(stats.GetType().GetProperty("ActiveRentals")?.GetValue(stats) ?? 0);
        pendingBookings = (int)(stats.GetType().GetProperty("PendingBookings")?.GetValue(stats) ?? 0);
        todayBookings = (int)(stats.GetType().GetProperty("TodayBookings")?.GetValue(stats) ?? 0);
        totalUsers = await Db.Users.CountAsync();
        totalVehicles = await Db.Vehicles.CountAsync();
        completionRate = totalBookings > 0 ? Math.Round((double)await Db.Bookings.CountAsync(b => b.Status == BookingStatus.Completed) / totalBookings * 100, 1) : 0;

        var now = DateTime.UtcNow.Date;
        monthlyData = Enumerable.Range(0, 30).Select(i => { var d = now.AddDays(-i); return (d, Db.Bookings.Where(b => b.PaidAt.HasValue && b.PaidAt.Value.Date == d).Sum(b => b.TotalPrice)); }).Reverse().ToList();

        var popRaw = await Db.Bookings.Where(b => b.PaymentStatus == PaymentStatus.Paid).GroupBy(b => new { b.VehicleId, b.Vehicle!.Name }).Select(g => new { g.Key.Name, Count = g.Count(), Revenue = g.Sum(b => b.TotalPrice) }).OrderByDescending(x => x.Count).Take(8).ToListAsync();
        popularVehicles = popRaw.Select(x => (x.Name, x.Count, x.Revenue)).ToList();

        var pmRaw = await Db.Bookings.Where(b => b.PaymentStatus == PaymentStatus.Paid && b.PaymentMethod.HasValue).GroupBy(b => b.PaymentMethod!.Value).Select(g => new { Method = g.Key.ToString(), Count = g.Count(), Revenue = g.Sum(b => b.TotalPrice) }).ToListAsync();
        paymentMethods = pmRaw.Select(x => (x.Method, x.Count, x.Revenue)).ToList();
    }

    private async Task VerifyVehicle(int id, bool verified) { await VehicleService.VerifyVehicleAsync(id, verified); pendingVehicles = await VehicleService.GetPendingVerificationAsync(); }
    private string GetPaymentIcon(string m) => m switch { "BankTransfer" => "🏦", "EWallet" => "📱", "QRIS" => "📲", "CreditCard" => "💳", _ => "💰" };
}
