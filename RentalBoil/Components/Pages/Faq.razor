@page "/faq"
@inject AppDbContext Db

@if (faqList != null)
{
    <div class="page-header">
        <h1 class="page-title">❓ FAQ</h1>
    </div>
    @foreach (var cat in faqCategories)
    {
        <h3 class="mt-24 mb-16" style="font-weight:700;">📁 @cat</h3>
        @foreach (var f in faqList.Where(x => x.Category == cat))
        {
            <details class="clay-card mb-8" style="padding:16px;">
                <summary style="font-weight:600;cursor:pointer;">@f.Question</summary>
                <div class="mt-8" style="color:var(--text-secondary);white-space:pre-line;">@f.Answer</div>
            </details>
        }
    }
}

@code {
    private List<RentalBoil.Models.Faq>? faqList;
    private List<string> faqCategories = new();

    protected override async Task OnInitializedAsync()
    {
        faqList = await Db.Faqs.Where(f => f.IsActive).OrderBy(f => f.SortOrder).ToListAsync();
        faqCategories = faqList.Select(f => f.Category).Distinct().ToList();
    }
}
