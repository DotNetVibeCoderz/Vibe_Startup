@page "/"

@inject VehicleService VehicleService
@inject NavigationManager Navigation

@if (popularVehicles != null)
{
    <section class="hero clay-card mb-24" style="padding: 48px; text-align: center; background: linear-gradient(135deg, var(--accent-light), var(--accent));">
        <h1 style="font-size: 2.5rem; font-weight: 800; color: white; margin-bottom: 8px;">🚗 RentalBoil</h1>
        <p style="font-size: 1.2rem; color: rgba(255,255,255,0.9); margin-bottom: 24px;">Rental Kendaraan Anti Ngambek! Mobil & Motor tersedia 24/7</p>
        <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
            <a href="/vehicles" class="btn-clay btn-clay-primary" style="font-size: 1.1rem; padding: 14px 32px; background: white; color: var(--accent);">🚘 Cari Kendaraan</a>
            <a href="/register" class="btn-clay" style="font-size: 1.1rem; padding: 14px 32px; background: rgba(255,255,255,0.2); color: white; border-color: rgba(255,255,255,0.3);">✨ Daftar Sekarang</a>
        </div>
    </section>

    <section>
        <div class="flex-between mb-16">
            <h2 class="page-title">🔥 Kendaraan Populer</h2>
            <a href="/vehicles" class="btn-clay">Lihat Semua <i class="bi bi-arrow-right"></i></a>
        </div>
        <div class="grid-3">
            @foreach (var v in popularVehicles)
            {
                var vid = v.Id;
                <div class="vehicle-card clay-card-interactive" @onclick="() => GoToDetail(vid)" style="cursor:pointer;">
                    <div class="vehicle-card-image" style="display:flex;align-items:center;justify-content:center;font-size:3rem;">
                        @(v.Type == VehicleType.Car ? "🚗" : "🏍️")
                    </div>
                    <div class="vehicle-card-body">
                        <div class="flex-between">
                            <span class="badge-clay @(v.Type == VehicleType.Car ? "badge-clay-accent" : "badge-clay-info")">@(v.Type == VehicleType.Car ? "Mobil" : "Motor")</span>
                            <div class="vehicle-card-rating">⭐ @v.AverageRating.ToString("F1")</div>
                        </div>
                        <h5 class="mt-8" style="font-weight:700;">@v.Name</h5>
                        <div class="flex-between mt-8">
                            <div class="vehicle-card-price">Rp @v.PricePerDay.ToString("N0") <small class="text-muted">/hari</small></div>
                            <span class="badge-clay badge-clay-success">@v.RentalCount x</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <section class="mt-24 mb-24">
        <h2 class="page-title text-center mb-24">✨ Kenapa RentalBoil?</h2>
        <div class="grid-3">
            <div class="stat-card"><div class="stat-icon" style="background:rgba(108,92,231,0.15);color:var(--accent);">🔒</div><div><div class="stat-value" style="font-size:1rem;">Aman</div><div class="stat-label">Verifikasi identitas</div></div></div>
            <div class="stat-card"><div class="stat-icon" style="background:rgba(0,184,148,0.15);color:var(--success);">💰</div><div><div class="stat-value" style="font-size:1rem;">Harga Kompetitif</div><div class="stat-label">Dynamic pricing</div></div></div>
            <div class="stat-card"><div class="stat-icon" style="background:rgba(253,203,110,0.15);color:var(--warning);">🗺️</div><div><div class="stat-value" style="font-size:1rem;">GPS Tracking</div><div class="stat-label">Real-time</div></div></div>
            <div class="stat-card"><div class="stat-icon" style="background:rgba(116,185,255,0.15);color:var(--info);">🤖</div><div><div class="stat-value" style="font-size:1rem;">AI Chat Bot</div><div class="stat-label">Bang Tony Brewok</div></div></div>
            <div class="stat-card"><div class="stat-icon" style="background:rgba(225,112,85,0.15);color:var(--danger);">🛡️</div><div><div class="stat-value" style="font-size:1rem;">Asuransi</div><div class="stat-label">Proteksi opsional</div></div></div>
            <div class="stat-card"><div class="stat-icon" style="background:rgba(108,92,231,0.15);color:var(--accent);">🎁</div><div><div class="stat-value" style="font-size:1rem;">Loyalty</div><div class="stat-label">Poin reward</div></div></div>
        </div>
    </section>
}

@code {
    private List<Vehicle>? popularVehicles;

    protected override async Task OnInitializedAsync()
    {
        popularVehicles = await VehicleService.GetPopularVehiclesAsync(6);
    }

    private void GoToDetail(int id) => Navigation.NavigateTo($"/vehicles/{id}");
}
