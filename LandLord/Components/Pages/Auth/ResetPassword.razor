@page "/reset-password"
@attribute [AllowAnonymous]

<PageTitle>🔑 Reset Password - LandLord</PageTitle>

<div class="animate-in" style="max-width:400px;margin:40px auto;">
    <div class="neo-card" style="padding:32px;">
        <div style="text-align:center;margin-bottom:20px;">
            <span style="font-size:3rem;">🔑</span>
            <h2 style="color:var(--accent);">Reset Password</h2>
            <p style="color:var(--text-secondary);">Masukkan email untuk reset password</p>
        </div>

        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="neo-badge @(_isSuccess ? "badge-success" : "badge-danger")" 
                 style="display:block;text-align:center;margin-bottom:16px;padding:12px;">
                @_message
            </div>
        }

        <div style="display:flex;flex-direction:column;gap:12px;">
            <input class="neo-input" @bind="_email" type="email" placeholder="Email terdaftar..." />
            <button class="neo-btn-primary" @onclick="HandleResetAsync" disabled="@_isLoading">
                @(_isLoading ? "🔄 Mengirim..." : "📧 Kirim Reset Link")
            </button>
        </div>

        <div style="text-align:center;margin-top:16px;">
            <a href="/login" style="color:var(--accent);">🔐 Kembali ke Login</a>
        </div>
    </div>
</div>

@code {
    private string _email = "";
    private string? _message;
    private bool _isSuccess, _isLoading;

    [Inject] private IAuthService AuthService { get; set; } = null!;

    private async Task HandleResetAsync()
    {
        _isLoading = true;
        _message = null;

        try
        {
            var result = await AuthService.ResetPasswordAsync(_email);
            _isSuccess = true;
            _message = "✅ Jika email terdaftar, link reset akan dikirimkan.";
        }
        catch
        {
            _isSuccess = false;
            _message = "❌ Terjadi kesalahan. Silakan coba lagi.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
