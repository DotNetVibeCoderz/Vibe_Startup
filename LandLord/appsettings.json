{
  "ConnectionStrings": { "DefaultConnection": "Data Source=LandLord.db" },
  "AppSettings": { "AppName": "LandLord", "AppVersion": "1.0.0", "Theme": "light" },

  "DatabaseProvider": {
    "Provider": "SQLite",
    "ConnectionString": "Data Source=LandLord.db"
  },

  "StorageProvider": {
    "Provider": "FileSystem",
    "BasePath": "wwwroot/uploads",
    "BaseUrl": "/uploads",
    "MaxFileSizeMB": 50,
    "AllowedExtensions": [".jpg",".jpeg",".png",".gif",".webp",".svg",".pdf",".mp4",".mp3",".doc",".docx",".xls",".xlsx",".zip"],
    "FileSystem": { "BasePath": "wwwroot/uploads", "BaseUrl": "/uploads" },
    "AzureBlob": { "ConnectionString": "DefaultEndpointsProtocol=https;xxx", "ContainerName": "landlord-documents", "CdnEndpoint": "" },
    "S3": { "AccessKey": "", "SecretKey": "", "BucketName": "landlord-documents", "Region": "ap-southeast-3", "PublicEndpoint": "" },
    "MinIO": { "AccessKey": "minioadmin", "SecretKey": "minioadmin", "BucketName": "landlord-documents", "Region": "us-east-1", "ServiceUrl": "http://localhost:9000", "PublicEndpoint": "http://localhost:9000" }
  },

  "VectorDB": { "Provider": "InMemory", "ConnectionString": "" },

  "LLMProvider": {
    "Provider": "OpenAI",
    "Model": "gpt-4o-mini",
    "Endpoint": "https://api.openai.com/v1/",
    "ApiKey": "sk-proj-open-ai-key",
    "Temperature": 0.7,
    "MaxTokens": 4096,
    "Providers": {
      "OpenAI": { "ApiKey": "sk-proj-open-ai-key", "Model": "gpt-4o-mini", "Endpoint": "https://api.openai.com/v1/" },
      "Anthropic": { "ApiKey": "", "Model": "claude-3-sonnet-20240229", "Endpoint": "" },
      "Gemini": { "ApiKey": "", "Model": "gemini-1.5-pro", "Endpoint": "" },
      "Ollama": { "ApiKey": "", "Model": "llama3", "Endpoint": "http://localhost:11434" }
    }
  },

  "ChatBot": {
    "Name": "Frengky Ganteng",
    "SystemPrompt": "Kamu adalah Frengky Ganteng, asisten virtual yang ramah dan informatif untuk aplikasi LandLord. Kamu membantu pengguna mencari informasi tentang tanah, bangunan, dan data properti. Kamu memiliki akses ke database tanah dan bangunan serta pencarian internet via Tavily. Gunakan fungsi yang tersedia untuk memberikan jawaban akurat. Jawab dalam bahasa Indonesia dengan gaya santai dan profesional. Gunakan emoji secukupnya.",
    "Temperature": 0.8,
    "MaxTokens": 4096,
    "MaxHistory": 20,
    "EnableInternetSearch": true,
    "EnableDatabaseQuery": true
  },

  "Tavily": {
    "ApiKey": "tvly-tavily-key",
    "BaseUrl": "https://api.tavily.com",
    "SearchDepth": "advanced",
    "IncludeAnswer": true,
    "IncludeRawContent": false,
    "IncludeImages": false,
    "MaxResults": 5,
    "TimeoutSeconds": 30
  },

  "GoogleMaps": {
    "ApiKey": "google-map-key",
    "DefaultCenterLat": -6.2088,
    "DefaultCenterLng": 106.8456,
    "DefaultZoom": 13
  },

  "SemanticSearch": { "Enabled": true, "MinScore": 0.7 },
  "Logging": { "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Warning" } },
  "AllowedHosts": "*"
}
