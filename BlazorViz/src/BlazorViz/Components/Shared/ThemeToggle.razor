@rendermode InteractiveServer
@inject IJSRuntime JS

<button class="btn sm" style="width:100%;" @onclick="Toggle">@(_dark ? "☀️ Light mode" : "🌙 Dark mode")</button>

@code {
    private bool _dark;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // initTheme re-applies the saved theme to <html> (it can get lost on navigation) and returns it
            var theme = await JS.InvokeAsync<string>("bv.initTheme");
            _dark = theme == "dark";
            StateHasChanged();
        }
    }

    private async Task Toggle()
    {
        _dark = !_dark;
        await JS.InvokeVoidAsync("bv.setTheme", _dark ? "dark" : "light");
    }
}
