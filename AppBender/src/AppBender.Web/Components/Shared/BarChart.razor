@* Simple responsive SVG bar chart. *@
<div class="ab-card">
    @if (!string.IsNullOrEmpty(Title))
    {
        <div class="ab-chart-title">@Title</div>
    }
    @if (Data.Count == 0)
    {
        <div class="text-secondary small">No data</div>
    }
    else
    {
        var max = Data.Values.Max();
        if (max <= 0) { max = 1; }
        var barWidth = Math.Max(8.0, (Width - 40.0) / Data.Count - 8);
        <svg class="ab-chart-svg" viewBox="0 0 @Width @Height" preserveAspectRatio="xMidYMid meet">
            @{ var i = 0; }
            @foreach (var (label, value) in Data)
            {
                var h = (value / max) * (Height - 55);
                var x = 20 + i * (barWidth + 8);
                var y = Height - 35 - h;
                <rect x="@F(x)" y="@F(y)" width="@F(barWidth)" height="@F(h)" rx="4"
                      fill="@Charts.Palette[i % Charts.Palette.Length]">
                    <title>@label: @value.ToString("0.##")</title>
                </rect>
                @SvgText(x + barWidth / 2, y - 5, value.ToString("0.#"))
                @SvgText(x + barWidth / 2, Height - 18, Trim(label))
                i++;
            }
        </svg>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public Dictionary<string, double> Data { get; set; } = [];
    [Parameter] public int Width { get; set; } = 560;
    [Parameter] public int Height { get; set; } = 240;

    private static string F(double d) => d.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
    private static string Trim(string s) => s.Length > 10 ? s[..9] + "…" : s;

    private static MarkupString SvgText(double x, double y, string content) => new(
        $"<text x=\"{F(x)}\" y=\"{F(y)}\" text-anchor=\"middle\" font-size=\"10\" fill=\"currentColor\">" +
        System.Net.WebUtility.HtmlEncode(content) + "</text>");
}
