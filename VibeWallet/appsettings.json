{
  "VibeWallet": {
    "AppName": "VibeWallet",
    "Version": "1.0.0",
    "Description": "Digital Wallet Application",
    "CompanyName": "VibeWallet Indonesia",
    "SupportEmail": "support@vibewallet.id",
    "SupportPhone": "+62812-3456-7890",
    "ItemsPerPage": 20,
    "MaxLoginAttempts": 5,
    "LockoutMinutes": 15,
    "SessionTimeoutMinutes": 30
  },

  "ConnectionStrings": {
    "Provider": "SQLite",
    "SQLite": "Data Source=Data/VibeWallet.db",
    "SQLServer": "Server=(localdb)\\mssqllocaldb;Database=VibeWallet;Trusted_Connection=True;MultipleActiveResultSets=true",
    "MySQL": "Server=localhost;Database=VibeWallet;User=root;Password=;",
    "Postgre": "Host=localhost;Database=VibeWallet;Username=postgres;Password=;"
  },

  "Storage": {
    "Provider": "FileSystem",
    "FileSystem": {
      "BasePath": "wwwroot/uploads"
    },
    "AzureBlob": {
      "ConnectionString": "",
      "ContainerName": "vibewallet"
    },
    "S3": {
      "AccessKey": "",
      "SecretKey": "",
      "BucketName": "vibewallet",
      "Region": "ap-southeast-1",
      "ServiceUrl": ""
    },
    "MinIO": {
      "Endpoint": "localhost:9000",
      "AccessKey": "minioadmin",
      "SecretKey": "minioadmin",
      "BucketName": "vibewallet",
      "UseSSL": false
    }
  },

  "ChatBot": {
    "Name": "Mbak Selvi",
    "Provider": "OpenAI",
    "SystemPrompt": "Kamu adalah Mbak Selvi, asisten virtual yang ramah dan helpful dari VibeWallet, aplikasi dompet digital terkemuka di Indonesia. Kamu membantu pengguna dengan pertanyaan seputar fitur VibeWallet, transaksi, saldo, pembayaran, dan layanan keuangan lainnya. Gunakan bahasa Indonesia yang santai dan ramah, sesekali gunakan kata 'kak', 'sahabat VibeWallet', atau 'bestie'. Kamu bisa membantu: cek saldo, mutasi transaksi, info promo, cara top-up, transfer, bayar tagihan, dan fitur lainnya. Jangan pernah memberikan informasi yang tidak kamu ketahui, selalu arahkan ke CS untuk masalah serius.",
    "Temperature": 0.7,
    "MaxTokens": 2000,
    "TopP": 0.9,
    "Models": {
      "OpenAI": {
        "ApiKey": "sk-proj-xxx",
        "ModelId": "gpt-4o-mini",
        "Endpoint": "https://api.openai.com/v1"
      },
      "Anthropic": {
        "ApiKey": "",
        "ModelId": "claude-3-5-sonnet-20241022",
        "Endpoint": "https://api.anthropic.com/v1/messages"
      },
      "Gemini": {
        "ApiKey": "",
        "ModelId": "gemini-1.5-pro",
        "Endpoint": ""
      },
      "Ollama": {
        "ModelId": "llama3.2",
        "Endpoint": "http://localhost:11434"
      }
    },
    "Tavily": {
      "ApiKey": "tvly-dev-xxx",
      "Endpoint": "https://api.tavily.com/search"
    }
  },

  "TransactionLimits": {
    "DailyTransferLimit": 25000000,
    "DailyTopUpLimit": 10000000,
    "DailyPaymentLimit": 50000000,
    "MonthlyTransferLimit": 100000000,
    "MaxWalletBalance": 50000000,
    "MinTransferAmount": 10000,
    "MinTopUpAmount": 5000
  },

  "Rewards": {
    "CashbackPercentage": 0.5,
    "PointsPerTransaction": 1,
    "MinimumTransactionForPoints": 10000,
    "PointsExchangeRate": 1000
  },

  "KYC": {
    "RequiredForTransactions": true,
    "MaxUploadSizeMB": 5,
    "AllowedFileTypes": [".jpg", ".jpeg", ".png", ".pdf"],
    "AutoVerificationEnabled": false
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}
