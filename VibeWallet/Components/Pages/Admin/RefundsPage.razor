@page "/admin/refunds"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject VibeWallet.Data.VibeWalletDbContext Db

<PageTitle>Refund & Dispute - Admin</PageTitle>

<div class="animate-fade-in">
    <h2 class="mb-lg">↩️ Refund & Dispute Handling</h2>
    <div class="card-neumorph">
        <div class="table-wrapper">
            <table>
                <thead><tr><th>Ref</th><th>User</th><th>Amount</th><th>Type</th><th>Status</th><th>Date</th><th>Actions</th></tr></thead>
                <tbody>
                    @foreach (var tx in _transactions)
                    {
                        <tr>
                            <td class="text-sm" style="font-family:monospace;">@tx.TransactionRef</td>
                            <td>@_userNames.GetValueOrDefault(tx.UserId, "?")</td>
                            <td class="font-bold">Rp @Math.Abs(tx.Amount).ToString("N0")</td>
                            <td><span class="badge badge-info">@tx.Type</span></td>
                            <td><span class="badge @(tx.Status == TransactionStatus.Completed ? "badge-success" : tx.Status == TransactionStatus.Pending ? "badge-warning" : "badge-danger")">@tx.Status</span></td>
                            <td class="text-sm">@tx.CreatedAt.ToString("dd/MM HH:mm")</td>
                            <td class="flex gap-sm">
                                @if (tx.Status == TransactionStatus.Completed)
                                {
                                    <button class="btn btn-sm btn-warning" @onclick="() => RefundTx(tx)">↩️ Refund</button>
                                }
                                @if (tx.Status == TransactionStatus.Pending)
                                {
                                    <button class="btn btn-sm btn-danger" @onclick="() => CancelTx(tx)">❌ Cancel</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(_msg))
    {
        <div class="mt-md card-flat p-md" style="background:rgba(16,185,129,0.1);color:var(--accent-success);">✅ @_msg</div>
    }
</div>

@code {
    private List<WalletTransaction> _transactions = new();
    private Dictionary<Guid, string> _userNames = new();
    private string _msg = "";

    protected override async Task OnInitializedAsync()
    {
        _transactions = await Db.WalletTransactions.Where(t => t.Type == TransactionType.Payment && t.CreatedAt >= DateTime.UtcNow.AddDays(-30)).OrderByDescending(t => t.CreatedAt).Take(100).ToListAsync();
        var ids = _transactions.Select(t => t.UserId).Distinct().ToList();
        _userNames = await Db.Users.Where(u => ids.Contains(u.Id)).ToDictionaryAsync(u => u.Id, u => u.FullName);
    }

    private async Task RefundTx(WalletTransaction tx)
    {
        var wallet = await Db.Wallets.FirstOrDefaultAsync(w => w.UserId == tx.UserId);
        if (wallet == null) return;
        wallet.Balance += Math.Abs(tx.Amount);
        var refund = new WalletTransaction
        {
            WalletId = wallet.Id, UserId = tx.UserId, TransactionRef = $"REFUND-{tx.TransactionRef}",
            Type = TransactionType.Refund, Status = TransactionStatus.Completed, Method = PaymentMethod.WalletBalance,
            Amount = Math.Abs(tx.Amount), Fee = 0, BalanceBefore = wallet.Balance - Math.Abs(tx.Amount),
            BalanceAfter = wallet.Balance, Description = $"Refund for {tx.TransactionRef}", CompletedAt = DateTime.UtcNow
        };
        Db.WalletTransactions.Add(refund);
        tx.Status = TransactionStatus.Reversed;
        await Db.SaveChangesAsync();
        _msg = $"Refund processed: {tx.TransactionRef}";
        await OnInitializedAsync();
    }

    private async Task CancelTx(WalletTransaction tx)
    {
        tx.Status = TransactionStatus.Cancelled;
        await Db.SaveChangesAsync();
        _msg = $"Transaction cancelled: {tx.TransactionRef}";
        await OnInitializedAsync();
    }
}

<style>
.table-wrapper { overflow-x: auto; }
.btn-warning { background: var(--accent-warning); color: white; }
.btn-warning:hover { filter: brightness(1.1); }
</style>
