@page "/payment/bills"
@inject IPaymentService PaymentService
@inject AuthenticationStateProvider AuthState
@attribute [Authorize]

<PageTitle>Bayar Tagihan - VibeWallet</PageTitle>

<div class="animate-fade-in">
    <h2 class="mb-lg">📋 <span class="text-gradient">Bayar Tagihan</span></h2>

    <div class="grid grid-3 mb-lg">
        <div class="card-neumorph p-md text-center" style="cursor:pointer;" @onclick="() => _selectedBill = BillType.Electricity">
            <div style="font-size:2.5rem;">⚡</div>
            <div class="font-semibold">Listrik (PLN)</div>
            <div class="text-sm text-muted">Token & Pascabayar</div>
            @if (_selectedBill == BillType.Electricity) { <span class="badge badge-purple mt-sm">Dipilih</span> }
        </div>
        <div class="card-neumorph p-md text-center" style="cursor:pointer;" @onclick="() => _selectedBill = BillType.Water">
            <div style="font-size:2.5rem;">💧</div>
            <div class="font-semibold">Air (PDAM)</div>
            <div class="text-sm text-muted">PDAM seluruh Indonesia</div>
            @if (_selectedBill == BillType.Water) { <span class="badge badge-purple mt-sm">Dipilih</span> }
        </div>
        <div class="card-neumorph p-md text-center" style="cursor:pointer;" @onclick="() => _selectedBill = BillType.BPJS">
            <div style="font-size:2.5rem;">🏥</div>
            <div class="font-semibold">BPJS</div>
            <div class="text-sm text-muted">Kesehatan & Ketenagakerjaan</div>
            @if (_selectedBill == BillType.BPJS) { <span class="badge badge-purple mt-sm">Dipilih</span> }
        </div>
        <div class="card-neumorph p-md text-center" style="cursor:pointer;" @onclick="() => _selectedBill = BillType.Internet">
            <div style="font-size:2.5rem;">🌐</div>
            <div class="font-semibold">Internet & TV</div>
            <div class="text-sm text-muted">Indihome, First Media, dll</div>
            @if (_selectedBill == BillType.Internet) { <span class="badge badge-purple mt-sm">Dipilih</span> }
        </div>
        <div class="card-neumorph p-md text-center" style="cursor:pointer;" @onclick="() => _selectedBill = BillType.TVCable">
            <div style="font-size:2.5rem;">📺</div>
            <div class="font-semibold">TV Kabel</div>
            <div class="text-sm text-muted">Berlangganan TV</div>
            @if (_selectedBill == BillType.TVCable) { <span class="badge badge-purple mt-sm">Dipilih</span> }
        </div>
        <div class="card-neumorph p-md text-center" style="cursor:pointer;" @onclick="() => _selectedBill = BillType.Education">
            <div style="font-size:2.5rem;">🎓</div>
            <div class="font-semibold">Pendidikan</div>
            <div class="text-sm text-muted">SPP & Biaya Kuliah</div>
            @if (_selectedBill == BillType.Education) { <span class="badge badge-purple mt-sm">Dipilih</span> }
        </div>
    </div>

    <div class="card-neumorph p-xl">
        <h3>📝 Detail Pembayaran - @_selectedBill</h3>
        <div class="grid grid-2 mt-md">
            <div>
                <div class="form-group">
                    <label class="form-label">Provider</label>
                    <select class="form-input" @bind="_providerName">
                        <option value="">Pilih Provider</option>
                        @foreach (var p in GetProvidersForBill(_selectedBill))
                        { <option value="@p">@p</option> }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Nomor Pelanggan</label>
                    <input class="form-input" @bind="_customerId" placeholder="Masukkan nomor pelanggan" />
                </div>
                <div class="form-group">
                    <label class="form-label">Periode Tagihan</label>
                    <input class="form-input" @bind="_billPeriod" placeholder="YYYYMM (contoh: 202501)" />
                </div>
                <button class="btn btn-secondary w-full" @onclick="CheckBill">🔍 Cek Tagihan</button>
            </div>
            <div>
                @if (_billAmount > 0)
                {
                    <div class="card-flat p-xl" style="background:rgba(16,185,129,0.08);">
                        <div class="text-sm text-muted">Total Tagihan</div>
                        <div style="font-size:2rem;font-weight:800;color:var(--accent-success);">Rp @_billAmount.ToString("N0")</div>
                        <div class="text-sm text-muted mt-sm">Biaya Admin: Rp 2.500</div>
                        <div class="font-semibold text-lg mt-sm">Total: Rp @((_billAmount + 2500).ToString("N0"))</div>
                        <button class="btn btn-primary w-full mt-md" @onclick="PayBill" disabled="@_isPaying">
                            @(_isPaying ? "Memproses..." : "💳 Bayar Sekarang")
                        </button>
                    </div>
                }
                @if (!string.IsNullOrEmpty(_result))
                {
                    <div class="mt-md" style="color:@(_success ? "var(--accent-success)" : "var(--accent-danger)")">
                        @(_success ? "✅" : "❌") @_result
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private BillType _selectedBill = BillType.Electricity;
    private string _providerName = "";
    private string _customerId = "";
    private string _billPeriod = DateTime.UtcNow.AddHours(7).ToString("yyyyMM");
    private decimal _billAmount;
    private bool _isPaying;
    private string _result = "";
    private bool _success;
    private Guid _userId;

    private string[] GetProvidersForBill(BillType t) => t switch
    {
        BillType.Electricity => new[] { "PLN", "PLN Prepaid" },
        BillType.Water => new[] { "PDAM", "Aetra", "Palyja" },
        BillType.BPJS => new[] { "BPJS Kesehatan", "BPJS Ketenagakerjaan" },
        BillType.Internet => new[] { "IndiHome", "First Media", "Biznet", "MyRepublic", "MNC Play" },
        BillType.TVCable => new[] { "IndiHome TV", "First Media", "MNC Vision", "TransVision" },
        BillType.Education => new[] { "Universitas Terbuka", "Bimbel Online" },
        _ => Array.Empty<string>()
    };

    protected override async Task OnInitializedAsync()
    {
        var u = await AuthState.GetAuthenticationStateAsync();
        var uid = u.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (uid != null) _userId = Guid.Parse(uid.Value);
    }

    private async Task CheckBill()
    {
        if (string.IsNullOrWhiteSpace(_providerName)) { _result = "Pilih provider dulu."; _success = false; return; }
        if (string.IsNullOrWhiteSpace(_customerId)) { _result = "Masukkan nomor pelanggan."; _success = false; return; }
        _billAmount = await PaymentService.CheckBillAmountAsync(_selectedBill, _customerId);
        _result = ""; _success = true;
    }

    private async Task PayBill()
    {
        _isPaying = true;
        try
        {
            var bill = await PaymentService.PayBillAsync(_userId, _selectedBill, _providerName, _customerId, _billAmount, _billPeriod);
            _result = $"Pembayaran berhasil! Ref: {bill.PaymentRef}"; _success = true; _billAmount = 0;
        }
        catch (Exception ex) { _result = ex.Message; _success = false; }
        finally { _isPaying = false; }
    }
}
