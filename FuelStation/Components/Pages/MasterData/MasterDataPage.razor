    private async Task SaveProduct()
    {
        if (string.IsNullOrWhiteSpace(_productForm.Name)) return;
        if (_editingProduct != null)
        {
            var existing = await Db.FuelProducts.FindAsync(_editingProduct.Id);
            if (existing != null)
            {
                existing.Name = _productForm.Name;
                existing.Code = _productForm.Code;
                existing.FuelType = _productForm.FuelType;
                existing.OctaneRating = _productForm.OctaneRating;
                existing.PricePerLiter = _productForm.PricePerLiter;
                existing.CostPerLiter = _productForm.CostPerLiter;
                existing.ColorCode = _productForm.ColorCode;
                existing.IsActive = _productForm.IsActive;
                existing.UpdatedAt = DateTime.UtcNow;
            }
        }
        else
        {
            var newProduct = new FuelProduct
            {
                Id = Guid.NewGuid(),
                Name = _productForm.Name,
                Code = _productForm.Code,
                FuelType = _productForm.FuelType,
                OctaneRating = _productForm.OctaneRating,
                PricePerLiter = _productForm.PricePerLiter,
                CostPerLiter = _productForm.CostPerLiter,
                ColorCode = _productForm.ColorCode,
                IsActive = _productForm.IsActive,
                CreatedAt = DateTime.UtcNow
            };
            Db.FuelProducts.Add(newProduct);
        }

        await Db.SaveChangesAsync();
        _showAddModal = false;
        await LoadData();
    }

