@page "/pos"
@using FuelStation.Data
@using FuelStation.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject Services.IPrinterService PrinterService
@inject NavigationManager Nav

<PageTitle>POS Kasir - FuelStation</PageTitle>

<div class="pos-grid">
    <!-- Left: Product Selection -->
    <div style="display:flex;flex-direction:column;gap:16px;">
        <div class="flex-between">
            <h2 style="font-weight:800;">⛽ Point of Sale</h2>
            <div class="flex-center gap-1">
                <select class="form-select" style="width:auto;" @bind="_selectedStationId">
                    <option value="">-- Pilih Stasiun --</option>
                    @foreach (var s in _stations)
                    {
                        <option value="@s.Id.ToString()">@s.Name</option>
                    }
                </select>
                <button class="btn btn-sm" @onclick="ClearOrder">🔄 Reset</button>
            </div>
        </div>

        <!-- Fuel Products Grid -->
        <div class="pos-products">
            @foreach (var product in _fuelProducts)
            {
                <button class="pos-product-btn @(_selectedProduct?.Id == product.Id ? "selected" : "")"
                        @onclick="() => SelectProduct(product)"
                        style="border-left:8px solid @(product.ColorCode ?? "#666");">
                    <div style="font-size:2rem;">⛽</div>
                    <div style="font-weight:800;">@product.Name</div>
                    <div style="font-size:0.85rem;color:var(--text-secondary);">@product.OctaneRating</div>
                    <div style="font-weight:700;margin-top:4px;">Rp @product.PricePerLiter.ToString("N0")/L</div>
                </button>
            }
        </div>

        <!-- Numeric Keypad for Liters -->
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;">
            @foreach (var key in new[] { "7", "8", "9", "⌫", "4", "5", "6", "C", "1", "2", "3", "5L", "0", "00", ".", "10L" })
            {
                <button class="btn @(key == "⌫" || key == "C" ? "btn-danger" : "")" style="padding:16px;font-size:1.3rem;"
                        @onclick='() => HandleKeypad(key)'>
                    @key
                </button>
            }
        </div>

        <!-- Quick Liter Buttons -->
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
            @foreach (var preset in new[] { 1m, 2m, 5m, 10m, 20m, 30m })
            {
                <button class="btn btn-sm" @onclick="() => _litersInput = preset.ToString()"
                        style="@(_litersInput == preset.ToString() ? "background:var(--accent);" : "")">
                    @preset L
                </button>
            }
        </div>
    </div>

    <!-- Right: Transaction Summary -->
    <div class="pos-summary">
        <h3 style="font-weight:800;margin-bottom:8px;">🧾 Ringkasan</h3>

        @if (_currentItem != null)
        {
            <div style="background:var(--accent-light);padding:12px;border-radius:8px;border:2px solid var(--border-bold);margin-bottom:12px;">
                <div style="font-weight:800;font-size:1.2rem;">@_currentItem.Value.ProductName</div>
                <div>@_currentItem.Value.Liters.ToString("F2") L x Rp @_currentItem.Value.PricePerLiter.ToString("N0")</div>
                <div style="font-weight:800;font-size:1.3rem;text-align:right;">Rp @_currentItem.Value.Subtotal.ToString("N0")</div>
            </div>
        }

        <!-- Payment Method Selection -->
        <div style="font-weight:700;margin-bottom:8px;">Metode Pembayaran:</div>
        <div class="pos-payment-grid">
            @foreach (var method in _paymentMethods)
            {
                <button class="pos-payment-btn @(_selectedPayment == method ? "selected" : "")"
                        @onclick="() => _selectedPayment = method">
                    @GetPaymentIcon(method) @method
                </button>
            }
        </div>

        @if (_selectedPayment == "QRIS")
        {
            <div style="text-align:center;padding:16px;background:white;border-radius:8px;margin:8px 0;border:2px solid var(--border-bold);">
                <div style="font-weight:700;margin-bottom:4px;">Scan QRIS</div>
                <div style="font-size:0.8rem;color:var(--text-secondary);">Menunggu pembayaran...</div>
            </div>
        }

        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="alert @(_isSuccess ? "alert-success" : "alert-danger")">@_message</div>
        }

        <div style="flex:1;"></div>

        <!-- Grand Total -->
        <div style="border-top:3px solid var(--border-bold);padding-top:12px;">
            <div class="pos-total">Rp @(_currentItem?.Subtotal.ToString("N0") ?? "0")</div>
        </div>

        <!-- Action Buttons -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:12px;">
            <button class="btn btn-danger btn-lg" @onclick="ClearOrder" style="padding:16px;">
                ❌ Batal
            </button>
            <button class="btn btn-success btn-lg" @onclick="ProcessTransaction"
                    disabled="@(_currentItem == null || string.IsNullOrEmpty(_selectedPayment))"
                    style="padding:16px;">
                ✅ Bayar
            </button>
        </div>

        @if (_lastReceiptHtml != null)
        {
            <button class="btn btn-info btn-lg mt-1" @onclick="PrintReceipt" style="padding:14px;">
                🖨️ Cetak Struk
            </button>
        }
    </div>
</div>

<!-- Receipt Preview Modal -->
@if (_showReceipt)
{
    <div style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.6);z-index:1000;display:flex;align-items:center;justify-content:center;"
         @onclick="() => _showReceipt = false">
        <div style="background:white;padding:24px;border-radius:12px;border:3px solid var(--border-bold);max-height:80vh;overflow:auto;"
             @onclick:stopPropagation="true">
            <div class="flex-between mb-2">
                <h3>📄 Struk Pembayaran</h3>
                <button class="btn btn-sm" @onclick="() => _showReceipt = false">✕ Tutup</button>
            </div>
            <div style="width:320px;margin:0 auto;">
                @((MarkupString)_lastReceiptHtml!)
            </div>
            <div class="flex-center gap-2 mt-2">
                <button class="btn btn-primary" @onclick="PrintReceipt">🖨️ Cetak</button>
                <button class="btn" @onclick="() => _showReceipt = false">Tutup</button>
            </div>
        </div>
    </div>
}

@code {
    private List<FuelStationLocation> _stations = new();
    private List<FuelProduct> _fuelProducts = new();
    private FuelProduct? _selectedProduct;
    private string? _selectedStationId;
    private string _litersInput = "";
    private string _selectedPayment = "Cash";
    private string? _message;
    private bool _isSuccess;
    private string? _lastReceiptHtml;
    private bool _showReceipt;

    private readonly string[] _paymentMethods = { "Cash", "QRIS", "EWallet", "DebitCard", "CreditCard", "BankTransfer" };

    private (string ProductName, decimal Liters, decimal PricePerLiter, decimal Subtotal)? _currentItem;

    protected override async Task OnInitializedAsync()
    {
        _stations = await Db.FuelStations.Where(s => s.IsActive).ToListAsync();
        _fuelProducts = await Db.FuelProducts.Where(p => p.IsActive).ToListAsync();
        if (_stations.Any()) _selectedStationId = _stations.First().Id.ToString();
    }

    private void SelectProduct(FuelProduct product)
    {
        _selectedProduct = product;
        UpdateCurrentItem();
    }

    private void HandleKeypad(string key)
    {
        switch (key)
        {
            case "⌫":
                if (_litersInput.Length > 0) _litersInput = _litersInput[..^1];
                break;
            case "C":
                _litersInput = "";
                break;
            case "5L":
                _litersInput = "5";
                break;
            case "10L":
                _litersInput = "10";
                break;
            default:
                _litersInput += key;
                break;
        }
        UpdateCurrentItem();
    }

    private void UpdateCurrentItem()
    {
        if (_selectedProduct == null || !decimal.TryParse(_litersInput, out var liters) || liters <= 0)
        {
            _currentItem = null;
            return;
        }
        _currentItem = (_selectedProduct.Name, liters, _selectedProduct.PricePerLiter, liters * _selectedProduct.PricePerLiter);
    }

    private async Task ProcessTransaction()
    {
        if (_currentItem == null || string.IsNullOrEmpty(_selectedStationId)) return;

        try
        {
            var product = _selectedProduct!;
            var tx = new Transaction
            {
                Id = Guid.NewGuid(),
                TransactionNumber = $"TRX-{DateTime.UtcNow:yyyyMMddHHmmss}-{Guid.NewGuid():N}"[..25],
                TransactionDate = DateTime.UtcNow,
                FuelStationId = Guid.Parse(_selectedStationId),
                TotalAmount = _currentItem.Value.Subtotal,
                GrandTotal = _currentItem.Value.Subtotal,
                PaymentMethod = _selectedPayment,
                Status = "Completed",
                PaymentReference = _selectedPayment == "QRIS" ? $"QRIS-{Guid.NewGuid():N}"[..12] : null
            };

            tx.TransactionDetails.Add(new TransactionDetail
            {
                Id = Guid.NewGuid(),
                TransactionId = tx.Id,
                FuelProductId = product.Id,
                Liters = _currentItem.Value.Liters,
                PricePerLiter = product.PricePerLiter,
                Subtotal = _currentItem.Value.Subtotal
            });

            Db.Transactions.Add(tx);

            // Update tank
            var tank = await Db.Tanks
                .FirstOrDefaultAsync(t => t.FuelProductId == product.Id && t.FuelStationId == tx.FuelStationId);
            if (tank != null)
                tank.CurrentVolumeLiters = Math.Max(0, tank.CurrentVolumeLiters - _currentItem.Value.Liters);

            await Db.SaveChangesAsync();

            // Generate receipt
            var station = _stations.FirstOrDefault(s => s.Id == tx.FuelStationId);
            _lastReceiptHtml = await PrinterService.GenerateReceiptHtml(tx, station?.Name ?? "FuelStation");

            _message = $"✅ Transaksi berhasil! No: {tx.TransactionNumber}";
            _isSuccess = true;
            _showReceipt = true;

            ClearOrder();
        }
        catch (Exception ex)
        {
            _message = $"❌ Error: {ex.Message}";
            _isSuccess = false;
        }
    }

    private void ClearOrder()
    {
        _selectedProduct = null;
        _litersInput = "";
        _currentItem = null;
        _message = null;
    }

    private async Task PrintReceipt()
    {
        if (_lastReceiptHtml != null)
        {
            // Trigger browser print
            await Task.CompletedTask;
        }
    }

    private static string GetPaymentIcon(string method) => method switch
    {
        "Cash" => "💵",
        "QRIS" => "📱",
        "EWallet" => "💳",
        "DebitCard" => "🏦",
        "CreditCard" => "💳",
        "BankTransfer" => "🏧",
        _ => "💰"
    };
}
