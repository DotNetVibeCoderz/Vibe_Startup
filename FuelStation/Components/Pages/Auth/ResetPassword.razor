@page "/reset-password"
@attribute [AllowAnonymous]
@using System.ComponentModel.DataAnnotations
@using FuelStation.Data
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>Reset Password - FuelStation</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-title">🔁 Reset Password</div>
        <div class="auth-subtitle">Masukkan email dan password baru</div>

        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="alert @(_isSuccess ? "alert-success" : "alert-danger")">@_message</div>
        }

        <EditForm Model="_input" OnValidSubmit="HandleReset">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-1">
                <label class="form-label">Email</label>
                <InputText class="form-input" @bind-Value="_input.Email" placeholder="name@fuelstation.com" />
            </div>

            <div class="mb-1">
                <label class="form-label">Password Baru</label>
                <InputText type="password" class="form-input" @bind-Value="_input.NewPassword" placeholder="Minimal 6 karakter" />
            </div>

            <div class="mb-2">
                <label class="form-label">Konfirmasi Password</label>
                <InputText type="password" class="form-input" @bind-Value="_input.ConfirmPassword" />
            </div>

            <button class="btn btn-primary" type="submit" style="width:100%;">🔐 Reset</button>
        </EditForm>

        <div class="auth-footer">
            Kembali ke <a href="/login"><strong>Login</strong></a>
        </div>
    </div>
</div>

@code {
    private readonly ResetInput _input = new();
    private string? _message;
    private bool _isSuccess;

    private async Task HandleReset()
    {
        if (_input.NewPassword != _input.ConfirmPassword)
        {
            _isSuccess = false;
            _message = "❌ Konfirmasi password tidak cocok.";
            return;
        }

        var user = await UserManager.FindByEmailAsync(_input.Email);
        if (user == null)
        {
            _isSuccess = false;
            _message = "❌ User tidak ditemukan.";
            return;
        }

        var token = await UserManager.GeneratePasswordResetTokenAsync(user);
        var result = await UserManager.ResetPasswordAsync(user, token, _input.NewPassword);

        if (!result.Succeeded)
        {
            _isSuccess = false;
            _message = string.Join("\n", result.Errors.Select(e => e.Description));
            return;
        }

        _isSuccess = true;
        _message = "✅ Password berhasil direset.";
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private sealed class ResetInput
    {
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required, MinLength(6)]
        public string NewPassword { get; set; } = string.Empty;

        [Required, MinLength(6)]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
