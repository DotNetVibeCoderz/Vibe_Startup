@page "/simulator"
@using FuelStation.Services
@inject SimulatorService Simulator
@implements IAsyncDisposable

<PageTitle>Simulator - FuelStation</PageTitle>

<h2 class="mb-2" style="font-weight:800;">🚗 Background Simulator</h2>

<div class="grid-2 mb-2">
    <!-- Control Panel -->
    <div class="card">
        <div class="card-header"><span class="card-title">🎮 Kontrol Simulator</span></div>

        <div class="stats-grid mb-2">
            <div class="stat-card">
                <div class="stat-value" style="color: @(Simulator.IsRunning ? "var(--success)" : "var(--danger)")">
                    @(Simulator.IsRunning ? "▶️ ON" : "⏹️ OFF")
                </div>
                <div class="stat-label">Status</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@Simulator.TotalTransactions</div>
                <div class="stat-label">Total Transaksi</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@Simulator.Vehicles.Count</div>
                <div class="stat-label">Kendaraan Aktif</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@Simulator.TransactionsPerSecond/s</div>
                <div class="stat-label">Throughput</div>
            </div>
        </div>

        <div class="flex-center gap-1">
            @if (!Simulator.IsRunning)
            {
                <button class="btn btn-success btn-lg" @onclick="() => Simulator.Start()">▶️ Start</button>
            }
            else
            {
                <button class="btn btn-danger btn-lg" @onclick="() => Simulator.Stop()">⏹️ Stop</button>
            }
            <button class="btn btn-warning btn-lg" @onclick="ClearLogs">🗑️ Clear Log</button>
            <button class="btn btn-info btn-lg" @onclick="RunStressTest">🔥 Stress Test</button>
        </div>

        @if (_lastStressResult != null)
        {
            <div class="card mt-2" style="background:var(--warning-light);">
                <div class="card-title">📊 Hasil Stress Test</div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
                    <div>Total Order: <strong>@_lastStressResult.TotalOrders</strong></div>
                    <div>Concurrent: <strong>@_lastStressResult.ConcurrentOrders</strong></div>
                    <div>Completed: <strong style="color:var(--success);">@_lastStressResult.Completed</strong></div>
                    <div>Failed: <strong style="color:var(--danger);">@_lastStressResult.Failed</strong></div>
                    <div>Duration: <strong>@_lastStressResult.TotalDurationMs.ToString("F0") ms</strong></div>
                    <div>Avg Response: <strong>@_lastStressResult.AverageResponseMs.ToString("F1") ms</strong></div>
                    <div>Min/Max: <strong>@_lastStressResult.MinResponseMs.ToString("F0") / @_lastStressResult.MaxResponseMs.ToString("F0") ms</strong></div>
                    <div>Orders/s: <strong>@_lastStressResult.OrdersPerSecond.ToString("F1")</strong></div>
                </div>
            </div>
        }
    </div>

    <!-- Vehicles -->
    <div class="card">
        <div class="card-header">
            <span class="card-title">🚙 Kendaraan Aktif (@Simulator.Vehicles.Count)</span>
            <button class="btn btn-sm" @onclick="ClearVehicles">🗑️ Clear</button>
        </div>
        <div style="max-height:300px;overflow-y:auto;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Plat</th>
                        <th>BBM</th>
                        <th>Liter</th>
                        <th>Status</th>
                        <th>Stasiun</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Simulator.Vehicles.OrderByDescending(v => v.ArrivalTime))
                    {
                        <tr>
                            <td style="font-weight:700;">@v.LicensePlate</td>
                            <td>@v.FuelType</td>
                            <td class="text-right">@v.RequestedLiters.ToString("F1")L</td>
                            <td>
                                <span class="badge @(v.Status == "Completed" ? "badge-success" : v.Status == "Fueling" ? "badge-warning" : "badge-info")">
                                    @(v.Status == "Arrived" ? "🚗 Datang" : v.Status == "Fueling" ? "⛽ Isi" : "✅ Selesai")
                                </span>
                            </td>
                            <td>@v.StationName</td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (!Simulator.Vehicles.Any())
            {
                <p class="text-muted text-center mt-2">Tidak ada kendaraan</p>
            }
        </div>
    </div>
</div>

<!-- Logs -->
<div class="card">
    <div class="card-header">
        <span class="card-title">📝 Simulation Log</span>
        <span class="text-muted">@Simulator.Logs.Count entries</span>
    </div>
    <div style="max-height:400px;overflow-y:auto;font-family:var(--font-mono);font-size:0.85rem;">
        @foreach (var log in Simulator.Logs.OrderByDescending(l => l.Time).Take(100))
        {
            <div style="padding:4px 12px;border-bottom:1px solid var(--border-color);">
                <span style="color:var(--text-muted);">@log.Time.ToLocalTime().ToString("HH:mm:ss.fff")</span>
                <span style="margin-left:8px;">@log.Message</span>
            </div>
        }
    </div>
</div>

@code {
    private StressTestResult? _lastStressResult;
    private System.Timers.Timer? _uiTimer;

    protected override void OnInitialized()
    {
        _uiTimer = new System.Timers.Timer(1000);
        _uiTimer.Elapsed += (_, _) => InvokeAsync(StateHasChanged);
        _uiTimer.Start();
    }

    private async Task RunStressTest()
    {
        _lastStressResult = await Simulator.RunStressTest(10, 50);
    }

    private void ClearLogs() => Simulator.ClearLogs();
    private void ClearVehicles() => Simulator.ClearVehicles();

    public async ValueTask DisposeAsync()
    {
        if (_uiTimer != null)
        {
            _uiTimer.Stop();
            _uiTimer.Dispose();
        }
        await Task.CompletedTask;
    }
}
